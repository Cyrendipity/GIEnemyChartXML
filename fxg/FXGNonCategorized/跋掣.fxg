		<BitmapImage source="@Embed('/跋掣.assets/Image_22.png')" x="720" y="138">
		</BitmapImage>
		<BitmapImage source="@Embed('/跋掣.assets/Image_23.png')" x="1392" y="137">
		</BitmapImage>
		<BitmapImage source="@Embed('/跋掣.assets/Image_24.png')" x="720" y="425">
		</BitmapImage>
		<BitmapImage source="@Embed('/跋掣.assets/Image_25.png')" x="720" y="713">
		</BitmapImage>
		<BitmapImage source="@Embed('/跋掣.assets/Image_26.png')" x="1391" y="425">
		</BitmapImage>
		<RichText x="738" y="223" width="439" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">跋掣一支发射6个水珠追踪玩家，每个造成<span color="#7fbfff">40%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/跋掣.assets/Image_27.png')" x="596" y="171" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/跋掣.assets/Image_28.png')" x="576" y="150" blendMode="normal">
		</BitmapImage>
		<RichText x="1410" y="223" width="424" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">跋掣一支在边缘不断移动，使用口部吸引玩家，之后喷出巨大喷流，造成<span color="#7fbfff">70%</span><span>伤害，继续接触喷流则额外再造成3段</span><span color="#7fbfff">40%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="511" width="408" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">跋掣一支后倾，然后用力朝前方撞去，造成<span color="#7fbfff">80%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="739" y="799" width="440" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">当跋掣只剩下一支时，每15s，在场上产生8个下落的水弹，每个造成<span color="#7fbfff">40%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="511" width="425" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">跋掣一支在场地中间产生一个漩涡，吸引玩家并持续造成<span color="#7fbfff">40%</span><span>伤害，5s后漩涡喷发，造成</span><span color="#7fbfff">100%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="77" y="501" fontFamily="仓耳渔阳体 W04" fontSize="40" fontStyle="italic" fontWeight="normal" color="#7fbfff" width="286" height="43" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="仓耳渔阳体 W04" fontSize="40" fontStyle="italic" color="#7fbfff">「漩涡的余威」</p>
			</content>
			<filters>
