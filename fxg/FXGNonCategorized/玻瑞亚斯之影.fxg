		<RichText x="738" y="223" width="424" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">玻瑞亚斯使用左或右爪迅速划击，造成<span color="#99ffff">58.3%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_30.png')" x="720" y="138">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_31.png')" x="596" y="171" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_32.png')" x="576" y="150" blendMode="normal">
		</BitmapImage>
		<RichText x="1410" y="223" width="433" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">玻瑞亚斯在自身位置产生霜气，随后旋转身迅速划击，造成<span color="#99ffff">83.3%</span><span>伤害</span><span color="#ffbfbf">(闪避帧无效)</span><span>，并产生一个</span><span color="#99ffff">冰元素晶球</span><span>。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_33.png')" x="1391" y="138">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_34.png')" x="1268" y="171" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_35.png')" x="1248" y="150" blendMode="normal">
		</BitmapImage>
		<RichText x="738" y="447" width="423" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">玻瑞亚斯在落地的位置产生寒气，随后跳跃至此，造成<span color="#99ffff">83.3%</span><span>伤害</span><span color="#ffbfbf">(闪避帧无效)</span><span>，并产生一个</span><span color="#99ffff">冰元素晶球</span><span>。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_36.png')" x="719" y="362">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_37.png')" x="596" y="395" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_38.png')" x="576" y="374" blendMode="normal">
		</BitmapImage>
		<RichText x="1410" y="447" width="424" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">玻瑞亚斯突然朝前方进行一次疾冲，造成<span color="#99ffff">100%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_39.png')" x="1391" y="362">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_40.png')" x="1268" y="395" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_41.png')" x="1248" y="374" blendMode="normal">
		</BitmapImage>
		<RichText x="1410" y="895" width="423" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">玻瑞亚斯在原地晃动全身，凝聚空气中的水汽，不断产生冰锥下坠，造成<span color="#99ffff">25%</span><span>伤害</span><span color="#ffbfbf">(闪避帧无效)</span><span>，持续15s。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_42.png')" x="1392" y="810">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_43.png')" x="1268" y="843" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_44.png')" x="1248" y="822" blendMode="normal">
		</BitmapImage>
		<RichText x="738" y="671" width="408" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">玻瑞亚斯抬起身子在途经上产生霜面，走在霜面上减速<span color="#ffccbf">30%</span><span>，并附着冰元素，随后霜面开始起爆，造成</span><span color="#99ffff">41.6%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_45.png')" x="722" y="585">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_46.png')" x="596" y="619" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/玻瑞亚斯之影.assets/Image_47.png')" x="576" y="598" blendMode="normal">
		</BitmapImage>
		<RichText x="738" y="1151" width="430" height="172" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">低于<span color="#ffbfbf">60%生命值</span><span>时，玻瑞亚斯绕场地边缘跑动，跑3圈，前两圈跑完3/4圈将直接发起冲撞，最后一圈跑完起跳下落至场地中央。触碰跑动的玻瑞亚斯或遭其冲撞，将造成</span><span color="#99ffff">60%</span><span>伤害；安德留斯跃入场地中央造成</span><span color="#99ffff">20%</span><span>伤害。</span></p>
			</content>
		</RichText>
