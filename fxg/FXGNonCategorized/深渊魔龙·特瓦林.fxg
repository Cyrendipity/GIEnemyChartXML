		</BitmapImage>
		<BitmapImage source="@Embed('/深渊魔龙%B7特瓦林.assets/Image_25.png')" x="1268" y="171" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/深渊魔龙%B7特瓦林.assets/Image_26.png')" x="1268" y="619" blendMode="normal">
