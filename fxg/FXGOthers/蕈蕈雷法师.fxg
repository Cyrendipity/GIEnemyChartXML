				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="32" color="#ffffff">Wt/Ed: 75/20</p>
			</content>
			<filters>
				<DropShadowFilter angle="40" color="#efbfff" distance="10" alpha="0.75" quality="2" blurX="25" blurY="25"/>
			</filters>
