		<BitmapImage source="@Embed('/镀金旅团%B7灵风猎手.assets/Image_13.png')" x="596" y="843" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/镀金旅团%B7灵风猎手.assets/Image_14.png')" x="576" y="822" blendMode="normal">
		</BitmapImage>
		<RichText x="66" y="1032" fontFamily="仓耳渔阳体 W03" fontSize="16" fontStyle="normal" fontWeight="bold" color="#ffffff" width="435" height="39" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.7490196078431373">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="16" fontWeight="bold" color="#ffffff">正在蓄力箭矢或处于魔化状态下，抗打断0，质量翻6倍。虚弱状态下抗打断0。</p>
			</content>
		</RichText>
		<RichText x="738" y="223" width="423" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">灵风猎手发射一枚风元素箭矢，造成<span color="#7fffd7">75%</span><span>伤害，虚弱的灵风猎手只会施放此技能。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="447" width="424" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">灵风猎手凌空蓄力，产生真空场不断吸引玩家至风矢范围内，3s后箭矢发射，造成<span color="#7fffd7">80%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="671" width="408" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">距离玩家较远时，灵风猎手直接冲来，使用风矢划击，造成<span color="#7fffd7">75%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="895" width="996" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">当灵风猎手的<span color="#ffbfbf">生命值低于70%(特化为100%)</span><span>时，其会唤出武器内的风之魔鸢，</span><span color="#bfffdf">进入魔化状态</span><span>，全抗性提升50%。击破风之魔鸢会使灵风猎手受到基于</span><span color="#7fffd7">当前生命值的37.5%</span><span>的</span><span color="#7fffd7">风元素真伤</span><span>，并虚弱10s，一次战斗内仅会施放一次该技能。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/镀金旅团%B7灵风猎手.assets/Image_15.png')" x="720" y="138">
		</BitmapImage>
