		</BitmapImage>
		<BitmapImage source="@Embed('/冰风组曲%B7科培琉司的劫罚.assets/Image_21.png')" x="1392" y="1065">
		</BitmapImage>
		<RichText x="738" y="447" width="423" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">科培琉司将歌裴莉娅抛上天，之后下落，造成<span color="#7fffd7">60%</span><span>伤害，落地的歌裴莉娅顺势旋转，持续造成</span><span color="#7fffd7">15%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="447" width="423" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">歌裴莉娅使用扇子挥出3个凝风尘弹，，每个造成<span color="#7fffd7">75%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="1151" width="439" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">歌裴莉娅在场地外挥出3刀风刃，均造成<span color="#7fffd7">100%</span><span>伤害，随后旋转准备回归，风刃会将经过的霜之心再次触发冰爆。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="1151" width="424" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">歌裴莉娅在不断旋转回归，接触持续造成<span color="#7fffd7">25%</span><span>伤害，之后与科培琉司顺利会合。会合时科培琉司会再次进行3段攻击，均造成</span><span color="#99ffff">100%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="899" y="62" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" fontStyle="normal" fontWeight="normal" color="#257d8f" width="207" height="28" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#257d8f">制图@Csxylic米游社</p>
			</content>
		</RichText>
		<RichText x="738" y="895" width="439" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">科培琉司将歌裴莉娅送出，送出时将进行葬离颂舞：科培琉司进行3段划击，依次造成<span color="#99ffff">90%,90%,100%</span><span>伤害；旋转3周后顺势送出歌裴莉娅。</span></p>
			</content>
		</RichText>
