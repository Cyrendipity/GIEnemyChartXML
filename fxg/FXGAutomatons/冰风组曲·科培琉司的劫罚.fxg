		</BitmapImage>
		<BitmapImage source="@Embed('/冰风组曲%B7科培琉司的劫罚.assets/Image_18.png')" x="719" y="361">
		</BitmapImage>
		<BitmapImage source="@Embed('/冰风组曲%B7科培琉司的劫罚.assets/Image_19.png')" x="1391" y="361">
		</BitmapImage>
