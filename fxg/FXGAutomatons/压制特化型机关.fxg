		</BitmapImage>
		<BitmapImage source="@Embed('/压制特化型机关.assets/Image_20.png')" x="1391" y="137">
		</BitmapImage>
		<RichText x="1410" y="223" width="424" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">压制机关使用左臂发射近距霰弹，造成<span color="#b8b8b8">40%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="899" y="62" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" fontStyle="normal" fontWeight="normal" color="#96673d" width="207" height="28" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#96673d">制图@Csxylic米游社</p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/压制特化型机关.assets/Image_21.png')" x="1248" y="150" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/压制特化型机关.assets/Image_22.png')" x="576" y="150" blendMode="normal">
		</BitmapImage>
		<RichText x="66" y="912" width="409" height="39" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.7490196078431373">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="16" fontWeight="bold" color="#ffffff">荒芒性质：<span color="#ffbfbf">2次</span><span>芒荒攻击可以瘫痪相反属性的压制机关，约25s-30s后恢复荒芒属性。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/压制特化型机关.assets/Image_23.png')" x="64" y="67" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/压制特化型机关.assets/Image_24.png')" x="576" y="374" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/压制特化型机关.assets/Image_25.png')" x="1248" y="374" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/压制特化型机关.assets/Image_26.png')" x="1268" y="619" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/压制特化型机关.assets/Image_27.png')" x="596" y="619" blendMode="normal">
		</BitmapImage>
		<RichText x="1410" y="671" width="439" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">压制机关先进行瞄准，地面出现标识，随后使用左臂发射4枚小型火箭弹，造成<span color="#ff9999">60%,42%,30%,12%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="671" width="437" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">压制机关使用左臂的加特林，持续不断的朝玩家发射火弹，持续造成<span color="#ff9999">20%,10%,<br/>5%,2%,0.2%</span><span>伤害。</span></p>
			</content>
		</RichText>
