		<RichText x="738" y="223" width="399" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">压制机关使用右臂发射一枚较大的导弹，造成<span color="#b9b9b9">30%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="447" width="424" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">压制机关使用右臂的炮筒，发射丛蔓毒光并爆炸，造成<span color="#99ff87">100%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="447" width="439" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">压制机关使用右臂的炮筒，连续发射3枚较大的草属性火箭弹，每个造成<span color="#99ff87">70%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/压制特化型机关.assets/Image_17.png')" x="721" y="137">
		</BitmapImage>
		<BitmapImage source="@Embed('/压制特化型机关.assets/Image_18.png')" x="720" y="361">
		</BitmapImage>
