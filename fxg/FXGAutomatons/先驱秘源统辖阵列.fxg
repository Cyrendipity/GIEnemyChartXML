		<RichText x="1411" y="223" width="422" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">先驱阵列将滚动而来，接触造成<span color="#7fbfff">80%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="899" y="62" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" fontStyle="normal" fontWeight="normal" color="#2c62d3" width="207" height="28" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#2c62d3">制图@Csxylic米游社</p>
			</content>
		</RichText>
		<RichText x="738" y="223" width="408" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">距离较近时，先驱阵列原地起跳下落，造成<span color="#7fbfff">70%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="511" width="439" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">距离较远时，先驱阵列向空中抛出5枚水弹，向目标随机洒落，造成<span color="#7fbfff">55%,27.5%,<br/>11%,5.5%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/先驱秘源统辖阵列.assets/Image_14.png')" x="1392" y="137">
		</BitmapImage>
		<BitmapImage source="@Embed('/先驱秘源统辖阵列.assets/Image_15.png')" x="720" y="425">
		</BitmapImage>
		<BitmapImage source="@Embed('/先驱秘源统辖阵列.assets/Image_16.png')" x="720" y="714">
		</BitmapImage>
		<BitmapImage source="@Embed('/先驱秘源统辖阵列.assets/Image_17.png')" x="1392" y="425">
		</BitmapImage>
		<BitmapImage source="@Embed('/先驱秘源统辖阵列.assets/Image_18.png')" x="1391" y="714">
		</BitmapImage>
		<RichText x="739" y="799" width="438" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">先驱阵列使用古月力启动「<span textDecoration="underline">聚流力场</span><span>」，并向空中依次丢出2枚大水泡，造成</span><span color="#7fbfff">100%</span><span>伤害。施放期间持续附着</span><span color="#7fbfff">水元素</span><span>。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="511" width="424" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">距离较远时，先驱阵列转出炮口，发射一枚普通水弹，造成<span color="#7fbfff">70%</span><span>伤害，随后再发射一枚强劲水弹，造成</span><span color="#7fbfff">80%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/先驱秘源统辖阵列.assets/Image_19.png')" x="719" y="138">
		</BitmapImage>
