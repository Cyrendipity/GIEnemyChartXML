			</BitmapImage>
			<BitmapImage source="@Embed('/蚀灭的源焰之主s.assets/Image_12.png')" x="303" y="1069" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/蚀灭的源焰之主s.assets/Image_13.png')" x="244" y="1069" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/蚀灭的源焰之主s.assets/Image_14.png')" x="424" y="1069" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/蚀灭的源焰之主s.assets/Image_15.png')" x="124" y="1069" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/蚀灭的源焰之主s.assets/Image_16.png')" x="66" y="1069" blendMode="normal">
