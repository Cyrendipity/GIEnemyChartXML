		</BitmapImage>
		<BitmapImage source="@Embed('/终末绿洲的守望者.assets/Image_18.png')" x="1391" y="137">
		</BitmapImage>
		<BitmapImage source="@Embed('/终末绿洲的守望者.assets/Image_19.png')" x="1392" y="362">
		</BitmapImage>
		<BitmapImage source="@Embed('/终末绿洲的守望者.assets/Image_20.png')" x="1391" y="585">
		</BitmapImage>
		<RichText x="1410" y="223" width="412" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">守望者进行2或4段的普通攻击：划、砸、旋、翻，每段分别造成<span color="#b9b9b9">50%,50%,<br/>80%,90%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="447" width="437" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">处在其后侧方时，守望者进行至多2段的划击，每段分别造成<span color="#b9b9b9">70%,90%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="671" width="423" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">守望者在原地大范围旋转，造成<span color="#bababa">90%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="899" y="62" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" fontStyle="normal" fontWeight="normal" color="#24a451" width="207" height="28" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#24a451">制图@Csxylic米游社</p>
			</content>
