			<BitmapImage source="@Embed('/祸津御建鸣神命3.assets/Image_4.png')" x="64" y="1069" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/祸津御建鸣神命3.assets/Image_5.png')" x="64" y="1133" blendMode="normal">
