		</BitmapImage>
		<BitmapImage source="@Embed('/吞星之鲸.assets/Image_16.png')" x="1392" y="138">
		</BitmapImage>
		<BitmapImage source="@Embed('/吞星之鲸.assets/Image_17.png')" x="1392" y="457">
		</BitmapImage>
		<BitmapImage source="@Embed('/吞星之鲸.assets/Image_18.png')" x="719" y="746">
		</BitmapImage>
		<RichText x="66" y="1008" fontFamily="仓耳渔阳体 W03" fontSize="16" fontStyle="normal" fontWeight="bold" color="#ffffff" width="437" height="58" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.7490196078431373">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="16" fontWeight="bold" color="#ffffff">涡眼：8次次数盾，1单位芒荒盾，击破后+30敌意。<br/>敌意：满120，+1/1s，+2/1s(&gt;80)；受伤将额外加上对应生命值百分比的分子。</p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/吞星之鲸.assets/Image_19.png')" x="64" y="64" blendMode="normal">
		</BitmapImage>
