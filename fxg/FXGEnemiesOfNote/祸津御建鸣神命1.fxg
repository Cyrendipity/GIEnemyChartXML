			<BitmapImage source="@Embed('/祸津御建鸣神命1.assets/Image_4.png')" x="64" y="1005" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/祸津御建鸣神命1.assets/Image_5.png')" x="64" y="1069" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/祸津御建鸣神命1.assets/Image_6.png')" x="184" y="1005" blendMode="normal">
