		</BitmapImage>
		<BitmapImage source="@Embed('/无相之冰.assets/Image_18.png')" x="719" y="585">
		</BitmapImage>
		<BitmapImage source="@Embed('/无相之冰.assets/Image_19.png')" x="1391" y="586">
		</BitmapImage>
		<BitmapImage source="@Embed('/无相之冰.assets/Image_20.png')" x="1391" y="137">
		</BitmapImage>
		<BitmapImage source="@Embed('/无相之冰.assets/Image_21.png')" x="1391" y="362">
		</BitmapImage>
		<BitmapImage source="@Embed('/无相之冰.assets/Image_22.png')" x="1391" y="841">
		</BitmapImage>
		<RichText x="1410" y="223" width="439" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">无相之冰开阵，8个冰立方外壳围一圈暴露核心，从上到下发射8根追踪玩家的冰锥，每个冰锥造成<span color="#99ffff">50%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="447" width="424" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">无相之冰将外壳化为成两面墙，随后夹击，造成<span color="#99ffff">100%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="927" width="423" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">无相之冰在其侧方产生7个冰锥追踪玩家，每个冰锥造成<span color="#99ffff">50%</span><span>伤害，若某个冰锥为这一轮中第一个命中玩家的冰锥，则造成两段</span><span color="#99ffff">50%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="899" y="62" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" fontStyle="normal" fontWeight="normal" color="#2686a2" width="207" height="28" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#2686a2">制图@Csxylic米游社</p>
			</content>
		</RichText>
