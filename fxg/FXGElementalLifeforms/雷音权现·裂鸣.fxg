			<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_13.png')" x="486" y="1229">
			</BitmapImage>
		</Group>
		<RichText x="738" y="223" width="439" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">雷音权现首先放出3个<span textDecoration="underline">雷霆探针</span><span>，每个探针击中造成</span><span color="#ffacff">16.6%</span><span>伤害。探针检测自身半径8m、高3m圆柱内的玩家，满即标记。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="223" width="424" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">距离雷音权现很近时，雷音权现在自身处产生一次雷暴轰击，造成<span color="#ffacff">83.3%</span><span>伤害，其会</span><span color="#99ff99">标记玩家</span><span>。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="895" width="428" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">当雷音权现成功标记到玩家时，随即进行一次高声怒喝，同时施放12道落雷，每道可造成1至2段的<span color="#ffacff">50%</span><span>伤害，同时摧毁所有探针，造成</span><span color="#ffacff">27.7%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="895" width="424" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">雷音权现标记玩家后，被标记的玩家每秒受到<span color="#ffacff">125%×E</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="1119" width="424" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">处在雷音权现后方时，雷音权现挥动左或右翼造成<span color="#ffacff">55.5%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="1343" width="423" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">雷音权现<span color="#bfffed">召唤2个幻影</span><span>，同时进行攻击，从左到右依次发射5个雷球，均造成</span><span color="#ffacff">28.8%,14.4%,7.7%,2.88%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="1567" width="423" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">雷音权现俯下朝玩家冲刺，共冲刺2次，每次均造成<span color="#ffacff">83.3%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_14.png')" x="720" y="137">
		</BitmapImage>
		<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_15.png')" x="1392" y="137">
		</BitmapImage>
