		</BitmapImage>
		<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_19.png')" x="720" y="1258">
		</BitmapImage>
		<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_20.png')" x="719" y="1482">
		</BitmapImage>
		<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_21.png')" x="719" y="361">
		</BitmapImage>
		<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_22.png')" x="1392" y="585">
		</BitmapImage>
		<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_23.png')" x="1391" y="1257">
		</BitmapImage>
		<RichText x="738" y="447" width="439" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">雷音权现升空，施放8道落雷，总计施放2轮，每道造成<span color="#ffacff">43.3%</span><span>伤害，其会</span><span color="#99ff99">标记玩家</span><span>，8道落雷的位置与玩家共圆，并且不会出现在中心。</span></p>
			</content>
		</RichText>
		<RichText x="1411" y="671" width="441" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">雷音权现在场地边缘处召唤4个随机游走的电笼，不会追踪，持续20s，接触持续造成<span color="#ffacff">27.7%</span><span>伤害，其会</span><span color="#99ff99">标记玩家</span><span>。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="1343" width="424" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">雷音权现在已标记的玩家处召唤一个追踪玩家的长方形电笼，接触持续造成<span color="#ffacff">27.7%</span><span>伤害，持续7s。</span></p>
			</content>
		</RichText>
		<RichText x="899" y="62" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" fontStyle="normal" fontWeight="normal" color="#a30ddb" width="207" height="28" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#a30ddb">制图@Csxylic米游社</p>
			</content>
		</RichText>
		<RichText x="738" y="671" width="425" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">距离雷音权现较近时，雷音权现在周围<span color="#bfffed">召唤3个幻影</span><span>，同时进行攻击：旋转自身，施放短程旋转造成</span><span color="#ffacff">27.7%,13.85%,<br/>6.925%,2.77%</span><span>伤害，其会</span><span color="#99ff99">标记玩家</span><span>。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="447" width="439" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">雷音权现在场地的四周处召唤相对的2组雷墙，其慢慢朝中间移动，触碰持续造成<span color="#ffacff">100%,70%,50%,25%,10%</span><span>伤害，其会</span><span color="#99ff99">标记玩家</span><span>。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_24.png')" x="721" y="586">
		</BitmapImage>
		<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_25.png')" x="1393" y="362">
		</BitmapImage>
		<RichText x="1410" y="1119" width="424" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">雷音权现召唤两面相对的雷墙，雷墙缓慢向中间合拢，消失，触碰持续造成<span color="#ffacff">100%,70%,50%,25%,10%</span><span>伤害；有时也可能召唤两道平行同向的雷墙。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_26.png')" x="1391" y="1033">
		</BitmapImage>
		<RichText x="1410" y="1567" width="424" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">靠近雷音权现时，雷音权现<span color="#bfffed">召唤2个幻影</span><span>，同时进行攻击，旋转自身，施放长程旋转造成</span><span color="#ffacff">27.7%,13.85%,6.925%,<br/>2.77%</span><span>伤害。</span></p>
			</content>
		</RichText>
