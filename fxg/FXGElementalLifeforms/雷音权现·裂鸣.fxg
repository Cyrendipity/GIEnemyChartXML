			<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_3.png')" x="64" y="1229" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_4.png')" x="64" y="1293" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_5.png')" x="184" y="1229" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_6.png')" x="364" y="1229" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_7.png')" x="303" y="1229" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_8.png')" x="244" y="1229" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_9.png')" x="424" y="1229" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_10.png')" x="124" y="1229" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/雷音权现%B7裂鸣.assets/Image_11.png')" x="66" y="1229" blendMode="normal">
