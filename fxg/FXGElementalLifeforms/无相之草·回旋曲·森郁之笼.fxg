			<BitmapImage source="@Embed('/无相之草%B7回旋曲%B7森郁之笼.assets/Image_4.png')" x="64" y="1037" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/无相之草%B7回旋曲%B7森郁之笼.assets/Image_5.png')" x="184" y="973" blendMode="normal">
