			<BitmapImage source="@Embed('/无相之草%B7回旋曲%B7森郁之笼.assets/Image_10.png')" x="124" y="973" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/无相之草%B7回旋曲%B7森郁之笼.assets/Image_11.png')" x="66" y="973" blendMode="normal">
			</BitmapImage>
