			</BitmapImage>
			<BitmapImage source="@Embed('/无相之水.assets/Image_6.png')" x="364" y="973" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/无相之水.assets/Image_7.png')" x="303" y="973" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/无相之水.assets/Image_8.png')" x="244" y="973" blendMode="normal">
			</BitmapImage>
