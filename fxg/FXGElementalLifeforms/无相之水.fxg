			<BitmapImage source="@Embed('/无相之水.assets/Image_3.png')" x="64" y="973" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/无相之水.assets/Image_4.png')" x="64" y="1037" blendMode="normal">
			</BitmapImage>
