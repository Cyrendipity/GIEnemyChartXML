			<BitmapImage source="@Embed('/古岩龙蜥.assets/Image_3.png')" x="64" y="1037" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/古岩龙蜥.assets/Image_4.png')" x="64" y="1101" blendMode="normal">
			</BitmapImage>
