		<RichText x="739" y="223" width="436" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">山王至多进行践踏、甩尾2段攻击，分别造成<span color="#99ff86">50%,65%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="447" width="424" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">山王借助长舌纵身一跃，重重下落造成<span color="#99ff86">80%</span><span>伤害，并产生一次相同伤害的振波。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="671" width="423" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">山王喷吐一枚草弹，造成<span color="#99ff86">50%</span><span>伤害，可重复施放3次。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/贪食匿叶龙山王.assets/Image_15.png')" x="718" y="137">
		</BitmapImage>
		<BitmapImage source="@Embed('/贪食匿叶龙山王.assets/Image_16.png')" x="721" y="362">
		</BitmapImage>
		<BitmapImage source="@Embed('/贪食匿叶龙山王.assets/Image_17.png')" x="720" y="585">
		</BitmapImage>
		<BitmapImage source="@Embed('/贪食匿叶龙山王.assets/Image_18.png')" x="1391" y="137">
		</BitmapImage>
		<BitmapImage source="@Embed('/贪食匿叶龙山王.assets/Image_19.png')" x="1391" y="361">
		</BitmapImage>
		<RichText x="1410" y="223" width="424" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">山王拍拍肚子，扑倒并朝玩家方向开始旋转，持续造成<span color="#99ff86">35%,17.5%,8.75%,<br/>3.5%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="447" width="424" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">山王借助长舌抵达高处，缓慢下落，造成<span color="#99ff86">80%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="899" y="62" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" fontStyle="normal" fontWeight="normal" color="#24a451" width="207" height="28" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#24a451">制图@Csxylic米游社</p>
			</content>
		</RichText>
