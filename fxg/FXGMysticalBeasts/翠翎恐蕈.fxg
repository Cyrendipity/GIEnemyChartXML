		</BitmapImage>
		<BitmapImage source="@Embed('/翠翎恐蕈.assets/Image_17.png')" x="720" y="810">
		</BitmapImage>
		<BitmapImage source="@Embed('/翠翎恐蕈.assets/Image_18.png')" x="1392" y="138">
		</BitmapImage>
		<BitmapImage source="@Embed('/翠翎恐蕈.assets/Image_19.png')" x="1391" y="361">
		</BitmapImage>
		<BitmapImage source="@Embed('/翠翎恐蕈.assets/Image_20.png')" x="1392" y="585">
		</BitmapImage>
		<BitmapImage source="@Embed('/翠翎恐蕈.assets/Image_21.png')" x="1392" y="809">
		</BitmapImage>
		<RichText x="1410" y="223" width="439" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">翠翎恐蕈激化一式：疯狂向玩家冲来，触碰依次造成<span color="#99ff87">120%,48%,12%</span><span>伤害，来回撞击2次，全程</span><span color="#bfffbf">自身附着草</span><span>，然后眩晕20s。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="447" width="429" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">翠翎恐蕈激化二式：蓄力施放巨量孢子，孢子弱追踪玩家，每个孢子造成<span color="#99ff87">45%,22.5%,4.5%,0.45%</span><span>伤害，技能结束眩晕20s。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="671" width="436" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">翠翎恐蕈激化三式：在原地疯狂进行挑动，持续4次，造成<span color="#99ff87">120%,60%</span><span>伤害，技能结束眩晕20s。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="895" width="424" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">距离翠翎恐蕈比较远时，翠翎恐蕈会短暂展开尾翼鸣叫，并<span color="#bfffbf">自身附着草</span><span>，该技能不造成伤害。</span></p>
			</content>
		</RichText>
		<RichText x="899" y="62" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" fontStyle="normal" fontWeight="normal" color="#24a451" width="207" height="28" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#24a451">制图@Csxylic米游社</p>
			</content>
		</RichText>
