			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#937122">制图@Csxylic米游社</p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/岩龙蜥.assets/Image_18.png')" x="64" y="192" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/岩龙蜥.assets/Image_19.png')" x="596" y="171" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/岩龙蜥.assets/Image_20.png')" x="576" y="150" blendMode="normal">
		</BitmapImage>
		<RichText x="738" y="223" width="435" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">岩龙蜥汲取<span color="#ff9999">火元素</span><span>，</span><span color="#ff9999">火抗+20%</span><span>，此后的所有攻击均附带</span><span color="#ff9999">火元素附魔</span><span>，同时攻击倍率提升；下落时会产生额外的地刺造成伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/岩龙蜥.assets/Image_21.png')" x="720" y="138">
		</BitmapImage>
		<BitmapImage source="@Embed('/岩龙蜥.assets/Image_22.png')" x="1268" y="171" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/岩龙蜥.assets/Image_23.png')" x="1248" y="150" blendMode="normal">
		</BitmapImage>
		<RichText x="1410" y="223" width="435" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">岩龙蜥汲取<span color="#ffacff">雷元素</span><span>，</span><span color="#ffacff">雷抗+20%</span><span>，此后的所有攻击均产生一定数量的游离雷球，游离的雷球触碰即造成</span><span color="#ffacff">30%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/岩龙蜥.assets/Image_24.png')" x="1392" y="137">
		</BitmapImage>
		<RichText x="1410" y="447" width="436" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">岩龙蜥汲取<span color="#99ffff">冰元素</span><span>，</span><span color="#99ffff">冰抗+20%</span><span>，此后岩龙蜥进行攻击时会在其附近产生冰簇，冰簇会在触碰或5s后爆破，造成</span><span color="#99ffff">35%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/岩龙蜥.assets/Image_25.png')" x="1392" y="361">
		</BitmapImage>
		<BitmapImage source="@Embed('/岩龙蜥.assets/Image_26.png')" x="596" y="395" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/岩龙蜥.assets/Image_27.png')" x="576" y="374" blendMode="normal">
		</BitmapImage>
		<RichText x="738" y="447" width="436" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">岩龙蜥汲取<span color="#7fbfff">水元素</span><span>，</span><span color="#7fbfff">水抗+20%</span><span>，此后岩龙蜥进行攻击时即会给玩家施加水环，水环同步于玩家，5s后水环爆破，造成</span><span color="#7fbfff">25%</span><span>伤害。</span></p>
			</content>
		</RichText>
