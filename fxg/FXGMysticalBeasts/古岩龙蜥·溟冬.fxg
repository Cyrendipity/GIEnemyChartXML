		<BitmapImage source="@Embed('/古岩龙蜥%B7溟冬.assets/Image_3.png')" x="64" y="64" blendMode="normal">
		</BitmapImage>
		<RichText x="1445" y="52" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="30" fontStyle="normal" fontWeight="normal" color="#ffffff" width="438" height="34" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.5019607843137255">
			<content>
				<p textAlign="right" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="30" color="#ffffff">元素能量：WP[66,33],WO[0x2]</p>
			</content>
			<filters>
				<DropShadowFilter angle="40" color="#ffe599" distance="16" alpha="0.75" quality="2" blurX="25" blurY="25"/>
			</filters>
		</RichText>
		<RichText x="738" y="223" width="423" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">古岩龙蜥使用右爪挥扫，造成对应元素的<span color="#99e5ff">40%</span><span>伤害；古岩龙蜥使用左爪敲地，后拔扯，敲地和拔扯依次造成对应元素的</span><span color="#99e5ff">35%,15%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="447" width="428" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">古岩龙蜥进行右爪扫-左爪划-双爪拍三段攻击，其依次造成对应元素的<span color="#99e5ff">40%,<br/>50%,62.5%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="671" width="423" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">处于古岩龙蜥身后时，古岩龙蜥使用尾部旋扫一圈，造成<span color="#ffe599">80%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="447" width="439" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">古岩龙蜥凝聚自身元素，朝前方扇形区域扫过，造成对应元素的<span color="#99e5ff">40%,20%,10%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="927" width="442" height="258" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">古岩龙蜥会依据自身属性产生「龙鳞」，不同元素的攻击方式不同：<br/><span color="#7fbfff">清涟</span><span>：朝玩家方向产生7~8次水喷，每个水喷造成</span><span color="#7fbfff">16%</span><span>伤害；<br/></span><span color="#99ffff">青霜</span><span>：产生三波冰棘，依次造成</span><span color="#99ffff">25%,<br/>25%,37.5%</span><span>伤害。<br/>「龙鳞」将在古岩龙蜥施放「原岩喷吐」或「晶鳞四处」或被某些攻击打断时立即消失。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="671" width="437" height="143" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">古岩龙蜥抖动全身，飞出8个对应元素的「龙鳞」，落地后绕龙蜥围成一圈，然后敲一下地板造成对应元素的<span color="#99e5ff">80%</span><span>伤害。<br/>施放后可转换元素属性，顺序为</span><span color="#99ffff">冰</span><span color="#7fbfff">水</span><span>。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="223" width="423" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">古岩龙蜥大跳移步，落地造成对应元素的<span color="#99e5ff">70%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/古岩龙蜥%B7溟冬.assets/Image_4.png')" x="720" y="137">
		</BitmapImage>
