			<BitmapImage source="@Embed('/魔像督军.assets/Image_3.png')" x="64" y="1069" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/魔像督军.assets/Image_4.png')" x="64" y="1133" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/魔像督军.assets/Image_5.png')" x="184" y="1069" blendMode="normal">
			</BitmapImage>
