		<RichText x="6" y="949" width="52" height="42" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p textAlign="center" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#ffffff">常态<br/><span fontSize="14">深渊+80</span></p>
			</content>
		</RichText>
		<RichText x="6" y="1009" width="52" height="42" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p textAlign="center" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#ffffff">红温<span fontSize="14">深渊+40</span></p>
			</content>
		</RichText>
		<RichText x="6" y="1069" width="52" height="42" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p textAlign="center" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#ffffff">瘫痪<span fontSize="14">深渊+40</span></p>
			</content>
		</RichText>
		<RichText x="738" y="479" width="428" height="143" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">陆巡舰使用舰炮朝空中发射2枚迫击弹，依次在玩家处落下，造成<span color="#99ffff">80%</span><span>伤害并飞溅出10枚霜核，接触造成</span><span color="#99ffff">40%</span><span>伤害；此外命中处留下冰地面，持续造成</span><span color="#99ffff">6%</span><span>伤害，持续12s。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="767" width="442" height="143" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">高热计量满时，陆巡舰立即展开持续<span color="#ffdfbf">18s </span><span>的</span><span textDecoration="underline">散热套件</span><span>护罩，持续减少高热计量；若成功击破护罩，则其将立即受到</span><span color="#ffdfbf">当前30%生命值</span><span>的</span><span color="#ff9999">火元素</span><span>真伤并瘫痪15s；否则施放「断明颓敝」，期间抗性不变。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/超重型陆巡舰%B7机动战垒.assets/Image_30.png')" x="720" y="393">
