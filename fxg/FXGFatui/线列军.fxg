		</BitmapImage>
		<BitmapImage source="@Embed('/线列军.assets/Image_18.png')" x="64" y="64" blendMode="normal">
		</BitmapImage>
		<RichText x="738" y="255" width="439" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">线列军使用枪上的刺刀进行至多2段的攻击，依次造成<span color="#99ffff">40%,50%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="479" width="413" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">线列军发射一枚冰子弹，造成<span color="#99ffff">100%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="703" width="439" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">线列军激活刺枪，连续发射6枚子弹，造成<span color="#99ffff">70%,13.5%,7%</span><span>伤害。武器属「双极」物件，其可用</span><span color="#bfdfff">月</span><span color="#ccbfff">矩</span><span color="#ebbfff">力</span><span>没收。</span></p>
			</content>
