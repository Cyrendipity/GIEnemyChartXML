			<content>
				<p textAlign="center" fontFamily="SDK_SC_Web" fontSize="24" fontStyle="italic" color="#ffffff">Emperor of Fire and Iron: Ordained Conquest</p>
			</content>
			<filters>
				<DropShadowFilter angle="40" color="#ff9999" distance="16" alpha="0.75" quality="2" blurX="25" blurY="25"/>
