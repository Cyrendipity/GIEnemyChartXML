		<RichText x="736" y="120" fontFamily="SDK_SC_Web" fontSize="24" fontStyle="italic" fontWeight="normal" color="#ffffff" width="447" height="30" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.7490196078431373">
			<content>
				<p textAlign="center" fontFamily="SDK_SC_Web" fontSize="24" fontStyle="italic" color="#ffffff">Iniquitous Baptist: Resonant Wrath</p>
			</content>
			<filters>
				<DropShadowFilter angle="40" color="#baafed" distance="16" alpha="0.75" quality="2" blurX="25" blurY="25"/>
