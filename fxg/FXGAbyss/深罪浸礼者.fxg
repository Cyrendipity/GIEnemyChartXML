			<BitmapImage source="@Embed('/深罪浸礼者.assets/Image_4.png')" x="64" y="1197" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/深罪浸礼者.assets/Image_5.png')" x="64" y="1261" blendMode="normal">
			</BitmapImage>
