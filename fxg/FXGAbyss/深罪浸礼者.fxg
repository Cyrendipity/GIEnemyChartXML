			</BitmapImage>
			<BitmapImage source="@Embed('/深罪浸礼者.assets/Image_7.png')" x="364" y="1197" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/深罪浸礼者.assets/Image_8.png')" x="303" y="1197" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/深罪浸礼者.assets/Image_9.png')" x="244" y="1197" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/深罪浸礼者.assets/Image_10.png')" x="424" y="1197" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/深罪浸礼者.assets/Image_11.png')" x="124" y="1197" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/深罪浸礼者.assets/Image_12.png')" x="66" y="1197" blendMode="normal">
			</BitmapImage>
			<BitmapImage source="@Embed('/深罪浸礼者.assets/Image_14.png')" x="486" y="1197">
