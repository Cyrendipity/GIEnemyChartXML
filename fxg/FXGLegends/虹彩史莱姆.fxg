		<BitmapImage source="@Embed('/虹彩史莱姆.assets/Image_41.png')" x="576" y="150" blendMode="normal">
		</BitmapImage>
		<RichText x="718" y="1024" width="476" height="58" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W01" fontSize="16" fontWeight="bold" color="#99ff87">草元素<span color="#ffffff">：下落造成</span><span>40%</span><span color="#ffffff">伤害，并产生4枚毒草种，触碰中毒5s并持续造成</span><span>3%</span><span color="#ffffff">伤害；毒草种遇</span><span color="#7fffd7">风</span><span color="#ffffff">攻击会被驱散消失，遇</span><span color="#ff9999">火</span><span color="#ffffff">攻击则发生爆炸，造成</span><span color="#b8b8b8">70%</span><span color="#ffffff">伤害。</span></p>
			</content>
		</RichText>
		<RichText x="718" y="896" width="461" height="39" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W01" fontSize="16" fontWeight="bold" color="#ff9999">火元素<span color="#ffffff">：下落造成</span><span>55%</span><span color="#ffffff">伤害，并产生4-5枚火球，落地造成</span><span>15%</span><span color="#ffffff">伤害。</span></p>
			</content>
		</RichText>
		<RichText x="718" y="960" width="473" height="39" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W01" fontSize="16" fontWeight="bold" color="#7fbfff">水元素<span color="#ffffff">：下落造成</span><span>40%</span><span color="#ffffff">伤害，并产生4枚弹跳的水泡，触碰造成</span><span>15%</span><span color="#ffffff">伤害。</span></p>
			</content>
		</RichText>
		<RichText x="718" y="1120" width="464" height="39" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W01" fontSize="16" fontWeight="bold" color="#ffacff">雷元素<span color="#ffffff">：下落造成</span><span>45%</span><span color="#ffffff">伤害并弹一下，随后再次下落，造成</span><span>21%</span><span color="#ffffff">伤害。</span></p>
			</content>
		</RichText>
		<RichText x="718" y="1184" width="465" height="39" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W01" fontSize="16" fontWeight="bold" color="#99ffff">冰元素<span color="#ffffff">：下落造成</span><span>36%</span><span color="#ffffff">伤害，同时产生持续5.5s的冰雾，持续造成</span><span>3%</span><span color="#ffffff">伤害。</span></p>
			</content>
		</RichText>
		<RichText x="718" y="1312" width="465" height="20" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W01" fontSize="16" fontWeight="bold" color="#ffe599">岩元素<span color="#ffffff">：下落造成</span><span>45%</span><span color="#ffffff">伤害，并产生3枚石块，落地造成</span><span>25%</span><span color="#ffffff">伤害。</span></p>
			</content>
		</RichText>
		<RichText x="718" y="1248" width="448" height="39" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W01" fontSize="16" fontWeight="bold" color="#7fffd7">风元素<span color="#ffffff">：不下落攻击，短暂鼓胀后朝玩家处作冲击，造成</span><span>45%</span><span color="#ffffff">伤害，落地之后立即膨胀一次，造成</span><span>25%</span><span color="#ffffff">伤害。</span></p>
			</content>
		</RichText>
