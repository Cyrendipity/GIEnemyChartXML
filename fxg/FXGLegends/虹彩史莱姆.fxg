		</BitmapImage>
		<BitmapImage source="@Embed('/虹彩史莱姆.assets/Image_39.png')" x="1248" y="1174" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/虹彩史莱姆.assets/Image_40.png')" x="576" y="694" blendMode="normal">
