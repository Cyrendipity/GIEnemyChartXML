			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#1595bf">制图@Csxylic米游社</p>
			</content>
		</RichText>
		<RichText x="1423" y="48" width="455" height="34" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.5019607843137255">
			<content>
				<p textAlign="right" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="30" color="#ffffff">元素能量：<span color="#99ffff">CP</span><span>[75,50,25,0],</span><span color="#99ffff">CO</span><span>[0]</span></p>
			</content>
			<filters>
				<DropShadowFilter angle="40" color="#99e5ff" distance="10" alpha="0.75" quality="2" blurX="25" blurY="25"/>
			</filters>
		</RichText>
		<RichText x="63" y="368" fontFamily="仓耳渔阳体 W04" fontSize="80" fontStyle="normal" fontWeight="normal" color="#ffffff" width="511" height="81" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="仓耳渔阳体 W04" fontSize="80" color="#ffffff">波塔波的声援</p>
			</content>
			<filters>
				<DropShadowFilter angle="40" color="#bfefff" distance="16" alpha="0.75" quality="2" blurX="25" blurY="25"/>
			</filters>
		</RichText>
		<RichText x="68" y="457" fontFamily="SDK_SC_Web" fontSize="24" fontStyle="italic" fontWeight="normal" color="#ffffff" width="265" height="30" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.7490196078431373">
			<content>
				<p fontFamily="SDK_SC_Web" fontSize="24" fontStyle="italic" color="#ffffff">“Potapo’s Solidarity”</p>
			</content>
			<filters>
				<DropShadowFilter angle="40" color="#bfefff" distance="16" alpha="0.75" quality="2" blurX="25" blurY="25"/>
			</filters>
		</RichText>
		<RichText x="1410" y="799" width="435" height="258" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">「佑灵身」存在期间，若我方恢复的总生命值量累计超过「佑灵身」生命值上限的<span color="#99ffb2">90%</span><span>/</span><span color="#99ffb2">175%</span><span>/</span><span color="#99ffb2">250%</span><span>时，「佑灵身」将</span><span color="#bfffdf">唤醒施放「贯通」</span><span>/</span><span color="#bfffee">提升</span><span color="#bfffdf">「贯通」</span><span color="#bfffee">伤害</span><span>/</span><span color="#bfffee">提升为「决胜」</span><span>，「佑灵身」的攻击将持续对「声援」造成</span><span color="#ffeebf">0.5%</span><span>/</span><span color="#ffeebf">0.875%</span><span>/</span><span color="#ffeebf">1.25%生命值</span><span>的真伤。<br/>秘影重现的「佑灵身」造成的伤害提升为</span><span color="#ffeebf">1.6%</span><span>/</span><span color="#ffeebf">2.8%</span><span>/</span><span color="#ffeebf">4%生命值</span><span>的真伤。</span></p>
			</content>
		</RichText>
