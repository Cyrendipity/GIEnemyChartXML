	<Group d:userLabel="层_1" d:type="layer">
		<BitmapImage source="@Embed('/摩诃婆苏提婆耶弗太子.assets/Image_0.png')" x="0" y="1080" d:locked="true" blendMode="normal">
		</BitmapImage>
		<BitmapImage source="@Embed('/摩诃婆苏提婆耶弗太子.assets/Image_1.png')" x="0" y="0" d:locked="true" blendMode="normal">
		</BitmapImage>
		<RichText x="575" y="52" fontFamily="仓耳渔阳体 W04" fontSize="48" fontStyle="normal" fontWeight="normal" color="#ffffff" width="318" height="51" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="仓耳渔阳体 W04" fontSize="48" color="#ffffff">全技能一图流</p>
			</content>
			<filters>
				<DropShadowFilter angle="40" color="#ffefbf" distance="16" alpha="0.75" quality="2" blurX="25" blurY="25"/>
			</filters>
		</RichText>
		<RichText x="1426" y="52" width="457" height="34" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.5019607843137255">
			<content>
				<p textAlign="right" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="30" color="#ffffff">元素能量：<span color="#ffe599">GP</span><span>[75,50,25,0],</span><span color="#ffe599">GO</span><span>[0]</span></p>
			</content>
			<filters>
				<DropShadowFilter angle="40" color="#ffefbf" distance="16" alpha="0.75" quality="2" blurX="25" blurY="25"/>
			</filters>
		</RichText>
		<RichText x="738" y="223" width="408" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">太子立即快速冲来，接触后立即翻起，造成<span color="#ffe599">60%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="479" width="399" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">太子帽盖一亮，迅速旋转一圈，造成<span color="#ffe599">60%</span><span>伤害，可连续施放多次。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="735" width="439" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">枯焦状态的大招。太子变大，随后翻身一跃，下落同时借力弹起，该过程重复6次，第1-5次造成<span color="#ffe599">60%</span><span>伤害，第6次造成</span><span color="#ffe599">100%</span><span>伤害，技能结束后不清空计量条。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="223" width="421" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">太子发射2枚辛蕈果，造成<span color="#ffe599">60%,42%</span><span>伤害，可连续施放多次。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="479" width="424" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">太子用帽盖朝前方迅速顶击一次，造成<span color="#ffe599">25%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="1410" y="735" width="424" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">激化失控的大招，太子变大不移动，在中央胡乱抛洒香弥果，落地造成<span color="#ffe599">80%</span><span>伤害，技能结束后退至</span><span color="#ffbfbf">枯焦</span><span>状态，并将计量条重置为一半。</span></p>
			</content>
		</RichText>
