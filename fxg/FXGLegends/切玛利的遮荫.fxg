		<BitmapImage source="@Embed('/切玛利的遮荫.assets/Image_11.png')" x="1392" y="137">
		</BitmapImage>
		<BitmapImage source="@Embed('/切玛利的遮荫.assets/Image_12.png')" x="720" y="426">
		</BitmapImage>
