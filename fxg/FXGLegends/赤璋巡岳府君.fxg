		<RichText x="9" y="1209" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" fontStyle="normal" fontWeight="normal" color="#ffffff" width="46" height="28" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p textAlign="center" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#ffffff">荒寒</p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/赤璋巡岳府君.assets/Image_16.png')" x="64" y="64" blendMode="normal">
		</BitmapImage>
