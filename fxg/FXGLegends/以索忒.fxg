		<BitmapImage source="@Embed('/以索忒.assets/Image_14.png')" x="1392" y="137">
		</BitmapImage>
		<BitmapImage source="@Embed('/以索忒.assets/Image_15.png')" x="720" y="649">
		</BitmapImage>
		<RichText x="1410" y="223" width="423" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">霜役人使用单手剑瞬间向前方挥出几剑进行一段重击，对前方敌人造成<span color="#99ffff">80%,<br/>40%,20%,10%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="735" width="1110" height="114" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">霜役人瞄准目标，<span color="#ffecbf">消耗5%生命值</span><span>，2s后闪现发动攻击，对目标敌人造成</span><span color="#99ffff">40%</span><span>伤害并施加生命之契，随后发动追加「猎杀」攻击：<br/>闪现并发射一枚寒冰箭，造成</span><span color="#99ffff">50%</span><span>伤害并施加生命之契，随后冲刺下落，造成</span><span color="#99ffff">100%</span><span>伤害。<br/>被施加生命之契的目标，在遭受每段追加「猎杀」时都会累积生命之契。</span></p>
			</content>
		</RichText>
		<RichText x="899" y="62" fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" fontStyle="normal" fontWeight="normal" color="#2686a2" width="207" height="28" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="1">
			<content>
				<p fontFamily="造字工房悦圆 G0v1 常规体" fontSize="24" color="#2686a2">制图@Csxylic米游社</p>
			</content>
		</RichText>
		<RichText x="738" y="223" width="439" height="85" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">霜役人使用单手剑进行双划、寒役、空翻至多3段的连续攻击，对敌人分别造成<span color="#99ffff">50%x2,50%,70%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<RichText x="738" y="447" width="422" height="56" kerning="off" blendMode="normal" whiteSpaceCollapse="preserve" alpha="0.9019607843137255">
			<content>
				<p fontFamily="仓耳渔阳体 W03" fontSize="24" fontWeight="bold" color="#ffffff">霜役人向前突进一段距离，对路径上的敌人造成<span color="#99ffff">70%</span><span>伤害。</span></p>
			</content>
		</RichText>
		<BitmapImage source="@Embed('/以索忒.assets/Image_16.png')" x="720" y="137">
		</BitmapImage>
