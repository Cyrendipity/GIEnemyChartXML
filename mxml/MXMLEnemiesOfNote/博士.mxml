	<mx:Text styleName="textStyle6" x="64" y="928" width="375" text="Wt/Ed: 150/500"/>
	<mx:Text styleName="textStyle8" x="64" y="625" width="395" alpha="0.75" text="Heretic of the False Moon"/>
