	<mx:Text styleName="textStyle8" x="64" y="465" width="395" alpha="0.75" text="Dvalin"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="Erstwhile King of the Skies"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="特瓦林从远处猛地冲来，用爪子划过平台，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="特瓦林将头甩上平台，造成100%伤害，停留数秒后离去。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="特瓦林下潜，并从对面超远处平台冒出，蓄力施放巨大的能量球，对整个平台造成200%伤害(闪避帧无效)。"/>
	<mx:Text styleName="textStyle11" x="64" y="1008" width="448" alpha="0.75" text="千风之护：生命盾，继承20%特瓦林生命值。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="渐进的协奏-位移"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="魔龙的咏叹-防御"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="暴风的狂想-猛攻"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="裂风的回旋-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="袤远的奏鸣-远程"/>
	<mx:Text styleName="textStyle12" x="736" y="832" width="448" text="终天的闭幕-爆发"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="特瓦林趴在平台上，吐出疾风，持续造成50%伤害，从一侧开始扫过平台大部分区域。技能期间有25%减伤。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="特瓦林离开平台，一左一右地发射风弹，每次2个，每个造成50%伤害。技能期间有95%减伤。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="特瓦林使玩家附近的3个平台开裂，造成伤害，在一次战斗中至多施放3次。设造成伤害的次数为n，则该次受到的伤害值为3×n%的伤害(闪避帧无效)，n值初始为1，最大为100，即300%。"/>
	<mx:Text styleName="textStyle13" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Image source="Image5.png" x="64" y="64" width="256" height="256"/>
	<mx:Text styleName="textStyle12" x="1408" y="608" width="448" text="辰星的变奏-爆发"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="特瓦林盘旋升空，在所有平台周期性产生5道星陨阵，每个星陨阵造成50%伤害；特瓦林倒地则暂停施放，恢复后继续；在一次战斗中本技能至多施放1次。"/>
