	<mx:Text styleName="textStyle" x="64" y="512" width="410" text="「女士」"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="640" width="376" text="愚人众执行官第八席"/>
	<mx:Text styleName="textStyle4" x="64" y="960" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1247" y="64" width="609" alpha="0.5" text="元素能量：NA"/>
	<mx:Text styleName="textStyle6" x="64" y="800" width="305" text="HP: 371003 (10.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="768" width="305" alpha="0.75" text="周本-第一阶段 Lv.90 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="848" width="375" text="ATK: 9135 (4.8B1)"/>
	<mx:Text styleName="textStyle6" x="64" y="896" width="375" text="Wt/Ed: 150/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="593" width="395" alpha="0.75" text="「La Signora」"/>
	<mx:Text styleName="textStyle9" x="64" y="683" width="395" alpha="0.75" text="The Eighth of the Eleven Fatui Harbingers"/>
	<mx:Image source="Image5.png" x="64" y="1005" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="女士的部分攻击命中地面会产生结霜，其持续造成6.25%伤害(闪避帧无效)，命中+2.5%寒冷值。结霜永久存在，只能被炎之心破坏。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="女士扔出3朵冰莲花，片刻后爆炸；若在「冰茧」状态下，冰莲花则是随机下落；冰莲花爆炸造成37.5%伤害，并留下结霜，命中+2%寒冷值。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="女士召唤一个大号冰锥在玩家上方，同步于玩家，2s后落下造成50%伤害，3s后爆炸，造成75%伤害，并留下结霜，落下的同时女士身边会施放寒气，造成25%伤害，命中+5%寒冷值。"/>
	<mx:Text styleName="textStyle10" x="736" y="928" width="448" alpha="0.9" text="女士持续发射5个小冰锥追踪玩家；若在「冰茧」状态下，则有9个小冰锥发射，冰锥呈极强追踪性，每个小冰锥造成25%伤害，命中+2%寒冷值。"/>
	<mx:Text styleName="textStyle10" x="736" y="1152" width="448" alpha="0.9" text="当女士本次受到的伤害超过其本阶段生命值上限30.1%时，女士施放一次大范围爆炸，造成125%伤害(闪避帧无效)，充满寒冷值；该次伤害超过女士生命值30.1%的部分无效(即受到的最高伤害只能是女士生命值的30.1%)。"/>
	<mx:Image source="Image6.png" x="1268" y="875" width="128" height="128"/>
	<mx:Image source="Image7.png" x="1248" y="854" width="168" height="170"/>
	<mx:Image source="Image8.png" x="596" y="875" width="128" height="128"/>
	<mx:Image source="Image9.png" x="576" y="854" width="168" height="170"/>
	<mx:Text styleName="textStyle11" x="64" y="1136" width="448" alpha="0.75" text="「冰茧」：60冻盾，击破使其进入下一阶段。红莲蛾：用于破除冰茧，命中时额外施加8火。炎之心：7次次数盾，位于场地四角，靠近每秒-20%寒冷值，击破后清除半径12.5m内的结霜，且清空玩家寒冷值；最大可再生数量为2。寒冷：正常每秒积攒3%，满后每秒流失(3%+150)生命值，冰/水附着+20%积攒速度，火/燃附着-20%积攒速度。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="远冬之霜-天赋"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="愚绽遗芳-妨害"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="深寒之枷-锁定"/>
	<mx:Text styleName="textStyle12" x="736" y="864" width="448" text="碎砂冰砾-追踪"/>
	<mx:Text styleName="textStyle12" x="736" y="1088" width="448" text="寒卉潮翕-天赋"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="褶风百寒-靠近"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="凛冽之凌-碾压"/>
	<mx:Text styleName="textStyle13" x="1408" y="608" width="448" text="不泯凅雾-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="864" width="448" text="千夫对指-锁定"/>
	<mx:Text styleName="textStyle12" x="1408" y="1088" width="448" text="冰茧蕴温-天赋"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="女士瞬移至玩家身边，或者玩家距离女士过近时，女士跺脚产生一次冰爆，造成50%伤害，命中+5%寒冷值。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="女士先扔出5个一排的冰锥，然后丢出一个冰轮，冰轮呈极弱追踪性，会穿墙，不论冰锥与冰轮，均造成37.5%伤害，命中+5%寒冷值。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="女士召唤一排冰锥，朝其前方长矩形区域落坠下，造成75%伤害，并留下结霜，命中+5%寒冷值。"/>
	<mx:Text styleName="textStyle10" x="1408" y="928" width="448" alpha="0.9" text="「冰茧」状态下，女士使用冰刺锁定同步于玩家，约2s后全部扎向玩家，造成100%伤害，并留下结霜，命中+5%寒冷值。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1152" width="448" alpha="0.9" text="当女士的生命值低于20%时，女士形成化作「冰茧」，使寒冷值积攒更为迅速。在该状态下，女士只会施放碎砂冰砾、愚绽遗芳和千夫对指三个技能，周围会不断产生红莲蛾，使用它以破除「冰茧」。"/>
