	<mx:Text styleName="textStyle3" x="64" y="640" width="373" text="多托雷"/>
	<mx:Text styleName="textStyle4" x="64" y="960" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：NA"/>
	<mx:Text styleName="textStyle6" x="64" y="800" width="384" text="HP: 3561628 (96.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="768" width="305" alpha="0.75" text="周本-第一阶段 Lv.90 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="848" width="375" text="ATK: 22838 (12.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="896" width="375" text="Wt/Ed: 150/100"/>
	<mx:Text styleName="textStyle8" x="64" y="593" width="484" alpha="0.75" text="Exalted Master of the Heretical Path"/>
	<mx:Text styleName="textStyle9" x="64" y="683" width="395" alpha="0.75" text="Il Dottore"/>
	<mx:Image source="Image8.png" x="64" y="1005" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Image source="Image9.png" x="64" y="192" width="256" height="254"/>
	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="多托雷背身，立即用右手蓄力，立即在前方区域散布满地的冰棘，造成80%伤害，通常为「莫要应规昏聩」技能的后随。"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" alpha="0.9" text="距离较远时，多托雷升空，并在玩家附近生成3处环形扇区，依次爆发，均造成55%攻击力的伤害。通常后随「刻下寒与伤」。当生命值低于70%时施放。"/>
	<mx:Text styleName="textStyle11" x="1408" y="896" width="448" alpha="0.9" text="多托雷站在中间，双手一挥，两侧立即出现「缩压墙幕」，随后两墙进行夹击，触碰墙体造成100%伤害。通常后随「具象苦与痛」或「负担必将抛却」。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="刻下寒与伤-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="莫要应规昏聩-定点"/>
	<mx:Text styleName="textStyle12" x="736" y="1056" width="448" text="囿徒的觉悟-位移"/>
	<mx:Text styleName="textStyle12" x="1408" y="832" width="448" text="抹灭解脱与灵知-猛攻"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="多托雷使用右手朝玩家方向直线生成5枚1排的探针，五枚探针分别造成25%,30%,35%,45%,55%伤害，当多托雷生命值低于70%时，探针数量变为3排。"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" alpha="0.9" text="多托雷立即使用右手用力敲击地面，在方形区域内产生扩散阵列，造成75%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" alpha="0.9" text="多托雷闪现至半空，并立即发射废弃数据团，造成80%伤害。"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="具象苦与痛-定点"/>
	<mx:Text styleName="textStyle13" x="1408" y="608" width="448" text="莫要㧑卑威权-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="负担必将抛却-远程"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" alpha="0.9" text="距离较远时，多托雷操纵异步数据团，在远处发射2团数据垃圾，均造成65%伤害，大概率后随「莫要㧑卑威权」。"/>
	<mx:Text styleName="textStyle11" x="1408" y="1120" width="448" alpha="0.9" text="距离较远且多托雷不使用正常闪现连招时，多托雷立即化身能量团并进行z字位移到达玩家身旁。"/>
	<mx:Text styleName="textStyle11" x="736" y="1344" width="448" alpha="0.9" text="当多托雷处于闲置状态时，其韧性低可击退，若在5s内连续击退多托雷2次，将会使其立即闪现施放其他技能。"/>
	<mx:Text styleName="textStyle11" x="736" y="1120" width="448" alpha="0.9" text="处于多托雷侧方时，多托雷突然闪现，在原地迅速回转刷新一圈，造成70%伤害。极难触发。"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="樊笼必遭破毁-远程"/>
	<mx:Text styleName="textStyle12" x="1408" y="1056" width="448" text="善恶的离断-位移"/>
	<mx:Text styleName="textStyle12" x="736" y="1280" width="448" text="认知的深化-位移"/>
	<mx:Text styleName="textStyle11" x="736" y="896" width="448" alpha="0.9" text="多托雷打个响指，在自身后方处产生一面橙色防火墙体，内部的漏洞块短时间内持续向前飞出，接触造成85%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="832" width="448" text="缔造失败与死难-猛攻"/>
