	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 20000/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="465" width="395" alpha="0.75" text="Symphony Cryo Hypostasis"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="Sealed Lord of Vishaps"/>
	<mx:Image source="Image5.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="饕冹齑骨-爆发"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="若陀龙王潜入地下，留下尾部的伏龙树，开始召唤冰雹攻击，冰雹落地产生扩散3次的冰棘，均造成33.3%伤害，技能持续12轮，每轮同时落下3个冰雹。结束后若陀龙王钻出，造成8.3%伤害。"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="若陀龙王的冰元素攻击会标记没带盾的玩家，每秒造成13.3%伤害，标记持续8s，可以被元素反应消除。"/>
	<mx:Text styleName="textStyle11" x="736" y="480" width="448" alpha="0.9" text="若陀龙王使用尾部召唤出一个带刺冰球，悬浮于空中，每轮不断发射4个追踪冰锥，造成46.6%,23.3%,11.65%,4.66%伤害，持续5轮。"/>
	<mx:Image source="Image6.png" x="596" y="651" width="128" height="128"/>
	<mx:Image source="Image7.png" x="576" y="630" width="168" height="170"/>
	<mx:Text styleName="textStyle11" x="736" y="704" width="448" alpha="0.9" text="处在若陀龙王侧身时，若陀龙王侧倾身子，造成46.6%伤害(闪避帧无效)。"/>
	<mx:Text styleName="textStyle11" x="736" y="928" width="448" alpha="0.9" text="若陀龙王抖出身上的龙鳞，龙鳞落地造成23.3%伤害，随后留下不断下落的碎冰，持续造成11.6%,5.8%,2.9%,1.16%伤害，一共落下4枚龙鳞。"/>
	<mx:Text styleName="textStyle11" x="1408" y="928" width="448" alpha="0.9" text="处在若陀龙王尾部后方时，若陀龙王摇晃尾部重重下击，造成46.6%伤害，然后拔出尾部产生一次爆炸，造成23.3%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="704" width="448" alpha="0.9" text="若陀龙王蓄力冲向玩家，造成23.3%伤害，然后挑起，造成46.6%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="480" width="448" alpha="0.9" text="处在若陀龙王尾部侧后方时，若陀龙王摇晃尾部旋转身子，造成大范围46.6%伤害(闪避帧无效)，留下3个带刺冰球，爆炸造成23.3%伤害。"/>
	<mx:Text styleName="textStyle13" x="736" y="160" width="448" text="煞坎之印-天赋"/>
	<mx:Text styleName="textStyle13" x="736" y="416" width="448" text="宝璧剡凌-追踪"/>
