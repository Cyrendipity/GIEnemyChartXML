	<mx:Text styleName="textStyle6" x="64" y="800" width="305" alpha="0.75" text="周本-空中状态 Lv.90 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="880" width="375" text="ATK: 22838 (12.0B2)"/>
