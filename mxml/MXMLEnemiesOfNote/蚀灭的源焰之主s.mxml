	<mx:Text styleName="textStyle7" x="64" y="574" width="395" alpha="0.75" text="Lord of Eroded Primal Fire"/>
	<mx:Image source="Image8.png" x="64" y="1069" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="1472" y="480" width="512" alpha="0.9" text="古斯托特起身向前冲，使用铸影之暗和斫阳之曜各进行一次超大范围挥砍，分别造成25%(20),45%伤害；随后巡弋至另一侧，再重复上述过程一次，巡弋期间场地将随机出现大量地喷，造成15%(10)伤害并留下渊泥。"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="512" alpha="0.9" text="古斯托特使用斫阳之曜与铸影之暗进行炎、渊、十字三段普攻，曜与暗的攻击分别造成25%,25%(10)伤害并留下余烬/渊泥；每一段攻击都会产生相应的剑气，造成对应属性的15%伤害。"/>
	<mx:Text styleName="textStyle9" x="1472" y="416" width="448" text="伏蛟半潭分日影-位移"/>
	<mx:Text styleName="textStyle9" x="736" y="672" width="448" text="焰光淤影共徘徊-输出"/>
	<mx:Image source="Image9.png" x="64" y="192" width="256" height="256"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Image source="Image10.png" x="596" y="171" width="128" height="128"/>
	<mx:Image source="Image11.png" x="576" y="150" width="168" height="170"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="512" alpha="0.9" text="古斯托特释放寰宇界门，倾下数十秒的沦没黑雨，雨滴造成15%,3.75%,1.5%(5)伤害；黑雨间夹杂间断的磊块，磊块造成35%,8.75%,3.5%(15)伤害。"/>
	<mx:Text styleName="textStyle11" x="64" y="1200" width="480" alpha="0.75" text="图腾石碑：24虚界盾，破盾后破坏，并恢复全队100点元素能量寂特殊能量；一共有3个，全部击败后可令古斯托特主瘫痪15s并扣除古斯托特10%生命值。虚界护罩：成功破除后扣除古斯托特10%生命值。"/>
	<mx:Text styleName="textStyle8" x="1472" y="736" width="512" alpha="0.9" text="古斯托特将铸影之暗刺入空瞳，倏然一片虚空，鳞渊气泡如群星般散而又聚，而后湮毁，造成80%(30)伤害(闪避帧无效)；期间古斯托特持有10s的虚界护罩。"/>
	<mx:Text styleName="textStyle8" x="736" y="1248" width="512" alpha="0.9" text="古斯托特借自垂悬天界的渊隧之门降下，绽放出惑光之叶，造成100%(60)伤害(闪避帧无效)。"/>
	<mx:Text styleName="textStyle8" x="736" y="992" width="512" alpha="0.9" text="古斯托特将漆黑之翼上的鳞羽大量洒下，造成15%,7.5%,3.75%(2)伤害。"/>
	<mx:Text styleName="textStyle8" x="1472" y="224" width="512" alpha="0.9" text="继「星寰黑雨天刀磨」后，古斯托特凝聚日炎之力，使用斫阳之曜沿中心圆切线方向切开场地，造成大范围120%伤害。该技能最多施放3次。"/>
	<mx:Image source="Image12.png" x="1332" y="171" width="128" height="128"/>
	<mx:Image source="Image13.png" x="1312" y="150" width="168" height="170"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="512" alpha="0.9" text="古斯托特将斫阳之曜与铸影之暗插入地面，造成25%/25%(10)伤害并留下余烬/渊泥；随后两剑向前迸裂产生冲击波，造成上述相同效果；同时古斯托特蓄力朝玩家喷吐黑渊蚀光，持续造成50%,12.5%,5%(5)伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="盘虺一啸朝夕映-猛攻"/>
