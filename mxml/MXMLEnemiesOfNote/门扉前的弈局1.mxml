	<mx:Text styleName="textStyle" x="64" y="448" width="441" text="「弈局」：王棋&amp;后棋"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="608" width="464" text="并非「弈局」的执棋者"/>
	<mx:Text styleName="textStyle4" x="64" y="992" width="305" alpha="0.9" text="抗性数据(单位%)"/>
