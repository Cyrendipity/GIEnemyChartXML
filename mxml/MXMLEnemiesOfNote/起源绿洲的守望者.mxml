	<mx:Text styleName="textStyle" x="64" y="384" width="410" text="起源绿洲的守望者"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="388" text="经由「火种」而得以复苏的生命"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1247" y="64" width="609" alpha="0.5" text="元素能量：NA"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="305" text="HP: 593605 (16.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="周本-第三阶段 Lv.90 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 19031 (10.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 20000/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="436" width="395" alpha="0.75" text="Warden of Oasis Prime"/>
	<mx:Text styleName="textStyle9" x="64" y="586" width="410" alpha="0.75" text="Revived By the Fire Seed"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="守望者进行甩尾、横扫2段攻击，每段分别造成80%,90%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="512" width="448" alpha="0.9" text="守望者朝天蓄能，产生持续3轮的下落缠花弹攻击。第一轮造成100%伤害，第二三轮造成70%伤害。该技能为持久技，第一轮之后守望者会施放其他技能。"/>
	<mx:Text styleName="textStyle10" x="736" y="800" width="768" alpha="0.9" text="守望者在原地不断旋舞、扩散有毒地面，接触其高频造成10%伤害。其将产生3个位置固定的「苏生的礼赞」护罩，吟唱5s后，施放末日的余波，造成400%伤害，以上伤害闪避帧均无效。处在「苏生的礼赞」护罩内的玩家不受任何伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="512" width="448" alpha="0.9" text="守望者钻入地面，在玩家处钻出(或在中央)，顺便进行扫尾攻击，造成70%伤害。该技能常用于位置转移。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="叶繁蓊茂-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" text="汐生菡蕾-持续"/>
	<mx:Text styleName="textStyle11" x="736" y="736" width="448" text="末日余波-爆发"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" text="逾土萌茁-位移"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="肇始旋奏-追踪"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="守望者蓄力，放出15个螺旋弹，该弹瞄准玩家后直线攻击，每个均造成50%,25%,12.5%,5%伤害。"/>
