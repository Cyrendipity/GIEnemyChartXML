	<mx:Image source="Image30.png" x="1248" y="1112" width="168" height="168"/>
	<mx:Text styleName="textStyle13" x="1408" y="1504" width="448" alpha="0.9" text="当一方倒下后，另一方会消耗当前50%生命值将其复活等同于消耗量的生命值，期间抗性大幅提升；治疗方处于20%生命值时不再消耗，若其低于20%则放弃治疗进入狂暴，任由另一方消亡，并将自身攻击力永久提升100%，降低抗性。王进入狂暴时造成40%伤害。"/>
	<mx:Text styleName="textStyle14" x="1408" y="1440" width="448" text="弈舞·未落之幕-回复"/>
	<mx:Image source="Image31.png" x="1248" y="1430" width="168" height="170"/>
	<mx:Image source="Image32.png" x="64" y="1189" width="484" height="60"/>
	<mx:Text styleName="textStyle12" x="0" y="1207" width="64" text="王怒"/>
	<mx:Image source="Image33.png" x="1268" y="171" width="128" height="128"/>
	<mx:Text styleName="textStyle13" x="1408" y="224" width="448" alpha="0.9" text="后召唤4枚雷电棘刺，对前方的目标造成40%,20%,8%伤害。"/>
	<mx:Text styleName="textStyle14" x="1408" y="160" width="448" text="风弦·声潺肃箭-输出"/>
