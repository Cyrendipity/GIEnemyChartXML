	<mx:Image source="Image9.png" x="576" y="1142" width="168" height="170"/>
	<mx:Text styleName="textStyle11" x="1408" y="896" width="448" text="祸神之黯-追踪"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="愠恚不弭-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="断梁绝槊-猛攻"/>
	<mx:Text styleName="textStyle11" x="1408" y="640" width="448" text="裁绸断碎-位移"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle13" x="64" y="1320" width="448" alpha="0.75" text="恶耀魔甲：96雷盾，击破可移除抗性，使祸津退出恶耀影向天魔状态并眩晕；与其发生元素反应可产生3枚全元素微粒，CD1.5s；每10s，将失去8雷盾。追忆花团：25雷充能盾，雷元素攻击+25/次，其他元素攻击+6.5/次，其他攻击无效，击破展开护罩。"/>
