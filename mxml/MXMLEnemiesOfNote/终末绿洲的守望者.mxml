	<mx:Text styleName="textStyle" x="64" y="384" width="410" text="终末绿洲的守望者"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="442" text="历经千年之「末日」的进化生命"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1247" y="64" width="609" alpha="0.5" text="元素能量：NA"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="305" text="HP: 667806 (18.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="周本-第一阶段 Lv.90 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 11419 (6.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 20000/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="436" width="395" alpha="0.75" text="Warden of the Last Oasis"/>
	<mx:Text styleName="textStyle9" x="64" y="586" width="410" alpha="0.75" text="Evolved From an Apocalyptic Millennium"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="守望者钻入地面，随后突出给玩家一个环抱，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="守望者进行3段的普通攻击：砸、划、翻，每段分别造成50%,80%,90%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="守望者将前肢插入地面，在玩家处冒出四个肢条，分别进行交砸，造成70%,35%,7%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="768" alpha="0.9" text="守望者进行连续三下的原地震敲攻击，三段分别造成70%,70%,90%伤害，并且前两段的每段均产生数十个随机翻滚的刺球，接触造成70%,35%,7%伤害，第三段震敲则变为产生大型的刺球，接触造成80%,40%,8%伤害。每次攻击都有概率产生2个有追踪性的刺球。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="穷乡踱围-伏击"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="萧枝寂蔓-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="608" width="448" text="藻荇交横-锁定"/>
	<mx:Text styleName="textStyle11" x="736" y="832" width="448" text="蠹祸之飨-爆发"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="葳菸相偕-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="末路扶疏-防卫"/>
	<mx:Text styleName="textStyle11" x="1408" y="608" width="448" text="妄淆余律-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="守望者进行2或4段的普通攻击：划、砸、旋、翻，每段分别造成50%,50%,80%,90%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="处在其后侧方时，守望者进行至多2段的划击，每段分别造成70%,90%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="守望者在原地大范围旋转，造成90%伤害。"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
