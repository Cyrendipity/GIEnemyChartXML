	<mx:Image source="Image14.png" x="1248" y="920" width="168" height="168"/>
	<mx:Text styleName="textStyle14" x="736" y="224" width="448" alpha="0.9" text="(半瘫施放)另一侧的机械臂会召唤至多6次的落雷，均造成66%伤害。第1、2、4、5次落雷施放完毕均掉落1个小能量块。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="正机召唤12个围绕自己的激光器，逆时针旋转，发射激光造成100%,50%,25%伤害，10s后激光爆发，伤害与之前相同，并掉落1个大能量块。正机身边的等离子场造成相同的伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="正机使用上方机械臂汇聚雷素，6s后发射激光作于全场，持续造成50%伤害，5s后爆破，造成100%伤害，并掉落1个大能量块。"/>
	<mx:Text styleName="textStyle10" x="736" y="1248" width="448" alpha="0.9" text="瘫痪状态的的正机恢复，施放强力轰击，击退所有在场玩家，无伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="正机上方的两机械臂不断洒落雷晶，造成100%,50%,25%,10%伤害，掉落2个小能量块，最后扔出2个雷光棱镜均造成50%伤害(闪避帧无效)。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="障破灵毕逐连-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="灭劫轮转殛流-猛攻"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="抚撼千灌爆震-猛攻"/>
	<mx:Text styleName="textStyle11" x="736" y="1184" width="448" text="无心除垢消桀-恢复"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="幽冥砺雷封合-持续"/>
