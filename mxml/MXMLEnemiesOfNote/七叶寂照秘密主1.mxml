	<mx:Text styleName="textStyle" x="64" y="480" width="442" text="七叶寂照秘密主"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="608" width="305" text="「正机之神」"/>
	<mx:Text styleName="textStyle4" x="64" y="928" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：NA"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="305" text="HP: 742006 (20.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="736" width="305" alpha="0.75" text="周本-第一阶段 Lv.90 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="816" width="375" text="ATK: 9516 (5.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="864" width="375" text="Wt/Ed: 20000/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="542" width="395" alpha="0.75" text="Everlasting Lord ofArcane Wisdom"/>
	<mx:Text styleName="textStyle9" x="64" y="651" width="395" alpha="0.75" text="Shouki no Kami, the Prodigal"/>
	<mx:Image source="Image5.png" x="64" y="973" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="704" width="448" alpha="0.9" text="正机使用单个机械臂朝地面猛击，造成对应元素的75%伤害，然后产生爆破，造成对应元素的100%伤害，并留下霜寒或余火地面，掉落1个大能量块。霜寒地面造成5%伤害；余火地面造成15%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="992" width="448" alpha="0.9" text="正机使用单个机械臂划过地面，然造成对应元素的100%伤害，留下小范围的霜寒或余火地面。"/>
	<mx:Text styleName="textStyle10" x="1408" y="992" width="448" alpha="0.9" text="正机召唤3个风涡，触碰造成33%伤害，之后染上水元素，形成水龙卷在场地游走，触碰造成50%伤害，一段时间后，水龙卷爆发，造成75%伤害，每个都会掉落1个小能量块。"/>
	<mx:Text styleName="textStyle10" x="1408" y="704" width="448" alpha="0.9" text="正机先使用一侧的机械臂喷洒冰雾或烈火扫场，持续造成对应元素的100%,50%,25%,10%伤害，并留下霜寒或余火地面，随后使用另一侧砸击地面，造成对应元素的66%伤害。掉落1个大能量块。"/>
	<mx:Text styleName="textStyle11" x="736" y="640" width="448" text="冰结炎劫轰震-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="928" width="448" text="残雪余温摩挲-追加"/>
	<mx:Text styleName="textStyle11" x="1408" y="928" width="448" text="风怒龙吟水啸-追加"/>
	<mx:Text styleName="textStyle11" x="1408" y="640" width="448" text="气寒灼焰覆辙-妨害"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle13" x="64" y="1104" width="448" alpha="0.75" text="大能量块：恢复虚空终端100%能量。小能量块：恢复虚空终端50%能量。雷元素矩阵：瘫痪正机之神的一侧，激活2侧可完全瘫痪正机之神，CD1min。风元素矩阵：产生持续15s的风场，用于躲避伤害，CD15s。火元素矩阵：清除全场的霜寒地面，CD10s。冰元素矩阵：清除全场的余烬地面，CD10s。水元素矩阵：持续恢复全部在场角色生命值，10%/2s，持续10s，CD15s。激活一次矩阵会掉落对应元素的5个元素微粒。"/>
