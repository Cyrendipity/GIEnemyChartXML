	<mx:Text styleName="textStyle8" x="64" y="529" width="485" alpha="0.75" text="Exalted Master of the Heretical Path"/>
	<mx:Text styleName="textStyle9" x="64" y="619" width="395" alpha="0.75" text="Il Dotorre"/>
