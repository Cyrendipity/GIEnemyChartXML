	<mx:Text styleName="textStyle" x="64" y="672" width="460" text="「公子」"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="800" width="419" text="别看了这里没有"/>
	<mx:Text styleName="textStyle4" x="64" y="1120" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1237" y="64" width="619" alpha="0.5" text="元素能量：WO[75,50,25,0]"/>
	<mx:Text styleName="textStyle6" x="64" y="928" width="305" alpha="0.75" text="周本-第三阶段 Lv.90 Data"/>
	<mx:Text styleName="textStyle7" x="64" y="960" width="305" text="HP: 243541 (10.0H)"/>
	<mx:Text styleName="textStyle7" x="64" y="1008" width="375" text="ATK: 26644 (14.0B1)"/>
	<mx:Text styleName="textStyle7" x="64" y="1056" width="375" text="Wt/Ed: 20000/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="753" width="395" alpha="0.75" text="「Childe」"/>
	<mx:Text styleName="textStyle9" x="64" y="835" width="395" alpha="0.75" text="Nothing There"/>
	<mx:Image source="Image6.png" x="64" y="1165" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="公子使用手中的邪刃进行3段普攻，第一段与第二段分别造成25%,35%伤害；第三段扔出邪枪，造成25%伤害；邪枪在前方旋转，持续造成4次15%伤害，命中均施加「断流·雷」效果。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="处在公子近身时，公子使用手中的邪刃先右斩再左斩，各造成25%伤害，命中施加「断流·雷」效果。"/>
	<mx:Text styleName="textStyle11" x="736" y="704" width="448" alpha="0.9" text="公子在每个玩家处召唤并落下4个雷枪，造成一次50%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="928" width="448" alpha="0.9" text="断流效果下，公子使用雷环标记玩家，升空几秒后落在圈的位置，5m内造成100%伤害，外围造成50%伤害(闪避帧均无效)，命中引爆「断流」效果。"/>
	<mx:Text styleName="textStyle12" x="1408" y="704" width="448" alpha="0.9" text="断流效果下，公子扔出手中的邪枪，邪枪绕场地滚动，触碰造成40%伤害，命中施加「断流·雷」效果，一段时间后邪枪消失。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="公子使用手中的邪枪进行至多5段冲刺，每次均造成37.5%伤害，命中施加「断流·雷」效果。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="处在公子身后时，公子挥转手中的邪枪向后斩击，造成50%伤害，命中施加「断流·雷」效果。"/>
	<mx:Text styleName="textStyle13" x="736" y="160" width="448" text="邪闪秽雷-输出"/>
	<mx:Text styleName="textStyle13" x="736" y="416" width="448" text="银索霎闪-输出"/>
	<mx:Text styleName="textStyle13" x="736" y="640" width="448" text="霓云雳雨-瞄准"/>
	<mx:Text styleName="textStyle13" x="736" y="864" width="448" text="殛恶绝陨-爆发"/>
	<mx:Text styleName="textStyle13" x="1408" y="640" width="448" text="疾电神枪-扰动"/>
	<mx:Text styleName="textStyle13" x="1408" y="160" width="448" text="紫风蹑影-位移"/>
	<mx:Text styleName="textStyle13" x="1408" y="416" width="448" text="霆时刹那-防卫"/>
