	<mx:Text styleName="textStyle" x="64" y="512" width="441" text="焚尽的炎之魔女"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="640" width="464" text="罗莎琳·克鲁兹希卡·洛厄法特"/>
	<mx:Text styleName="textStyle4" x="64" y="960" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：NA"/>
	<mx:Text styleName="textStyle6" x="64" y="800" width="305" text="HP: 742006 (20.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="768" width="305" alpha="0.75" text="周本-第二阶段 Lv.90 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="848" width="375" text="ATK: 9135 (4.8B1)"/>
	<mx:Text styleName="textStyle6" x="64" y="896" width="375" text="Wt/Ed: 20000/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="574" width="395" alpha="0.75" text="Crimson Witch of Embers"/>
	<mx:Text styleName="textStyle9" x="64" y="675" width="395" alpha="0.75" text="Rosalyne-Kruzchka Lohefalter"/>
	<mx:Image source="Image4.png" x="64" y="1005" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="罗莎琳使劲挥动手中的火鞭，以5种方式施放：近弧、远直、双连、倒直、倒弧，不论怎么施放，都造成50%伤害，命中+5%炎热值。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="罗莎琳张开双翼，扇一下挥出一个暗红色的火球，火球沿直线移动，碰到造成62.5%伤害，并在途经上留下余烬，命中+5%炎热值。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="罗莎琳张开双翼哀嚎，召唤数个火陨命中地面，有较弱的玩家倾向，每个火陨造成100%伤害，命中+5%炎热值。"/>
	<mx:Text styleName="textStyle10" x="1408" y="896" width="448" alpha="0.9" text="罗莎琳传送转移的时候化为暗红的火球，触碰造成37.5%伤害，命中+5%炎热值。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1120" width="448" alpha="0.9" text="当罗莎琳本次受到的伤害超过本阶段生命值的20.1%时，罗莎琳施放一次大范围爆炸，造成125%伤害(闪避帧无效)，充满炎热值；该次伤害超过罗莎琳生命值20.1%的部分无效(即受到的最高伤害只能是罗莎琳生命值的20.1%)。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="炽炎笞灭-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="燔焦炙土-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="608" width="448" text="冕霞降陨-爆发"/>
	<mx:Text styleName="textStyle12" x="1408" y="832" width="448" text="業瘴罪身-位移"/>
	<mx:Text styleName="textStyle11" x="1408" y="1056" width="448" text="流灼如狱-天赋"/>
	<mx:Text styleName="textStyle13" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle14" x="64" y="1136" width="448" alpha="0.75" text="霜之眼：7次次数盾，位于场地四角，靠近每秒-20%炎热值，击破后清除半径12.5m内的余烬，且清空玩家炎热值；最大可再生数量为2。炎热：正常每秒积攒3%，满后每秒流失(3%+150)生命值，火/燃附着+20%积攒速度，冰/水附着-20%积攒速度。"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="罗莎琳的部分攻击命中地面会产生余烬，其持续造成6.25%伤害(闪避帧无效)，命中+2.5%炎热值，余烬永久存在，只能被霜之眼破坏。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="罗莎琳张开双翼，召唤一堆的火之蝶坠向地面，造成25%伤害，并留下余烬，命中+2%炎热值。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="罗莎琳召唤一个较大的红莲蛾，红莲蛾追逐玩家，具有一定追踪性，会穿墙，碰到造成25%伤害，命中+5%炎热值。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="罗莎琳挥舞火鞭，插入地面，呈三叉状，造成50%伤害，之后罗莎琳用力拔出，造成75%伤害，命中+5%炎热值。"/>
	<mx:Text styleName="textStyle10" x="736" y="1120" width="448" alpha="0.9" text="罗莎琳位于场地中央，旋转自身变成大火龙卷，触碰造成75%伤害，该大火龙卷会不断分出4个小火龙卷，各造成37.5%伤害，大火龙卷经过的地方会留下余烬；被大火龙卷命中+5%炎热值，被小火龙卷则+2%炎热值；持续时间结束后大火龙卷重新变为罗莎琳，会充满一半的炎热值。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="焚心之赤-天赋"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="红莲翳火-妨害"/>
	<mx:Text styleName="textStyle11" x="736" y="608" width="448" text="丹蝶红莲-追踪"/>
	<mx:Text styleName="textStyle11" x="736" y="832" width="448" text="燹笞三罚-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="1056" width="448" text="净染超脱-爆发"/>
