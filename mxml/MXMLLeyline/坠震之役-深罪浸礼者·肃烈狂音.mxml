	<mx:Text styleName="textStyle14" x="1120" y="736" width="160" alpha="0.6" text="× 12.8"/>
	<mx:Text styleName="textStyle15" x="64" y="704" width="160" text="元素护罩："/>
	<mx:Text styleName="textStyle10" x="64" y="602" width="512" alpha="0.9" text="深罪浸礼者拥有4种元素核心，其厚度为2火/2水/1雷/2冻盾，于12s后爆炸，击毁可阻止其引爆，全部击毁可重瘫浸礼者。本次出场的浸礼者为雷火水版本。(N5) 该难度及以上将不会放置元素核心。"/>
