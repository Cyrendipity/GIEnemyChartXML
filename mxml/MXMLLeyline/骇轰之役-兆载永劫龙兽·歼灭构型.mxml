	<mx:Image source="Image6.png" x="654" y="847" width="100" height="99"/>
	<mx:Text styleName="textStyle11" x="64" y="388" width="576" alpha="0.9" text="吸收上一个周期内所受伤害最多的元素属性，并提升60%该元素抗性。(N5) 抗性提升效果变为为200%。"/>
	<mx:Text styleName="textStyle16" x="800" y="938" width="128" alpha="0.6" text="Multiple Elements Adv."/>
	<mx:Text styleName="textStyle17" x="640" y="938" width="128" alpha="0.3" text="——"/>
