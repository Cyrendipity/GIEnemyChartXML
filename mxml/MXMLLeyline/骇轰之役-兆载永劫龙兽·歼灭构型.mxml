	<mx:Text styleName="textStyle11" x="64" y="666" width="512" alpha="0.9" text="击中永劫龙兽的弱点时不会使其瘫痪落地，也不影响元素洪流的吸收，甚至无法中断技能施放。"/>
	<mx:Text styleName="textStyle11" x="64" y="762" width="512" alpha="0.9" text="永劫龙兽若保持同一元素抗性超过55s，则会尝试升空作战。"/>
	<mx:Image source="Image4.png" x="128" y="256" width="484" height="124"/>
	<mx:Text styleName="textStyle12" x="64" y="512" width="183" text="(N5) 反制保护："/>
	<mx:Text styleName="textStyle13" x="640" y="736" width="160" alpha="0.6" text="× 1.2"/>
	<mx:Text styleName="textStyle13" x="800" y="736" width="160" alpha="0.6" text="× 4.0"/>
	<mx:Text styleName="textStyle14" x="960" y="736" width="160" alpha="0.6" text="× 4.3"/>
	<mx:Text styleName="textStyle7" x="1120" y="768" width="160" text="17417"/>
	<mx:Text styleName="textStyle7" x="1120" y="704" width="160" text="13909262"/>
	<mx:Text styleName="textStyle8" x="1147" y="619" width="108" text="绝境 - N6Lv.110"/>
	<mx:Text styleName="textStyle15" x="1120" y="736" width="160" alpha="0.6" text="× 9.1"/>
	<mx:Text styleName="textStyle12" x="64" y="640" width="256" text="(N5) 强化翼胫："/>
	<mx:Text styleName="textStyle12" x="64" y="736" width="256" text="(N5) 多元作战："/>
	<mx:Text styleName="textStyle11" x="64" y="538" width="512" alpha="0.9" text="永劫龙兽会以自身生命值划分为4个周期进行战斗：由生命值处于75%/49%/24%的瞬时锁血进行划分，每个周期内永劫龙兽会吸收周期内所受伤害最多的元素进行转换并提升200%对应抗性。触发瞬时锁血后，永劫龙兽会立即播放瘫痪动画，随后吸收元素。"/>
	<mx:Text styleName="textStyle9" x="1152" y="938" width="128" alpha="0.3" text="——"/>
