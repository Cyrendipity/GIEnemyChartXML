	<mx:Text styleName="textStyle13" x="64" y="576" width="129" text="虚界力护罩："/>
	<mx:Text styleName="textStyle14" x="640" y="736" width="160" alpha="0.6" text="× 1.2"/>
	<mx:Text styleName="textStyle14" x="800" y="736" width="160" alpha="0.6" text="× 4.0"/>
	<mx:Text styleName="textStyle14" x="960" y="736" width="160" alpha="0.6" text="× 5.6"/>
	<mx:Text styleName="textStyle7" x="1120" y="768" width="160" text="15965"/>
	<mx:Text styleName="textStyle7" x="1120" y="704" width="160" text="11168065"/>
	<mx:Text styleName="textStyle8" x="1147" y="619" width="108" text="绝境 - N6Lv.110"/>
	<mx:Text styleName="textStyle15" x="1120" y="736" width="160" alpha="0.6" text="× 8.9"/>
	<mx:Text styleName="textStyle13" x="64" y="768" width="160" text="蚀破："/>
	<mx:Text styleName="textStyle16" x="64" y="602" width="512" alpha="0.9" text="在「祝祷」期间内展开持续13s的次数盾，其厚度为53次；每次元素攻击可削减该护盾1点，带有夜魂性质的攻击则削减3点，没有冷却；击破后，摹结株将瘫痪12s。(N4) 次数盾厚度为72次，且不再衰减。(N5) 非「祝祷」期间常驻厚度为150次次数盾，击破后依照次数盾所承受伤害造成一次高额真伤，由60%夜魂总伤+10%非夜魂总伤构成，不超过摹结株30%的生命值。击破后的瘫痪时间延长至18s；次数盾Gap为20s。"/>
	<mx:Text styleName="textStyle9" x="1152" y="938" width="128" alpha="0.3" text="——"/>
