	<mx:Text styleName="textStyle9" x="736" y="256" width="448" alpha="0.9" text="寄骑武士进行向上或向下的单次攻击，造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="480" width="448" alpha="0.9" text="寄骑武士将刀举过头顶，进行连续两次的下劈攻击，两段分别造成50%,100%伤害，该技能为振刀版的砻炼剑技。"/>
	<mx:Text styleName="textStyle9" x="736" y="704" width="448" alpha="0.9" text="寄骑武士进行左横劈、下直劈两段攻击，两段均造成75%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="928" width="448" alpha="0.9" text="寄骑武士面对玩家，侧身将剑对准玩家冲刺，造成125%伤害，距离较远。"/>
	<mx:Text styleName="textStyle10" x="736" y="1152" width="448" alpha="0.9" text="(一心传技能)寄骑武士侧身将刀入鞘，产生真空场吸引玩家，即刻挥出如万叶之一刀之「流风秋野」领域，其不断造成30%伤害，持续5轮后消失。"/>
	<mx:Text styleName="textStyle9" x="1408" y="928" width="448" alpha="0.9" text="寄骑武士侧身将刀入鞘，向玩家冲刺并拔刀，造成150%伤害，距离较近。"/>
	<mx:Text styleName="textStyle11" x="1408" y="1152" width="448" alpha="0.9" text="(振刀技能)寄骑武士赋予自己一层屏障效果，抗打断0，该效果在其受到盾反伤害后移除。"/>
	<mx:Text styleName="textStyle9" x="736" y="1376" width="448" alpha="0.9" text="寄骑武士架剑格挡前方伤害，抗打断0.5。格挡有两种姿势：双手持剑柄、左刃右柄。"/>
	<mx:Text styleName="textStyle9" x="1408" y="256" width="448" alpha="0.9" text="寄骑武士进行挥、劈、十字斩3段攻击，每段攻击分别造成87.5%,87.5%,75%x2伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="480" width="448" alpha="0.9" text="寄骑武士侧身，拔刀进行快速上下挥刀，两段均造成106.25%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="704" width="448" alpha="0.9" text="寄骑武士跳起来进行下劈，造成120%伤害。"/>
