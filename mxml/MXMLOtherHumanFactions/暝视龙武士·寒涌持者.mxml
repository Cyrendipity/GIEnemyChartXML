	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="寒涌持者旋转冰锯扔出一枚锯片，造成80%伤害，同时近身旋转的锯片也会造成75%伤害，两者造成的伤害存在(1,0.5)的衰减。"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" alpha="0.9" text="寒涌持者驱使灵力将飞锯附魔，攻击力提升20%，随后产生一次冰雾震，造成60%伤害，仅施放一次。施放后，寒涌持者之后施放的普攻将造成冰元素伤害，且第三段普攻将产生向前切的冰锯。"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="碎镜棱花-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="640" width="448" text="皑寒倾咒-强化"/>
