	<mx:Text styleName="textStyle13" x="1408" y="256" width="448" alpha="0.9" text="迷者旋转画笔，转身向前方泼洒凝霜彩漆，依次造成25%,100%伤害。"/>
	<mx:Text styleName="textStyle13" x="1408" y="480" width="448" alpha="0.9" text="迷者突然起身，造成36%伤害，并朝着玩家飞去，然后挥舞画笔两下，均造成85%伤害。"/>
	<mx:Text styleName="textStyle13" x="1408" y="704" width="448" alpha="0.9" text="迷者移至中央，荡起寒雾，造成75%伤害，又游引四处，生4道灵觉隐修的浮彩分身，并在迷者隐去和分身现形的位置再次鸣荡，造成25%伤害。"/>
	<mx:Text styleName="textStyle13" x="736" y="256" width="448" alpha="0.9" text="迷者使用笔刷进行2段普攻，依次造成60%,75%伤害。"/>
	<mx:Text styleName="textStyle13" x="736" y="480" width="448" alpha="0.9" text="迷者甩出追踪性的一滴晨露，造成95%伤害。"/>
	<mx:Text styleName="textStyle13" x="736" y="704" width="448" alpha="0.9" text="迷者在玩家下方生成1-3枚灵空印记，均造成100%伤害。"/>
	<mx:Text styleName="textStyle13" x="736" y="928" width="448" alpha="0.9" text="分身使用笔刷进行2段普攻，依次造成60%,75%伤害。单独施放。"/>
	<mx:Text styleName="textStyle13" x="736" y="1152" width="448" alpha="0.9" text="分身转身向前方泼洒凝霜彩漆，造成100%伤害。作为谜影循环的结尾技能施放。"/>
	<mx:Text styleName="textStyle13" x="1408" y="928" width="448" alpha="0.9" text="分身使用笔刷进行1段下滑普攻，造成85%伤害。作为谜影循环开始的持续循环技能。"/>
	<mx:Text styleName="textStyle14" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle15" x="64" y="1132" width="448" alpha="0.75" text="浮彩分身：8冻盾，一共4个，击破会使本体现身4s，全部击破则瘫痪本体12s；使用烟谜主/暝视龙的能力扫瞄一个分身，则可以硬控所有分身15s，并使全部分身-2冻。"/>
