	<mx:Text styleName="textStyle10" x="1408" y="416" width="448" text="迁毫搭锋-位移"/>
	<mx:Text styleName="textStyle10" x="1408" y="640" width="448" text="影徒随身-召唤"/>
	<mx:Text styleName="textStyle10" x="736" y="192" width="448" text="浅拖折锋-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="416" width="448" text="日台垂露-远程"/>
	<mx:Text styleName="textStyle10" x="736" y="640" width="448" text="烟络横林-远程"/>
	<mx:Text styleName="textStyle11" x="736" y="864" width="448" text="轻引回锋-输出"/>
