	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="雷腾进行3段的普通攻击，每段攻击都造成46.6%/46.6%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="雷腾将刀刃附上雷元素，附魔完成后进行一次下劈，造成100%伤害，附魔持续30s，不可被元素反应消除。"/>
	<mx:Text styleName="textStyle8" x="736" y="672" width="448" alpha="0.9" text="雷腾举着刀直接跳起来，朝下劈，造成80%/80%伤害，当处于雷附魔状态时跳劈纵向范围提升175%。"/>
	<mx:Text styleName="textStyle8" x="736" y="896" width="448" alpha="0.9" text="当附近有海乱鬼倒下时，短时间50m内战斗状态下的海乱鬼会进入「忿恨」状态：立即恢复50%生命值，免疫冻结和石化。雷腾进入此状态后，无论刀是否有火附魔，攻击均造成雷元素伤害。"/>
	<mx:Image source="Image7.png" x="596" y="1099" width="128" height="128"/>
	<mx:Image source="Image8.png" x="576" y="1078" width="168" height="170"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="雷腾将剑朝向玩家，并蓄势冲向玩家，造成66.6%/66.6%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="雷腾侧身插刀，拔刀时旋转一圈半，造成2段66.6%/66.6%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="672" width="448" alpha="0.9" text="雷腾斜拿刀刃，抵挡前方任何攻击，免疫击飞，持续一段时间后放下。该状态下不免疫冻结和石化，处于冻结或石化状态下仍可受伤。"/>
	<mx:Text styleName="textStyle9" x="1408" y="896" width="448" alpha="0.9" text="(振刀技能)雷腾进行至多5段的普通攻击，每段攻击都产生一道雷刃，造成30%伤害，该雷刃可被反击。"/>
	<mx:Text styleName="textStyle9" x="736" y="1152" width="448" alpha="0.9" text="(振刀技能)当雷腾进行格挡时，持续攻击雷腾会使其突然下劈一刀，造成150%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="刀法·奔雷-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="384" width="448" text="惟神术·震-强化"/>
	<mx:Text styleName="textStyle10" x="736" y="608" width="448" text="跃击·迁辐-猛攻"/>
	<mx:Text styleName="textStyle10" x="736" y="832" width="448" text="忿恨·雳惊-回复"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="冲击·电闪-位移"/>
	<mx:Text styleName="textStyle10" x="1408" y="384" width="448" text="冲旋·离解-位移"/>
	<mx:Text styleName="textStyle10" x="1408" y="608" width="448" text="格挡·雷花-格挡"/>
	<mx:Text styleName="textStyle10" x="1408" y="832" width="448" text="气刃·紫光-远程"/>
