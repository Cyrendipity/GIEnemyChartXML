	<mx:Image source="Image3.png" x="64" y="845" width="484" height="124"/>
	<mx:Text styleName="textStyle5" x="736" y="448" width="448" alpha="0.9" text="莉琉朝空中发射一枚大冰雹，随后立即炸裂，裂成8根追踪冰刺，均造成35%伤害。"/>
	<mx:Text styleName="textStyle5" x="1408" y="224" width="448" alpha="0.9" text="莉琉立即使用炮筒发射2枚冰雹，均造成45%伤害"/>
	<mx:Text styleName="textStyle5" x="1408" y="448" width="448" alpha="0.9" text="莉琉驱使灵力，使炮筒凝聚寒气，并产生冰雾震，造成60%伤害并进入强化状态：该状态下允许施放「沆霭眠凇」。"/>
	<mx:Text styleName="textStyle5" x="736" y="896" width="1024" alpha="0.9" text="莉琉的真本事之一。本技能有两种施放方式：1.低于80%生命值时，莉琉升空，并借用2枚坚石之晶汲取力量，在场地内持续不断地降下冰晶，造成100%伤害；2.低于15%生命值时，莉琉爬上高塔吟唱，在场地内持续不断地降下冰晶，造成100%伤害。"/>
	<mx:Text styleName="textStyle5" x="736" y="672" width="448" alpha="0.9" text="莉琉将炮筒滞空，命令其发射从天而降的冰锥，造成100%伤害。"/>
	<mx:Text styleName="textStyle6" x="736" y="384" width="448" text="蔽日萧凌-追踪"/>
	<mx:Text styleName="textStyle6" x="1408" y="160" width="448" text="谧寒星点-远程"/>
	<mx:Text styleName="textStyle6" x="1408" y="384" width="448" text="卜谜之巧-强化"/>
	<mx:Text styleName="textStyle6" x="736" y="832" width="448" text="沆霭眠凇-爆发"/>
	<mx:Text styleName="textStyle6" x="736" y="608" width="448" text="炽阳凛晶-定点"/>
	<mx:Text styleName="textStyle7" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle8" x="1387" y="64" width="469" alpha="0.5" text="元素能量：NA"/>
	<mx:Text styleName="textStyle2" x="64" y="352" width="490" text="暝视龙武士·「伊奎米利的寒星」「莉琉」"/>
	<mx:Text styleName="textStyle9" x="64" y="503" width="395" alpha="0.75" text="Iktomisaurus Warroir: Frost Star of Ixquimilli：Liliuo"/>
	<mx:Text styleName="textStyle10" x="65" y="976" width="448" alpha="0.75" text="坚岩之晶：4次次数盾，击破其中一个即可打断莉琉招式，并致摔伤。常驻抗打断0.25。"/>
	<mx:Image source="Image4.png" x="64" y="78" width="256" height="243"/>
	<mx:Text styleName="textStyle5" x="736" y="224" width="448" alpha="0.9" text="莉琉拿着炮筒进行划、砸2段攻击，分别造成50%,70%伤害。"/>
	<mx:Text styleName="textStyle5" x="1408" y="672" width="448" alpha="0.9" text="莉琉拿着炮筒进行格挡，可格挡最多4次，满4次时立即触发闪现，并施放随机小技能。此后各有50%概率将格挡计数重置为1或0。"/>
	<mx:Text styleName="textStyle6" x="736" y="160" width="448" text="质量久耐-输出"/>
	<mx:Text styleName="textStyle6" x="1408" y="608" width="448" text="捷御身武-防御"/>
