	<mx:Text styleName="textStyle" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle2" x="64" y="800" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle3" x="64" y="640" width="305" text="HP: 332760 (6.0F)"/>
	<mx:Text styleName="textStyle4" x="64" y="608" width="305" alpha="0.75" text="普通 Lv.100 Data"/>
