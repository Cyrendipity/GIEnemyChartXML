	<mx:Text styleName="textStyle" x="64" y="352" width="460" text="镀金旅团·魔岩役使"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle" x="64" y="736" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle3" x="1216" y="64" width="640" alpha="0.5" text="元素能量：GP[75,50,25,0]"/>
	<mx:Text styleName="textStyle4" x="64" y="576" width="305" text="HP: 277300 (5.0F)"/>
	<mx:Text styleName="textStyle5" x="64" y="544" width="305" alpha="0.75" text="普通 Lv.100 Data"/>
	<mx:Text styleName="textStyle4" x="64" y="624" width="375" text="ATK: 9849 (4.0B2)"/>
	<mx:Text styleName="textStyle4" x="64" y="672" width="375" text="Wt/Ed: 150/210"/>
	<mx:Text styleName="textStyle6" x="64" y="465" width="395" alpha="0.75" text="Eremite: Stone Enchanter"/>
	<mx:Text styleName="textStyle7" x="736" y="224" width="448" alpha="0.9" text="魔岩役使使用盾斧进行划、戳、掘岩3段攻击，前两段攻击均造成75%伤害，第三段产生的碎岩波造成50%,25%,10%,5%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="448" width="448" alpha="0.9" text="魔岩役使使用盾斧进行划击，造成75%伤害，是虚弱后施放的两个技能之一。"/>
	<mx:Text styleName="textStyle7" x="736" y="672" width="448" alpha="0.9" text="魔岩役使侧身使用盾斧蓄力，进行旋转攻击，持续造成50%伤害，旋转结束后施放尾刀，造成75%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="896" width="1024" alpha="0.9" text="当魔岩役使的生命值低于70%(特化为100%)时，其会唤出武器内的岩之魔蜥，进入魔化状态，全抗性提升50%。击破岩之魔蜥会使魔岩役使受到当前生命值的37.5%的岩元素真伤，并虚弱10s。一次战斗内仅会施放一次该技能。"/>
	<mx:Image source="Image3.png" x="1268" y="171" width="128" height="128"/>
	<mx:Image source="Image4.png" x="1248" y="150" width="168" height="170"/>
	<mx:Text styleName="textStyle7" x="1408" y="224" width="448" alpha="0.9" text="距离玩家较远时，魔岩役使直接进行掘岩攻击，产生碎岩波，造成50%,25%,10%,5%伤害，是虚弱后施放的两个技能之一。"/>
	<mx:Text styleName="textStyle7" x="1408" y="448" width="448" alpha="0.9" text="距离玩家较远时，魔岩役使跳到玩家上方，朝下丢出一个石块造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="672" width="448" alpha="0.9" text="(魔化)当玩家靠近魔岩役使时，魔岩役使使用盾斧格挡玩家攻击，可将其打碎使魔岩役使暂时失衡。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="岩锋尖斧-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="384" width="448" text="斫岩一击-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="608" width="448" text="黄金回璇-位移"/>
	<mx:Text styleName="textStyle9" x="736" y="832" width="448" text="厄灵解放·岩之魔蜥-位移"/>
