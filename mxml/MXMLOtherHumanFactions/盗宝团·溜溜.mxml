	<mx:Text styleName="textStyle7" x="1390" y="64" width="466" alpha="0.5" text="元素能量：WP[66,33,0](旧)WP[66,33,0x2](新)"/>
	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="(旧)溜溜掏出一瓶燃烧弹，朝玩家丢出，造成70%伤害，余下一片燃烧的地面，持续造成30%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="256" width="448" alpha="0.9" text="(旧)溜溜转身踢，造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="768" width="448" alpha="0.9" text="(新)溜溜给自己的弩附魔火元素，连续发射三枚炽焰箭，每个造成75%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="1024" width="448" alpha="0.9" text="(新)溜溜发怒，进入士气强化状态，该状态可使用「避邪爆竹」破除并使其瘫痪。"/>
	<mx:Text styleName="textStyle8" x="1408" y="512" width="448" alpha="0.9" text="(旧)溜溜掏出匕首，水平扔出，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="512" width="448" alpha="0.9" text="(旧)溜溜起跳，落地斜踢，造成150%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="768" width="448" alpha="0.9" text="(新)溜溜突然后撤，趁机留下一瓶燃烧弹，造成70%伤害，余下一片燃烧的地面，持续造成30%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="1024" width="448" alpha="0.9" text="(新)溜溜站稳，用弩发射火箭，造成75%伤害。"/>
