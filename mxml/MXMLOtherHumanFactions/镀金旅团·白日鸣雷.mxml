	<mx:Text styleName="textStyle" x="64" y="352" width="519" text="镀金旅团·白日鸣雷"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle" x="64" y="736" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle3" x="1387" y="64" width="469" alpha="0.5" text="元素能量：EP[75,50,25,0x2]"/>
	<mx:Text styleName="textStyle4" x="64" y="576" width="305" text="HP: 221840 (4.0F)"/>
	<mx:Text styleName="textStyle5" x="64" y="544" width="305" alpha="0.75" text="普通 Lv.100 Data"/>
	<mx:Text styleName="textStyle4" x="64" y="624" width="375" text="ATK: 5909 (2.4B2)"/>
	<mx:Text styleName="textStyle4" x="64" y="672" width="375" text="Wt/Ed: 80/150"/>
	<mx:Text styleName="textStyle6" x="64" y="465" width="395" alpha="0.75" text="Eremite: Daythunder"/>
	<mx:Text styleName="textStyle7" x="736" y="224" width="448" alpha="0.9" text="白日鸣雷进行连续3段的挥舞攻击，，每段攻击依次造成60%,50%,50%伤害。魔化：攻击伤害提升，依次造成80%,70%,70%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="512" width="448" alpha="0.9" text="当白日鸣雷的生命值低于70%时，白日鸣雷将武器的厄灵解放出来，进入魔化状态，该状态持续20s，状态结束后虚弱8s。"/>
	<mx:Text styleName="textStyle7" x="1408" y="224" width="448" alpha="0.9" text="距离玩家较远时，白日鸣雷拿着枪突然蹦起，触碰造成25%伤害，蹦起落地后迅速进行2次攻击，造成40%,50%伤害。"/>
	<mx:Text styleName="textStyle7" x="1408" y="512" width="448" alpha="0.9" text="白日鸣雷侧身拿着雷枪，进行蓄力旋转攻击，造成75%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="800" width="448" alpha="0.9" text="(魔化)距离玩家较远时，白日鸣雷拿着枪突然蹦起，造成25%伤害，落地迅速攻击两下，造成2段75%伤害，且周围劈下5道落雷，每道均造成75%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="电光斫斧-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="448" width="448" text="厄灵解放·雷覆-强化"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="起落惊雷-远程"/>
	<mx:Text styleName="textStyle9" x="1408" y="448" width="448" text="奔雷电转-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="736" width="448" text="光霆惩雷-远程"/>
