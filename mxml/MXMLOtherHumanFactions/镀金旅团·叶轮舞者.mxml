	<mx:Image source="Image2.png" x="0" y="0" width="426" height="426"/>
	<mx:Text styleName="textStyle" x="64" y="352" width="410" text="镀金旅团·叶轮舞者"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle" x="64" y="736" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle3" x="1247" y="64" width="609" alpha="0.5" text="元素能量：DP[75,50,25,0]"/>
	<mx:Text styleName="textStyle4" x="64" y="576" width="305" text="HP: 277300 (5.0F)"/>
	<mx:Text styleName="textStyle5" x="64" y="544" width="305" alpha="0.75" text="普通 Lv.100 Data"/>
	<mx:Text styleName="textStyle4" x="64" y="624" width="375" text="ATK: 9849 (4.0B2)"/>
	<mx:Text styleName="textStyle4" x="64" y="672" width="375" text="Wt/Ed: 80/210"/>
	<mx:Text styleName="textStyle6" x="64" y="465" width="395" alpha="0.75" text="Eremite: Floral Ring-Dancer"/>
	<mx:Text styleName="textStyle7" x="736" y="224" width="448" alpha="0.9" text="叶轮舞者使用花环进行左挑、右劈、旋转三段攻击，分别造成80%,100%,35%x3伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="448" width="448" alpha="0.9" text="叶轮舞者唤出两个顺时针旋转的花环绕自身旋转，自己则不断旋舞，接触轮环造成35%,17.5%,8.75%,3.5%伤害。"/>
	<mx:Image source="Image3.png" x="1268" y="619" width="128" height="128"/>
	<mx:Image source="Image4.png" x="1248" y="598" width="168" height="170"/>
	<mx:Text styleName="textStyle7" x="736" y="672" width="448" alpha="0.9" text="距离玩家较远时，叶轮舞者传送接近玩家，传送完毕时扔出花环，接触造成80%,20%伤害。该技能是虚弱后施放的两个技能之一。"/>
	<mx:Text styleName="textStyle7" x="736" y="896" width="1024" alpha="0.9" text="当叶轮舞者的生命值低于70%(特化为100%)时，其会唤出武器内的草之灵蛇，进入附魔状态，全抗性提升50%。击破草之灵蛇会使叶轮舞者受到当前生命值的37.5%的草元素真伤，并虚弱10s。一次战斗内仅会施放一次该技能。"/>
	<mx:Text styleName="textStyle8" x="736" y="160" width="448" text="叶轮细裁-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="384" width="448" text="双轮之舞-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="608" width="448" text="闪现飞轮-位移"/>
	<mx:Text styleName="textStyle8" x="736" y="832" width="448" text="厄灵解放·草之灵蛇-召唤"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="轮飞廻斜-远程"/>
	<mx:Text styleName="textStyle8" x="1408" y="384" width="448" text="柳叶快切-输出"/>
	<mx:Text styleName="textStyle8" x="1408" y="608" width="448" text="闪现快切-位移"/>
	<mx:Text styleName="textStyle7" x="1408" y="224" width="448" alpha="0.9" text="距离玩家较远时，叶轮舞者扔出花环进行攻击，接触造成80%,20%伤害，扔出的花环会返回。该技能是虚弱后施放的两个技能之一。"/>
	<mx:Text styleName="textStyle7" x="1408" y="448" width="448" alpha="0.9" text="叶轮舞者使用花环快速进行左挑、右劈两段攻击，分别造成80%,100%伤害。"/>
	<mx:Text styleName="textStyle7" x="1408" y="672" width="448" alpha="0.9" text="距离玩家较远时，叶轮舞者传送接近玩家，传送完毕进行突击，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
