	<mx:Text styleName="textStyle8" x="736" y="864" width="448" text="溯沙之浪-爆发"/>
	<mx:Text styleName="textStyle9" x="736" y="480" width="448" alpha="0.9" text="裂礁之涛打滚，后立即使用炮筒连续发射12枚水弹，每发水弹造成10%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="704" width="448" alpha="0.9" text="距离较远时，裂礁之涛将装弹炮筒，发射3枚迫击水球，均造成80%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="928" width="448" alpha="0.9" text="裂礁之涛驱使灵力，驾驶炮筒进行冲浪，到处乱跑，接触造成70%伤害。"/>
