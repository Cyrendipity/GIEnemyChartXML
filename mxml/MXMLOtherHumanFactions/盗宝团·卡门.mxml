	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="(旧)卡门横向挥动铲子，造成125%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="256" width="448" alpha="0.9" text="(旧)卡门纵向挥动铲子，造成120%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="704" width="448" alpha="0.9" text="(新)卡门纵向挥动铲子，造成75%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="928" width="448" alpha="0.9" text="(新)卡门用铲挖地，扔出3-5个泥土块，每个造成75%伤害，不会遮挡视野。"/>
	<mx:Text styleName="textStyle8" x="1408" y="480" width="448" alpha="0.9" text="(旧)卡门用铲挖地，扔出1个泥土块，不造成伤害，但遮挡视野。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="(旧)卡门横抓铲子，进行冲刺并不断挥动铲子，接触造成50%伤害，冲刺结束后施放强力尾刀，造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="704" width="448" alpha="0.9" text="(新)卡门横向挥动铲子，造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="928" width="448" alpha="0.9" text="(新)卡门横抓铲子，进行冲刺并不断挥动铲子，接触造成50%伤害，冲刺结束后施放强力尾刀，造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="1152" width="448" alpha="0.9" text="(新)卡门发怒，进入士气强化状态，该状态可使用「避邪爆竹」破除并使其瘫痪。"/>
