	<mx:Image source="Image4.png" x="64" y="1069" width="484" height="124"/>
	<mx:Text styleName="textStyle7" x="1408" y="224" width="448" alpha="0.9" text="炎威将剑朝向玩家，并蓄势冲向玩家，造成66.6%/66.6%伤害。"/>
	<mx:Text styleName="textStyle7" x="1408" y="448" width="448" alpha="0.9" text="炎威侧身插刀，拔刀时旋转一圈半，造成2段66.6%/66.6%伤害。"/>
	<mx:Text styleName="textStyle7" x="1408" y="672" width="448" alpha="0.9" text="炎威斜拿刀刃，抵挡前方任何攻击，免疫击飞，持续一段时间后放下。该状态下不免疫冻结和石化，处于冻结或石化状态下仍可受伤。"/>
	<mx:Text styleName="textStyle8" x="1408" y="160" width="448" text="冲击·焰飘-位移"/>
	<mx:Text styleName="textStyle8" x="1408" y="384" width="448" text="冲旋·烟星-位移"/>
	<mx:Text styleName="textStyle8" x="1408" y="608" width="448" text="格挡·击火-格挡"/>
	<mx:Text styleName="textStyle9" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle7" x="736" y="224" width="448" alpha="0.9" text="炎威进行3段的普通攻击，每段攻击都造成46.6%/46.6%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="448" width="448" alpha="0.9" text="炎威将刀刃附上火元素，附魔完成后进行一次下劈，造成100%伤害，附魔持续30s，不可被元素反应消除。"/>
	<mx:Text styleName="textStyle7" x="736" y="672" width="448" alpha="0.9" text="炎威举着刀直接跳起来，朝下劈，造成80%/80%伤害，当处于火附魔状态时跳劈纵向范围提升50%，并且留下高温地面，接触持续造成20%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="896" width="448" alpha="0.9" text="当附近有海乱鬼倒下时，短时间50m内战斗状态下的海乱鬼会进入「忿恨」状态：立即恢复50%生命值，免疫冻结和石化。炎威进入此状态后，无论刀是否有火附魔，攻击均造成火元素伤害。"/>
