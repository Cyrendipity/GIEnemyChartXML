	<mx:Text styleName="textStyle" x="64" y="352" width="410" text="镀金旅团·灵风猎手"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle" x="64" y="736" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle3" x="1387" y="64" width="469" alpha="0.5" text="元素能量：AP[75,50,25,0]"/>
	<mx:Text styleName="textStyle4" x="64" y="576" width="305" text="HP: 244024 (4.4F)"/>
	<mx:Text styleName="textStyle5" x="64" y="544" width="305" alpha="0.75" text="普通 Lv.100 Data"/>
	<mx:Text styleName="textStyle4" x="64" y="624" width="375" text="ATK: 12311 (5.0B2)"/>
	<mx:Text styleName="textStyle4" x="64" y="672" width="375" text="Wt/Ed: 80/210"/>
	<mx:Text styleName="textStyle6" x="64" y="465" width="395" alpha="0.75" text="Eremite: Galehunter"/>
	<mx:Image source="Image3.png" x="64" y="781" width="484" height="124"/>
	<mx:Image source="Image4.png" x="596" y="843" width="128" height="128"/>
	<mx:Image source="Image5.png" x="576" y="822" width="168" height="170"/>
	<mx:Text styleName="textStyle7" x="64" y="1032" width="448" alpha="0.75" text="正在蓄力箭矢或处于魔化状态下，抗打断0，质量翻6倍。虚弱状态下抗打断0。"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="灵风猎手发射一枚风元素箭矢，造成75%伤害，虚弱的灵风猎手只会施放此技能。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="灵风猎手凌空蓄力，产生真空场不断吸引玩家至风矢范围内，3s后箭矢发射，造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="672" width="448" alpha="0.9" text="距离玩家较远时，灵风猎手直接冲来，使用风矢划击，造成75%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="896" width="1024" alpha="0.9" text="当灵风猎手的生命值低于70%(特化为100%)时，其会唤出武器内的风之魔鸢，进入魔化状态，全抗性提升50%。击破风之魔鸢会使灵风猎手受到基于当前生命值的37.5%的风元素真伤，并虚弱10s，一次战斗内仅会施放一次该技能。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="光巡风矢-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="384" width="448" text="一箭风止-控制"/>
	<mx:Text styleName="textStyle9" x="736" y="608" width="448" text="风逐所向-位移"/>
	<mx:Text styleName="textStyle9" x="736" y="832" width="448" text="厄灵解放·风之魔鸢-召唤"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="弓矢搏刃-输出"/>
	<mx:Text styleName="textStyle9" x="1408" y="384" width="448" text="掷矢碎刃-输出"/>
	<mx:Text styleName="textStyle9" x="1408" y="608" width="448" text="诡风避之-位移"/>
	<mx:Image source="Image6.png" x="1268" y="171" width="128" height="128"/>
	<mx:Image source="Image7.png" x="1248" y="150" width="168" height="170"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="距离玩家较近时，灵风猎手手持风矢进行倒身挑、划、砸碎3段攻击，依次造成60%,70%,75%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="距离玩家较近时，灵风猎手掏出风矢并砸碎，造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="(魔化)若玩家接近灵风猎手，灵风猎手将迅速后撤远离玩家。"/>
