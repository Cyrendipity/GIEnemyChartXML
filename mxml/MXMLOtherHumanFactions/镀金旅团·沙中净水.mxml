	<mx:Text styleName="textStyle6" x="64" y="465" width="428" alpha="0.75" text="Eremite: Desert Clearwater"/>
	<mx:Text styleName="textStyle7" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle8" x="736" y="160" width="448" text="运水如丝-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" text="厄灵解放·吞水-强化"/>
	<mx:Image source="Image3.png" x="596" y="747" width="128" height="128"/>
	<mx:Image source="Image4.png" x="576" y="726" width="168" height="170"/>
	<mx:Text styleName="textStyle8" x="1408" y="160" width="448" text="交引汇流-输出"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" text="环转急流-位移"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="448" text="导引源水-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="224" width="448" alpha="0.9" text="沙中净水进行划、戳2段攻击，依次造成40%,50%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="512" width="448" alpha="0.9" text="当沙中净水的生命值低于70%时，沙中净水将武器的厄灵解放出来，进入魔化状态，该状态持续20s，状态结束后虚弱8s。"/>
	<mx:Text styleName="textStyle9" x="1408" y="224" width="448" alpha="0.9" text="沙中净水进行突进式的十字攻击，造成50%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="512" width="448" alpha="0.9" text="距离玩家较远时，沙中净水冲过来进行翻转攻击，造成2段50%伤害，后接十字斩攻击，造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="800" width="448" alpha="0.9" text="(魔化)沙中净水进行3段普通攻击，有2种施放方式：进行纵划、横划、十字斩3段攻击，该方式的攻击依次造成50%,50%,75%伤害；进行划、戳、十字斩3段攻击，每段攻击分别造成60%,50%,75%伤害。"/>
