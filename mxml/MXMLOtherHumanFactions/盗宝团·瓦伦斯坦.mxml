	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="瓦伦斯坦快速挥动大锤攻击，挥舞2段，均造成50%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="瓦伦斯坦抡起大锤，蓄力进行至多2段攻击，均造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="448" alpha="0.9" text="瓦伦斯坦甩动大锤，随后开始旋转并朝玩家移动，接触造成25%伤害，旋转结束后施放强力尾锤，造成30%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="瓦伦斯坦挥动大锤进行至多2段攻击，每段分别造成50%,100%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="480" width="448" alpha="0.9" text="瓦伦斯坦侧身跳起，拿大锤猛地砸下，造成75%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="736" width="448" alpha="0.9" text="瓦伦斯坦发怒，进入士气强化状态，该状态可使用「避邪爆竹」破除并使其瘫痪。"/>
