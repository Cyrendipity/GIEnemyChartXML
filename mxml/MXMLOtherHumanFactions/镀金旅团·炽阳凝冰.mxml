	<mx:Text styleName="textStyle5" x="736" y="224" width="448" alpha="0.9" text="炽阳凝冰进行右刃劈、左刃劈、十字斩3段攻击，依次造成40%,40%,50%伤害。魔化：攻击伤害提升，依次造成50%,50%,60%伤害。"/>
	<mx:Text styleName="textStyle5" x="736" y="512" width="448" alpha="0.9" text="当炽阳凝冰的生命值低于70%时，炽阳凝冰将武器的厄灵解放出来，进入魔化状态，该状态持续20s，状态结束后将虚弱8s。"/>
	<mx:Text styleName="textStyle5" x="1408" y="224" width="448" alpha="0.9" text="炽阳凝冰拼合两把刀的刀柄，形成双刃剑，进行旋转扫击，造成50%伤害。魔化：攻击伤害提升，造成75%伤害。"/>
	<mx:Text styleName="textStyle6" x="1408" y="512" width="448" alpha="0.9" text="(魔化)炽阳凝冰拼合武器成双刃剑，水平丢出，造成35%伤害，剑刃的方向为从左至右。该技能经常会后接「纵斩冰锋」。"/>
	<mx:Text styleName="textStyle6" x="736" y="800" width="448" alpha="0.9" text="(魔化)炽阳凝冰拼合武器成双刃剑，竖直丢出，造成2段25%伤害，该技能经常施放2次。"/>
	<mx:Text styleName="textStyle7" x="736" y="160" width="448" text="錾冰双刃-输出"/>
	<mx:Text styleName="textStyle7" x="736" y="448" width="448" text="厄灵解放·冰噬-强化"/>
	<mx:Text styleName="textStyle7" x="1408" y="160" width="448" text="镶霜逆刃-输出"/>
	<mx:Text styleName="textStyle7" x="1408" y="448" width="448" text="横斫冰锋-远程"/>
	<mx:Text styleName="textStyle7" x="736" y="736" width="448" text="纵斩冰锋-远程"/>
