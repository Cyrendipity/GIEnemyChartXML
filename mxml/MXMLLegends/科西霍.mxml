	<mx:Text styleName="textStyle6" x="64" y="544" width="305" alpha="0.75" text="地方传奇 Lv.103 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="736" width="305" alpha="0.75" text="历经百战 Lv.100 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="624" width="375" text="ATK: 28719 (11.0B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="816" width="417" text="ATK: 24622 (10.0B2) 10/11"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="375" text="Wt/Ed: 20000/4000"/>
