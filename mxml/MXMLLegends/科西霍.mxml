	<mx:Text styleName="textStyle7" x="64" y="446" width="395" alpha="0.75" text="Cosijo"/>
	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="科西霍放出一枚雷球，缓慢追踪玩家，接触爆炸造成100%伤害"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="科西霍需处于狂暴状态。若玩家在距其13m范围内对其造成伤害，则科西霍会立即反击，造成25%,6.75%伤害，多少次伤害就反击多少次。"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" alpha="0.9" text="科西霍导引震雷，于地面持续召唤落雷，造成50%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" alpha="0.9" text="科西霍开转，不断朝玩家方向行进，接触造成70%,35%,7%伤害；进入狂暴状态下，旋转还会额外飞出顺时针方向排布的弹幕炼狱，接触造成50%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="1152" width="448" alpha="0.9" text="科西霍在原地起跳重重下落，造成50%伤害，连续跳跃至多3次；狂暴状态下，伤害提升至70%。"/>
	<mx:Text styleName="textStyle9" x="736" y="192" width="448" text="循风荧雷-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="魁霆之涛-反击"/>
	<mx:Text styleName="textStyle9" x="736" y="864" width="448" text="织云紫霄-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="640" width="448" text="巨鼋璨青-位移"/>
	<mx:Text styleName="textStyle9" x="736" y="1088" width="448" text="雳海千钧-输出"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Image source="Image4.png" x="64" y="973" width="484" height="124"/>
	<mx:Text styleName="textStyle11" x="64" y="1104" width="448" alpha="0.75" text="雷壳护盾：16雷盾，不可伤害转化，击破即可瘫痪科西霍10s，并使其退出狂暴状态。狂暴状态：科西霍受到伤害时会累计怒气条，每受击1次增加3%充能(燃烧伤害除外)，条满后进入狂暴状态，并附着雷壳护盾。"/>
