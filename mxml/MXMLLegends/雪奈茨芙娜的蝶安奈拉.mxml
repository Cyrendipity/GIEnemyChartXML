	<mx:Image source="Image3.png" x="64" y="941" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="风役人施放一连串的风弹，进行至多3段的连续攻击，对敌人分别造成50%x3,50%x3,60%x5伤害，第三段攻击带有追踪性；攻击造成的伤害带有(1,0.5,0.25,0.1)的衰减。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="风役人展开风嶂，当敌人对其施放攻击时，无视此次伤害并发动反击：闪现至敌人上方投下权杖，造成70%伤害，并在此处再次产生一次较弱的风泽域，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="768" width="1120" alpha="0.9" text="风役人瞄准目标，消耗2%生命值，2s后发动攻击，对目标敌人降下翠叶之诀，造成90%伤害并施加生命之契，随后发动追加「猎杀」攻击：翠叶之诀的场地将产生爆炸，造成100%伤害并施加生命之契。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="普通攻击·风盈-追踪"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="元素战技·岗嶂-反击"/>
	<mx:Text styleName="textStyle10" x="736" y="704" width="448" text="元素爆发·玦风翠流-爆发"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="重击·陬花繁盛-输出"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="风役人旋转权杖，进行一段重击，在敌人的下方连续产生3次的风泽域，均造成100%伤害。"/>
	<mx:Text styleName="textStyle11" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Image source="Image4.png" x="68" y="64" width="252" height="256"/>
	<mx:Text styleName="textStyle8" x="1408" y="480" width="448" alpha="0.9" text="风役人的元素爆发命中所累加的生命之契大小等同于自身16%的攻击力，且在该生命之契的影响下，目标敌人将每秒流失(0.4%HP+72)的生命值(后台停5%)，其与生命之契同生共死，持续10min。"/>
	<mx:Text styleName="textStyle9" x="1408" y="416" width="448" text="固有天赋·入扉-妨害"/>
