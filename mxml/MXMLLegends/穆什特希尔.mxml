	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="先驱阵列将滚动而来，接触造成80%伤害。(仅大世界)开局从场地后方门处滚动而来。"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="迹循先望-位移"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="距离较近时，先驱阵列原地起跳下落，造成70%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="512" width="448" alpha="0.9" text="距离较远时，先驱阵列向空中抛出8枚水弹，向目标随机洒落，造成55%,27.5%,11%,5.5%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="1088" width="448" alpha="0.9" text="一段时间后或生命值低于50%时，先驱阵列移至场地中央展开「镇压力场」，并向后方放置「探侦机关」，同时在周围形成单向屏障。机关间歇性朝玩家发射激光，造成35%伤害。先驱阵列将持续发射水弹，造成70%或80%伤害，每发射一次就移动一小段。"/>
	<mx:Text styleName="textStyle8" x="736" y="800" width="448" alpha="0.9" text="先驱阵列使用古月力启动「聚流力场」，并向空中依次丢出3枚大水泡，造成100%伤害。施放期间持续附着水元素。"/>
	<mx:Text styleName="textStyle8" x="1408" y="512" width="448" alpha="0.9" text="距离较远时，先驱阵列转出炮口，发射一枚普通水弹，造成70%伤害，随后再发射至多2枚强劲水弹，均造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="1088" width="448" alpha="0.9" text="「镇压力场」持续20s。超时后，先驱阵列将尝试回收剩余的「探侦机关」，同时为自身施加聚水护罩，并产生大浪，造成120%伤害。回收的机关越多，护罩就越厚。护罩击破后无效果，其将在下次展开力场后移除。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="残躯跃铁-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="448" width="448" text="辽海微芒-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="1024" width="448" text="拓察辰星-召唤"/>
	<mx:Text styleName="textStyle9" x="736" y="736" width="448" text="亘索流聚-爆发"/>
	<mx:Text styleName="textStyle9" x="1408" y="448" width="448" text="明露逐星-远程"/>
	<mx:Text styleName="textStyle9" x="1408" y="1024" width="448" text="驰航戍海-防御"/>
	<mx:Image source="Image5.png" x="64" y="1097" width="484" height="60"/>
	<mx:Text styleName="textStyle11" x="0" y="1055" width="64" text="正常"/>
	<mx:Text styleName="textStyle11" x="0" y="1115" width="64" text="力场"/>
	<mx:Image source="Image6.png" x="64" y="1157" width="484" height="60"/>
	<mx:Text styleName="textStyle11" x="0" y="1175" width="64" text="瘫痪"/>
	<mx:Text styleName="textStyle12" x="64" y="1224" width="448" alpha="0.75" text="聚流/镇压力场：半径50m范围内重力减弱，跳起时减速45%；同时先驱阵列自身+200%全抗。探侦机关：6水盾，离地约3m；冻结后触发超导/碎冰/融化等反应可直接破坏，全部击破后瘫痪先驱阵列13s。聚水护罩：36水盾，基础12水，每回收一个机关+6水。"/>
	<mx:Image source="Image7.png" x="596" y="469" width="128" height="128"/>
	<mx:Text styleName="textStyle8" x="1408" y="800" width="448" alpha="0.9" text="当先驱阵列或「探侦机关」陷入冻结状态时，当冻结状态被超导/碎冰/融化/结晶/扩散等反应解除时，若为先驱阵列自身则将立即中断「聚流力场」，若为「探侦机关」则将直接被破坏。"/>
	<mx:Text styleName="textStyle9" x="1408" y="736" width="448" text="栗于未知-天赋"/>
