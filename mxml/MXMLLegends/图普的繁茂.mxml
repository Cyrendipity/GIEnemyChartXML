	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="「繁茂」飞快使用自身翼片旋转，造成20%x3伤害，并在攻击范围边缘产生8道落雷，均造成30%伤害，之后场地内缘落下相同的6道落雷，在其位置形成6枚「夜祝晶球」，一段时间后将其吸收。"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="「繁茂」甩下8道线性落雷，向8个方向劈，造成30%,15%,7.5%伤害，最多重复3次。"/>
	<mx:Text styleName="textStyle11" x="736" y="512" width="448" alpha="0.9" text="「繁茂」在身边唤出5枚闪雷球，并慢慢旋转，触碰持续造成10%,5%,2.5%,1%伤害，最终闪雷球被引爆，造成70%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="512" width="448" alpha="0.9" text="「繁茂」闪至场地中央，开始蓄力，期间触碰周身将持续造成30%伤害，从玩家后方外围开始顺时针生成「夜祝晶球」并快速飞向「繁茂」，26s后爆发，秒杀未被「巡礼护盾」庇护的在场角色，持续5s。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="落翼华珠-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="谴谶荒雷-远程"/>
	<mx:Text styleName="textStyle12" x="736" y="448" width="448" text="净罪囚霆-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="448" width="448" text="碎灵愆钧-爆发"/>
