	<mx:Image source="Image5.png" x="576" y="406" width="168" height="170"/>
	<mx:Text styleName="textStyle10" x="736" y="256" width="448" alpha="0.9" text="「佑助」释放4道葬峡晶浪，造成50%伤害(闪避帧无效)，之后再在前方放出繁生玉簇，造成70%伤害，均不可弹反。"/>
	<mx:Text styleName="textStyle10" x="736" y="928" width="448" alpha="0.9" text="「佑助」朝玩家方向蓄力，持续发射11枚岩粒弹，造成40%,8%伤害，可被弹回造成伤害。"/>
