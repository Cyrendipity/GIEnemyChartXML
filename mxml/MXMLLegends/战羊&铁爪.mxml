	<mx:Text styleName="textStyle" x="64" y="512" width="410" text="战羊&amp;铁爪"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="912" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="64" y="704" width="305" text="HP: 5313541 (87.2F)"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="305" alpha="0.75" text="地方传奇-单只 Lv.103 Data"/>
	<mx:Text styleName="textStyle4" x="64" y="752" width="441" text="ATK1: 33940 (13.0B2) (战羊)"/>
	<mx:Text styleName="textStyle4" x="64" y="800" width="418" text="ATK2: 26108 (10.0B2) (铁爪)"/>
	<mx:Text styleName="textStyle4" x="64" y="848" width="375" text="Wt/Ed: 150/4000"/>
	<mx:Text styleName="textStyle6" x="64" y="593" width="395" alpha="0.75" text="Battlegoat &amp; Ironclaw"/>
	<mx:Image source="Image13.png" x="64" y="957" width="484" height="124"/>
	<mx:Text styleName="textStyle7" x="736" y="224" width="448" alpha="0.9" text="战羊进行拱、角觗2段攻击，依次造成45%,75%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="战羊开始蓄力，出现冲刺轨迹，4s后冲刺，对玩家造成100%伤害，对铁爪造成暴击伤害为30%的必定暴击伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" alpha="0.9" text="战羊抬起前身，然后迅速扑下，造成100%伤害，若命中铁爪，则造成其当前12.5%生命值的暴击伤害，并令其立即旋转。愤怒状态下，将连续施放3次。"/>
	<mx:Text styleName="textStyle8" x="736" y="1184" width="448" alpha="0.9" text="当铁爪被战羊的蛮骑突击命中2次后，抱头展开头鸟坚壁，全抗大幅提升，持续30s。若继续被战羊的蛮骑突击命中，双方将损失20%生命值，并且眩晕8s。"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="战羊抬起前身，然后扑下顺势用角向前顶，造成65%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="战羊跑远开始蓄力，准备蛮骑突击，4s后冲刺，对玩家造成300%伤害，对铁爪造成暴击伤害为30%的必定暴击伤害，重复5次。命中铁爪的头鸟坚壁时双方将损失20%生命值，并且眩晕8s。"/>
	<mx:Text styleName="textStyle8" x="1408" y="704" width="448" alpha="0.9" text="铁爪从地面衔起一枚谷粒，抛向玩家，造成100%,20%伤害。愤怒状态下，将连续施放3次，每次将抛出3枚谷粒。"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" alpha="0.9" text="铁爪被战羊的冲刺命中后会撞飞，然后落地膨胀缓冲，随后立即旋转一圈，恢复体型并造成50%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="928" width="448" alpha="0.9" text="铁爪被战羊的「跃羊怒遏」命中后会立即开始不断旋转，朝玩家方向行径，触碰持续造成80%,40%伤害。若命中战羊，则造成其当前12.5%生命值的暴击伤害并中断技能。"/>
	<mx:Text styleName="textStyle8" x="1408" y="1184" width="448" alpha="0.9" text="入战后，铁爪和战羊的攻击都会对对方造成伤害；若阵亡一方，则另一方会陷入愤怒，攻击力提升200%，且部分技能获得强化。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="喧羊角逐-输出-战羊"/>
	<mx:Text styleName="textStyle9" x="736" y="384" width="448" text="蛮羊突围-位移-战羊"/>
	<mx:Text styleName="textStyle9" x="736" y="640" width="448" text="跃羊怒遏-妨害-战羊"/>
	<mx:Text styleName="textStyle9" x="736" y="1120" width="448" text="磐生铁壁-防御-铁爪"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="顽羊驱斥-输出-战羊"/>
	<mx:Text styleName="textStyle9" x="1408" y="384" width="448" text="蛮骑陷阵-爆发-战羊"/>
	<mx:Text styleName="textStyle9" x="1408" y="640" width="448" text="沃土衔粟-远程-铁爪"/>
