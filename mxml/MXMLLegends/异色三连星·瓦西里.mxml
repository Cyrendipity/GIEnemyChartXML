	<mx:Text styleName="textStyle7" x="736" y="256" width="448" alpha="0.9" text="火枪架起火狙，立即打一枪，造成66.6%伤害。强化技：连打三枪，造成100%,50%,25%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="480" width="448" alpha="0.9" text="进入战斗后，或从瘫痪恢复，火枪会尝试进入元素增幅状态：全抗提升100%，附属水御特化盾，有效元素是水。"/>
	<mx:Text styleName="textStyle7" x="736" y="928" width="448" alpha="0.9" text="火枪倒下后，会为存活的异色三连星队友提供永久增益：攻击力提升200%。"/>
	<mx:Text styleName="textStyle7" x="736" y="704" width="448" alpha="0.9" text="靠近刚开枪的火枪，火枪直接后撤远离玩家，在增幅状态下后撤后会立即再次开枪。"/>
	<mx:Text styleName="textStyle8" x="736" y="192" width="448" text="间续火候-远程"/>
	<mx:Text styleName="textStyle8" x="736" y="416" width="448" text="烧烤时间-强化"/>
	<mx:Text styleName="textStyle8" x="736" y="864" width="448" text="炎夏盛怒-强化"/>
	<mx:Text styleName="textStyle8" x="736" y="640" width="448" text="战术撤离-位移"/>
	<mx:Text styleName="textStyle9" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="64" y="1196" width="448" alpha="0.75" text="火御：8火盾，火水为2:1，其他所有反应均是1:10；击破可暂时瘫痪。该状态下，抗打断为0，重量翻6倍。"/>
