	<mx:Text styleName="textStyle" x="64" y="384" width="463" text="陨落的晨星之灵"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="736" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1247" y="64" width="609" alpha="0.5" text="元素能量：CP[75,50,25,0],CO[0]"/>
	<mx:Text styleName="textStyle5" x="64" y="576" width="305" text="HP: 5508534 (90.4F)"/>
	<mx:Text styleName="textStyle6" x="64" y="544" width="305" alpha="0.75" text="夜魂试炼 Lv.103 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="624" width="375" text="ATK: 18275 (7.0B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="375" text="Wt/Ed: 110/120"/>
	<mx:Text styleName="textStyle7" x="64" y="446" width="395" alpha="0.75" text="“Spirit of the Fallen Dawnstar”"/>
	<mx:Image source="Image8.png" x="64" y="781" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="64" y="912" width="448" alpha="0.75" text="落星加护：10冻盾，击破后打断并扣除15%生命值。祭祀火盆：被冻结时附加20冻盾，击破后可重新获得增益。"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="高瞻远睹-灵动"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="晨星之灵振翼，立即悬浮至空中，施放一次后，缓缓落地。"/>
	<mx:Text styleName="textStyle11" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="晨星之灵在地上生成4处烙印，均造成100%,10%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="晨星之灵发射2枚共寒音爆，均造成75%,7.5%伤害，可在空中施放。"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="1024" alpha="0.9" text="低于70%生命值时，晨星之灵升空，为自己施加「落星加护」，冻结所有「祭祀火盆」并在场地内生成6个随机游走的冰龙卷，接触将持续造成20%伤害；8s后，龙卷风消失，晨星之灵转为施放「曜石风暴」：强力的冰风暴席卷全场，持续造成40%伤害，10s后爆发，造成300%伤害。「曜石风暴」的伤害均无法使用闪避帧躲避。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="尘芒冰阵-定点"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="孤音荡魄-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="672" width="448" text="暝曜飞雪-爆发"/>
