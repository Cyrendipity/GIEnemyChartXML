	<mx:Text styleName="textStyle7" x="736" y="480" width="448" alpha="0.9" text="伊洛特尔使劲将飞锯敲入地面，产生振波造成100%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="928" width="448" alpha="0.9" text="伊洛特尔怒而起舞，挥舞飞锯进行连续不断的5段攻击，其依次造成33%,33%,33%,50%,70%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="704" width="448" alpha="0.9" text="伊洛特尔驱使灵力，唤出一枚岩晶，后伊洛特尔使用飞锯粉碎岩晶，产生的碎片造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="416" width="448" text="惊石振崖-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="864" width="448" text="唤声循峦-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="640" width="448" text="凿岩錾金-爆发"/>
	<mx:Text styleName="textStyle9" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="64" y="384" width="460" text="特拉扎库伊洛特尔"/>
	<mx:Image source="Image5.png" x="64" y="64" width="256" height="256"/>
	<mx:Text styleName="textStyle7" x="736" y="256" width="448" alpha="0.9" text="伊洛特尔使用飞锯进行纵、横、切至多3段的攻击，分别造成60%,60%,70%伤害，第三段留在地上的锯子额外造成10%x3伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="192" width="448" text="开山好手-输出"/>
