	<mx:Text styleName="textStyle" x="64" y="384" width="502" text="望乡的孤狼"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="928" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="64" y="576" width="305" text="HP: 5057614 (83.0F)"/>
	<mx:Text styleName="textStyle4" x="64" y="764" width="424" text="HP: 1196827 (21.58F) 26%"/>
	<mx:Text styleName="textStyle5" x="64" y="544" width="305" alpha="0.75" text="地方传奇 Lv.103 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="736" width="305" alpha="0.75" text="历经百战 Lv.100 Data"/>
	<mx:Text styleName="textStyle4" x="64" y="624" width="375" text="ATK: 20886 (8.0B2)"/>
	<mx:Text styleName="textStyle4" x="64" y="816" width="375" text="ATK: 11819 (4.8B2) 60%"/>
	<mx:Text styleName="textStyle4" x="64" y="672" width="375" text="Wt/Ed: 300/400"/>
	<mx:Text styleName="textStyle4" x="64" y="864" width="375" text="Wt/Ed: 300/400"/>
	<mx:Text styleName="textStyle6" x="64" y="465" width="395" alpha="0.75" text="“The Homesick Lone Wolf”"/>
	<mx:Text styleName="textStyle7" x="736" y="224" width="448" alpha="0.9" text="孤狼对玩家进行至多抓，咬，咬3段攻击，依次造成50%,40%,70%伤害，可单独施放。"/>
	<mx:Text styleName="textStyle7" x="1408" y="512" width="448" alpha="0.9" text="孤狼朝玩家凶猛袭来，并用力切割两次，每次造成70%伤害，可连续施放2次。无蕴光效果。"/>
	<mx:Text styleName="textStyle7" x="1408" y="224" width="448" alpha="0.9" text="孤狼迅速高跳至玩家处，并踉跄一下，造成100%伤害。召唤狼魂之前返回场地中央时立即施放。"/>
	<mx:Text styleName="textStyle7" x="736" y="800" width="448" alpha="0.9" text="孤狼用利爪用力劈开一刀风刃，造成90%伤害。无蕴光效果。"/>
	<mx:Text styleName="textStyle7" x="1408" y="800" width="448" alpha="0.9" text="一段时间后，或低于70%生命值时，孤狼移至场地中央，召唤先祖狼魂，狼魂会效仿孤狼的攻击造成冰元素伤害，期间孤狼的抗性大幅提升。狼魂不能够被直接命中，仅能通过在孤狼身上扩散雷火元素命中。"/>
	<mx:Text styleName="textStyle7" x="736" y="512" width="448" alpha="0.9" text="孤狼朝前方猛地喷吐狂风，造成造成80%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="1088" width="448" alpha="0.9" text="孤狼与狼魂一起朝地面喷吐暴风与狂霜，在地面上随机生成风刺与冰刺，造成基于各自30%攻击力的伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="160" width="448" text="青牙嚼啮-输出"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" text="摧驰号灭-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" text="愁狼风冽-远程"/>
	<mx:Text styleName="textStyle8" x="736" y="1024" width="448" text="萦寒枯葬-协同"/>
	<mx:Text styleName="textStyle8" x="1408" y="160" width="448" text="山松飞猎-位移"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="448" text="啸风坼裂-远程"/>
	<mx:Text styleName="textStyle9" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="1387" y="64" width="469" alpha="0.5" text="元素能量：AP[75,50,25,0],AO[0];NA(狼魂)"/>
