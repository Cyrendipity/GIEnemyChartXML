	<mx:Text styleName="textStyle6" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle7" x="64" y="912" width="448" alpha="0.75" text="元素螺栓：储存元素力。以上一次清空螺栓开始所受到的总和最高的伤害属性为准，不吸收挂着的元素，吸收完毕后该元素抗性+120%。"/>
	<mx:Image source="Image7.png" x="596" y="171" width="128" height="128"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="靠近地巡时，地巡原地旋转一圈，使用尾部齿轮造成60%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="近尾齿砌-输出"/>
	<mx:Image source="Image8.png" x="576" y="150" width="168" height="170"/>
	<mx:Image source="Image9.png" x="1268" y="171" width="128" height="128"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="靠近地巡时，地巡使用头部进行挑击，向左向右各一次，每次造成60%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="靠近地巡时，地巡使用足部左右各跺一次，每次造成50%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="672" width="448" alpha="0.9" text="远离地巡时，地巡利落的起跳落地，造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="驱地动掘-输出"/>
	<mx:Text styleName="textStyle9" x="1408" y="384" width="448" text="嵌石之踵-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="608" width="448" text="垂巡天坠-位移"/>
	<mx:Image source="Image10.png" x="1248" y="150" width="168" height="170"/>
