	<mx:Text styleName="textStyle7" x="736" y="256" width="448" alpha="0.9" text="雷锤举起大锤，进行3段的普通攻击，三段普攻分别造成46.6%,46.6%,66.6%伤害。强化技：三段普攻分别造成66.6%,66.6%,100%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="512" width="448" alpha="0.9" text="距离雷锤较远时，雷锤抡锤冲来并锤击；冲刺造成33.3%伤害，锤击造成66.6%伤害。强化技：冲刺造成50%伤害，锤击造成100%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="768" width="448" alpha="0.9" text="进入战斗后，或从瘫痪恢复，雷锤会尝试进入元素增幅状态：全抗提升100%，附属雷御特化盾，有效元素是冰。"/>
	<mx:Text styleName="textStyle7" x="736" y="992" width="448" alpha="0.9" text="雷锤倒下后，产生一次大爆炸，造成300%伤害，并恢复其他队友的元素护盾。"/>
	<mx:Text styleName="textStyle8" x="736" y="192" width="448" text="震光雷锤-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" text="曳光雷袭-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" text="马上了结-强化"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" text="电离毁尽-亡语"/>
	<mx:Text styleName="textStyle9" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="64" y="1196" width="448" alpha="0.75" text="雷御：8雷盾，雷冰为1:1，其他所有反应均是1:10；免疫感电；击破可暂时瘫痪。该状态下，抗打断为0，重量翻6倍。"/>
