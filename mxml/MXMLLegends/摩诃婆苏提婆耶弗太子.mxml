	<mx:Text styleName="textStyle" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle2" x="1387" y="64" width="469" alpha="0.5" text="元素能量：GP[75,50,25,0],GO[0]"/>
	<mx:Text styleName="textStyle3" x="736" y="224" width="448" alpha="0.9" text="太子立即快速冲来，接触后立即翻起，造成60%伤害。"/>
	<mx:Text styleName="textStyle3" x="736" y="480" width="448" alpha="0.9" text="太子帽盖一亮，迅速旋转一圈，造成60%伤害，可连续施放多次。"/>
	<mx:Text styleName="textStyle3" x="736" y="736" width="448" alpha="0.9" text="枯焦状态的大招。太子变大，随后翻身一跃，下落同时借力弹起，该过程重复6次，第1-5次造成60%伤害，第6次造成100%伤害，技能结束后不清空计量条。"/>
	<mx:Text styleName="textStyle3" x="1408" y="224" width="448" alpha="0.9" text="太子发射2枚辛蕈果，造成60%,42%伤害，可连续施放多次。"/>
	<mx:Text styleName="textStyle3" x="1408" y="480" width="448" alpha="0.9" text="太子用帽盖朝前方迅速顶击一次，造成25%伤害。"/>
	<mx:Text styleName="textStyle3" x="1408" y="736" width="448" alpha="0.9" text="激化失控的大招，太子变大不移动，在中央胡乱抛洒香弥果，落地造成80%伤害，技能结束后退至枯焦状态，并将计量条重置为一半。"/>
	<mx:Text styleName="textStyle4" x="736" y="160" width="448" text="西域蕈客-位移  枯焦"/>
	<mx:Text styleName="textStyle4" x="736" y="416" width="448" text="鲜腴之滋-输出  枯焦"/>
	<mx:Text styleName="textStyle4" x="736" y="672" width="448" text="印香深刻-爆发  枯焦"/>
	<mx:Text styleName="textStyle4" x="1408" y="160" width="448" text="有香自来-远程  枯焦"/>
	<mx:Text styleName="textStyle4" x="1408" y="416" width="448" text="守方正味-输出  正常"/>
	<mx:Text styleName="textStyle4" x="1408" y="672" width="448" text="沁香妙赐-爆发  活化"/>
