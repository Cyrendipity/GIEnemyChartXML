	<mx:Text styleName="textStyle" x="64" y="384" width="410" text="罗基·艾威尔森"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="736" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="64" y="576" width="305" text="HP: 3899847 (64.0F)"/>
	<mx:Text styleName="textStyle5" x="64" y="544" width="305" alpha="0.75" text="地方传奇 Lv.103 Data"/>
	<mx:Text styleName="textStyle4" x="64" y="624" width="375" text="ATK: 28719 (11.0B2)"/>
	<mx:Text styleName="textStyle4" x="64" y="672" width="375" text="Wt/Ed: 125/210"/>
	<mx:Text styleName="textStyle6" x="64" y="436" width="395" alpha="0.75" text="Rocky Avildsen"/>
	<mx:Image source="Image3.png" x="64" y="781" width="484" height="124"/>
	<mx:Text styleName="textStyle7" x="736" y="224" width="448" alpha="0.9" text="罗基进行蓄力，用力向前下方挥出一拳，造成85%伤害。概率接着施放「左侧平拳」；80%HP以下时，则概率接着施放「左侧二连」。"/>
	<mx:Text styleName="textStyle8" x="64" y="912" width="448" alpha="0.75" text="常驻抗打断0.75。"/>
	<mx:Text styleName="textStyle7" x="736" y="448" width="448" alpha="0.9" text="罗基侧身蓄力，朝对手快速使出2拳，依次造成50%,85%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="672" width="448" alpha="0.9" text="罗基倏的跳起，在对手上方重重落地，击飞对手并造成100%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="896" width="448" alpha="0.9" text="罗基的生命值低于80%时，将能够施放「彻天裂石」与「石碎尘砂」技能；罗基的生命值低于40%时，攻击力将永久提升40%。"/>
	<mx:Text styleName="textStyle7" x="1408" y="224" width="448" alpha="0.9" text="罗基侧身蓄力，朝对手快速使出一拳，造成66%伤害。"/>
	<mx:Text styleName="textStyle7" x="1408" y="448" width="448" alpha="0.9" text="若罗基被击飞落地，则直接闪现，或许突然挥来一平勾拳，造成85%伤害，或许从天而坠，造成100%伤害。"/>
	<mx:Text styleName="textStyle7" x="1408" y="672" width="448" alpha="0.9" text="罗基原地朝地拳击1-3次，产生以对手为方目标的1/2/4道地波，地波造成60%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="右平勾拳-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="384" width="448" text="左侧二连-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="608" width="448" text="彻天裂石-爆发"/>
	<mx:Text styleName="textStyle9" x="736" y="832" width="448" text="硬气犟劲-天赋"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="左侧平拳-输出"/>
	<mx:Text styleName="textStyle9" x="1408" y="384" width="448" text="伏下辄出-闪避"/>
	<mx:Text styleName="textStyle9" x="1408" y="608" width="448" text="石碎尘砂-远程"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
