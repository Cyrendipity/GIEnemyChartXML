	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="铁须使用锤后端砸向地面，造成50%伤害，之后锤头爆炸，造成80%伤害，铁须顺势后撤。"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" alpha="0.9" text="铁须的第三段普攻砸击地面时，将会召唤「熔裂突刺」；使用下落攻击破坏它将会引爆，对铁须造成10%生命值的真伤(无火附着)。"/>
	<mx:Text styleName="textStyle9" x="0" y="863" width="64" text="正常"/>
	<mx:Text styleName="textStyle6" x="0" y="909" width="64" text="突刺存在时"/>
	<mx:Text styleName="textStyle10" x="64" y="972" width="448" alpha="0.75" text="熔裂突刺：12岩盾，击破将引爆并对铁须造成伤害，下落攻击例外，可一次破除并引爆，若使用非下落攻击击破，则只会破坏无其他效果。常驻抗打断0.75"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" alpha="0.9" text="铁须导引灵力，飞起炬锤并砸向地面，造成100%伤害；若场上存在「熔裂突刺」，则铁须将砸向「突刺」并引爆它，造成200%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="416" width="448" text="无屈匠火-位移"/>
	<mx:Text styleName="textStyle11" x="736" y="640" width="448" text="熔铸三叠-召唤"/>
	<mx:Text styleName="textStyle11" x="736" y="864" width="448" text="终锻绝铭-爆发"/>
