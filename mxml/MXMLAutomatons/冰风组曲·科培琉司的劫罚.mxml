	<mx:Text styleName="textStyle" x="64" y="416" width="490" text="冰风组曲·科培琉司的劫罚"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="608" width="305" text="冰风组曲·阳面"/>
	<mx:Text styleName="textStyle" x="64" y="896" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1345" y="64" width="511" alpha="0.5" text="元素能量：WP[0x3],WO[75,50,25,0]"/>
