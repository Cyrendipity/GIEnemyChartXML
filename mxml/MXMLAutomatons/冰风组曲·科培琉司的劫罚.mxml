	<mx:Text styleName="textStyle7" x="0" y="1023" width="64" text="登场"/>
	<mx:Text styleName="textStyle7" x="0" y="1083" width="64" text="正常"/>
	<mx:Text styleName="textStyle8" x="64" y="529" width="395" alpha="0.75" text="Icewind Suite: Nemesis of Coppelius"/>
