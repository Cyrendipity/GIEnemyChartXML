	<mx:Image source="Image4.png" x="64" y="941" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="歌裴莉娅和科培琉司依次进行一次划击，均造成对应元素的60%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="科培琉司牵着歌裴莉娅一同旋转2周，造成5段30%伤害，随后停下。"/>
	<mx:Text styleName="textStyle10" x="1408" y="896" width="448" alpha="0.9" text="送走歌裴莉娅后，科培琉司立即展开寒芒冰嶂，该护盾为歌裴莉娅和科培琉司共用，同时开始暴露芒性核心直至组曲结束；随后便等待歌裴莉娅回归。再次施放时刷新护盾量。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="1024" alpha="0.9" text="科培琉司与歌裴莉娅开始进行表演，主角为科培琉司，场地内形成静止的3个霜之心，其不断产生冰爆造成60%伤害，其可被歌裴莉娅的风刃触发扩散，额外造成100%伤害。该技能分三个阶段：送别，独奏，回归，持续3个循环、8/3个回合。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="冰风旋舞-协同"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="流风旋动-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="832" width="448" text="藏芒冰嶂-防卫"/>
	<mx:Text styleName="textStyle11" x="736" y="608" width="557" text="科培琉司的霜之戒惩-组曲"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="如落天仙-妨害"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="蚀尘风弹-远程"/>
	<mx:Text styleName="textStyle11" x="736" y="1088" width="448" text="风袭流卷-独奏"/>
	<mx:Text styleName="textStyle11" x="1408" y="1088" width="448" text="风归雪落-回归"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="科培琉司将歌裴莉娅抛上天，之后下落，造成60%伤害，落地的歌裴莉娅顺势旋转，持续造成15%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="歌裴莉娅使用扇子挥出3个凝风尘弹，，每个造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1152" width="448" alpha="0.9" text="歌裴莉娅在场地外挥出3刀风刃，均造成100%伤害，随后旋转准备回归，风刃会将经过的霜之心再次触发冰爆。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1152" width="448" alpha="0.9" text="歌裴莉娅在不断旋转回归，接触持续造成25%伤害，之后与科培琉司顺利会合。会合时科培琉司会再次进行3段攻击，均造成100%伤害。"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="科培琉司将歌裴莉娅送出，送出时将进行葬离颂舞：科培琉司进行3段划击，依次造成90%,90%,100%伤害；旋转3周后顺势送出歌裴莉娅。"/>
	<mx:Text styleName="textStyle11" x="736" y="832" width="448" text="斫冰錾界-送别"/>
