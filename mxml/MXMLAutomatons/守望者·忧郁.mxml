	<mx:Text styleName="textStyle" x="64" y="384" width="512" text="守望者·忧郁"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="1008" width="448" alpha="0.75" text="权限：机制盾，共4层，破坏后直接秒杀梅兰塔。部分技能期间，抗打断80。梅兰塔：一阶段生命值为二阶段的15%。"/>
	<mx:Text styleName="textStyle4" x="64" y="512" width="460" text="世界望楼之守望"/>
	<mx:Text styleName="textStyle5" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle6" x="1216" y="64" width="640" alpha="0.5" text="元素能量：NA"/>
	<mx:Text styleName="textStyle7" x="64" y="672" width="329" text="HP: 8012479 (140.0F)"/>
	<mx:Text styleName="textStyle8" x="64" y="640" width="305" alpha="0.75" text="剧情-梅兰塔 Lv.101 Data"/>
	<mx:Text styleName="textStyle7" x="64" y="720" width="375" text="ATK: 9984 (4.0B2)"/>
	<mx:Text styleName="textStyle7" x="64" y="768" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle9" x="64" y="465" width="395" alpha="0.75" text="Watcher: Melancholy"/>
	<mx:Text styleName="textStyle10" x="64" y="555" width="407" alpha="0.75" text="World Watch Sentry"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" alpha="0.9" text="梅兰塔持矛立即进行破击，造成41%伤害，随后翻身，驾驭着长矛继续冲击，造成47%伤害，最多可连续冲击3次。"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" alpha="0.9" text="梅兰塔抬起长矛，朝前方的地上猛击，造成60%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="896" width="448" alpha="0.9" text="距离较远时，梅兰塔扔起长矛，纵身一跃，在玩家处落下，造成60%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" alpha="0.9" text="梅兰塔将长矛朝前方丢出，长矛经过将造成60%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="梅兰塔进行2段左右划攻击，依次造成32%,34%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="896" width="448" alpha="0.9" text="梅兰塔移至场地中央，并立即召唤2枚天矛，先后造成2次100%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="神仪之断罚-远程"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="笼间之决示-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="832" width="448" text="诤妄之天谴-位移"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="蠲除之负槊-远程"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="安守之规戒-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="832" width="448" text="现象之诳乱-爆发"/>
