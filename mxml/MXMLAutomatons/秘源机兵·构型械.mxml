	<mx:Text styleName="textStyle" x="64" y="384" width="484" text="秘源机兵·构型械"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="340" text="深谷遗迹建造机关"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：WO[75,50,25,0]"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="375" text="HP: 1584313 (26.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 20886 (8.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="436" width="395" alpha="0.75" text="Secret Source Automaton: Configuration Device"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="Ancient Ruins Constructor"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="构型械驻于原地，于自身处缓慢产生2次雷暴脉冲，均造成60%伤害；与此同时2枚浮游炮发射迂回中央的测距激光，造成30%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="远离构型械时，其将发射持续的雷激光，持续造成40%,20%,12%,4%,0.4%伤害；若在发射激光时靠近构型械，则其立即停止激光发射，转而化为爪掌拍下，造成60%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="构型械驻于原地，于自身炮筒发射3枚雷轰弹，落地爆炸，每枚造成70%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="过于靠近构型械时，构型械化作巨星爪掌并拍下，造成60%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" alpha="0.9" text="过于靠近构型械时，构型械化作巨星爪掌并划扫，造成60%伤害；此后浮游炮接着发射弹雨，持续造成30%,15%,3%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="992" width="1024" alpha="0.9" text="构型械开掘出2柱固态燃素，其上有「汲聚械」存在，辅助构型械进行蓄力；蓄力期间的浮游炮不断发射激光，造成50%伤害，并留下造成10%伤害的滞留雷息；15s后，构型械丢出球状雷弹，造成大范围200%伤害。「应战对策」满后强制施放，若为此法触发，则在蓄力之前，浮游炮会利用雷激光规划开采场地，激光造成30%伤害；若构型械不发生转身，则固态燃素将出现在激光交点处。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="匝合之视-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="416" width="448" text="裁月堇光-远程"/>
	<mx:Text styleName="textStyle12" x="64" y="1068" width="448" alpha="0.75" text="固态燃素：无法直接攀爬，仅「回声之子」成员可直接攀爬，高度接近岩脊，可使用万叶/钟离/玛拉妮/嘉明/绮良良等逃课。「汲聚械」：进入屏障内以1次攻击击破，屏障外免疫，击破全部可使构型械瘫痪12s，并扣除其15%生命值。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="渊霄丙明-定点"/>
	<mx:Text styleName="textStyle11" x="1408" y="416" width="448" text="空余孛辘-输出"/>
	<mx:Text styleName="textStyle13" x="736" y="672" width="448" text="煟暝紫械-输出"/>
	<mx:Text styleName="textStyle13" x="736" y="928" width="448" text="鸣烻焚薮-爆发"/>
