	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="攻坚机关使用左右两臂进行至多2段挥舞攻击，均造成50%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="攻坚机关使用右臂的长棍进行下劈，造成30%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="攻坚机关使用长棍进行旋、挑、旋至多三段的攻击，攻击依次造成60%,70%,90%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="672" width="448" alpha="0.9" text="攻坚机关使用长棍进行穿戳攻击，造成100%伤害，冲刺结束后可能进行一次挥扫，造成90%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="672" width="448" alpha="0.9" text="攻坚机关使用盾锯进行3段的旋扫攻击，其依次造成50%,50%,70%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="896" width="448" alpha="0.9" text="攻坚机关使用盾锯进行上挑、下落至多2段的攻击，其依次造成70%,90%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="896" width="448" alpha="0.9" text="攻坚机关使用盾锯进行重重下落，造成90%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="自相矛盾-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="384" width="448" text="锤罚光棍-击退"/>
	<mx:Text styleName="textStyle9" x="1408" y="384" width="448" text="戒退热浪-输出   芒"/>
	<mx:Text styleName="textStyle9" x="736" y="608" width="448" text="炎枪冲锋-位移   芒"/>
	<mx:Text styleName="textStyle9" x="1408" y="608" width="448" text="旋雳轮盘-输出   荒"/>
