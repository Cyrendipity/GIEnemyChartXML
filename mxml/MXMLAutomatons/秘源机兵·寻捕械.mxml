	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="寻捕械推出一个排满尖牙的排斥装甲，造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="寻捕械朝天发射一束高能脉冲，其持续打击地面，持续造成70%,35%,14%,7%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="512" width="448" alpha="0.9" text="寻捕械朝玩家发射连续的集中热能激光，持续造成60%伤害，至多3次。"/>
	<mx:Text styleName="textStyle8" x="1408" y="512" width="448" alpha="0.9" text="距离较远时，寻捕械突然朝玩家发动赤牙合击，造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="800" width="448" alpha="0.9" text="「应战对策」充满后，寻捕械会发射持续5s的集束激光，持续造成100%,10%伤害，期间抗性恢复正常。"/>
