	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="统御械张嘴，在其前方生成水漩涡，牵引玩家，位于其内将持续造成30%伤害；3s后漩涡喷发，造成90%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="统御械瞄准玩家，标记并禁锢落点位置，随后发射一枚水球落在范围处，造成85%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="736" width="448" alpha="0.9" text="构型械自身拥有180点「应战对策」上限。角色进入「夜魂加持」状态时，会积攒30充能，维持时每秒积攒10充能，充满时进入「应战对策」模式：其将产生一不断追踪玩家的泉眼，并间歇喷出1-4次的水柱，持续造成45%伤害；「动量」越多，泉眼移速越快。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="吞覆圆渊-定点"/>
	<mx:Text styleName="textStyle11" x="1408" y="416" width="448" text="津海天露-远程"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" text="急湍瀑泉-定点"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="统御械捏出一把水刀，进行左划、右划、纵合至多三段的攻击，依次造成60%,60%,75%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="统御械进行俯冲，朝玩家方向袭来，接触造成80%伤害，至多重复3次。"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" alpha="0.9" text="统御械立即移至场地中央，进入「荡除」状态，期间其身旁的2个水龙头将沿顺时针方向持续喷洒水流；当「动量」累积至7.4%/22.2%/44.4%时，其水柱将持续造成20%/50%/100%伤害。喷水持续30s，与「急湍瀑泉」共享时间。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="流锋舞涟-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="416" width="448" text="晨昏迅翮-位移"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" text="潺澜逝水-爆发"/>
