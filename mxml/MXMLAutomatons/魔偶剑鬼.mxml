	<mx:Text styleName="textStyle3" x="64" y="800" width="419" text="万般机巧，剑豪人形"/>
	<mx:Text styleName="textStyle4" x="64" y="1312" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：WP[0],WO[75,50,25,0]"/>
