	<mx:Text styleName="textStyle10" x="736" y="1792" width="448" alpha="0.9" text="当玩家距离剑鬼&gt;7m时，魔偶剑鬼就会开始格挡攻击。(振刀2技能)剑鬼会格挡近战攻击。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1792" width="448" alpha="0.9" text="魔偶剑鬼会不定时的握紧左拳，作出一副「你倒是打啊」的架势。"/>
	<mx:Text styleName="textStyle12" x="736" y="1728" width="448" text="枉面格挡-被动"/>
	<mx:Text styleName="textStyle12" x="1408" y="1728" width="448" text="挑衅嘲讽-嘲讽"/>
