	<mx:Text styleName="textStyle7" x="64" y="1248" width="375" text="Wt/Ed: 99999/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="753" width="395" alpha="0.75" text="Maguu Kenki"/>
	<mx:Text styleName="textStyle9" x="64" y="835" width="395" alpha="0.75" text="Ingenious Machine: Marionette Swordmaster"/>
	<mx:Image source="Image7.png" x="64" y="1357" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="剑鬼斜上插刀鞘，随后立即朝前突进，突进和终点处均造成60%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="剑鬼平插刀鞘，产生真空场吸引玩家，随后圆形斩击，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="896" width="448" alpha="0.9" text="剑鬼平插刀鞘，产生真空场吸引玩家，随后挥刀造成100%伤害，之后在原地产生霜驰幻影，霜驰在更大范围外挥一圈造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="剑鬼斜上插刀鞘，进行快速突进，突进和终点处均造成60%伤害，随后大概率接机巧声风技能，小概率接孤风刀势技能或霜驰刀势技能。"/>
	<mx:Text styleName="textStyle10" x="736" y="1120" width="448" alpha="0.9" text="剑鬼迅速瞬移，原地留下一个孤风幻影，孤风挥出一刀风刃，同时剑鬼继续劈砍3-4道风刃，风刃均造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1344" width="448" alpha="0.9" text="剑鬼在进行纵-横-纵的普通攻击时，孤风幻影会协同攻击，剑鬼造成50%伤害，孤风造成30%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1568" width="448" alpha="0.9" text="剑鬼迅速斜砍出一刀风刃，造成50%伤害，该技能不单放。"/>
	<mx:Text styleName="textStyle11" x="1408" y="1568" width="448" alpha="0.9" text="(振刀2技能)剑鬼后撤，迅速连续劈出1-5刀风刃，每个造成50%伤害，该风刃可被反击。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="居合破斩-位移	破剑阶段"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="真空破斩-吸引	破剑阶段"/>
	<mx:Text styleName="textStyle12" x="1408" y="832" width="448" text="真霜空斩-妨害"/>
	<mx:Text styleName="textStyle12" x="736" y="832" width="448" text="居合暴斩-位移	风魔阶段"/>
	<mx:Text styleName="textStyle12" x="736" y="1056" width="448" text="机巧刃锐-闪避	风魔阶段"/>
	<mx:Text styleName="textStyle12" x="736" y="1280" width="448" text="孤风流锷-协同输出	风魔阶段"/>
	<mx:Text styleName="textStyle12" x="736" y="1504" width="448" text="机巧声风-连招	风魔阶段"/>
	<mx:Text styleName="textStyle12" x="1408" y="1504" width="448" text="疾风连暴-输出	风魔阶段"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="一文破字-输出	破剑阶段"/>
	<mx:Text styleName="textStyle12" x="1408" y="608" width="448" text="七五斩落-输出	风魔阶段"/>
	<mx:Text styleName="textStyle12" x="1408" y="1280" width="448" text="霜驰凝锋-协同输出	风魔阶段"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="剑鬼在近处挥刀，最多可以进行3段普攻，有两种不同的方式：横-斜-纵、纵-横-纵，每段造成50%伤害"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="当生命值低于75%时，剑鬼右手持破风，左手拿来一把碎霜，朝地用尽全力猛击，造成80%+80%伤害，冰伤范围比风伤大，随后进入风魔阶段。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1344" width="448" alpha="0.9" text="剑鬼在进行横-斜-纵的普通攻击时，霜驰幻影会协同攻击，剑鬼造成50%伤害，霜驰造成30%伤害。"/>
	<mx:Text styleName="textStyle13" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="剑鬼拼合枉死之面，随后朝前推行，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="剑鬼放开枉死之面，面具追踪玩家，随后闭合发生爆炸，造成100%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="枉面推行-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="枉面夹笼-追踪"/>
	<mx:Text styleName="textStyle10" x="1408" y="1120" width="448" alpha="0.9" text="受击后，剑鬼突然后撤，原地留下一个霜驰幻影，剑鬼蓄力产生真空场吸引玩家，和霜驰同时挥出一刀，剑鬼造成100%伤害，霜驰造成60%伤害。"/>
	<mx:Text styleName="textStyle12" x="1408" y="1056" width="448" text="影突刃寒-闪避	风魔阶段"/>
