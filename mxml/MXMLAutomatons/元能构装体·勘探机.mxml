	<mx:Text styleName="textStyle" x="64" y="384" width="508" text="元能构装体·勘探机"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle3" x="576" y="128" width="469" alpha="0.5" text="元素能量：WP[75,50,25,0]"/>
	<mx:Text styleName="textStyle4" x="64" y="672" width="305" text="HP: 188564 (3.4F)"/>
	<mx:Text styleName="textStyle5" x="64" y="640" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle4" x="64" y="720" width="375" text="ATK: 8864 (3.6B2)"/>
	<mx:Text styleName="textStyle4" x="64" y="768" width="375" text="Wt/Ed: 200/400"/>
	<mx:Text styleName="textStyle6" x="64" y="497" width="395" alpha="0.75" text="Primal Construct: Prospector"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle7" x="736" y="256" width="448" alpha="0.9" text="勘探机使用激光部件发射激光进行勘探，造成50%,5%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="480" width="448" alpha="0.9" text="游离的激光部件间歇性发射激光，造成50%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="704" width="448" alpha="0.9" text="勘探机游离出两个电锯部件，自己进入隐蔽状态，驱散所有元素附着，全抗性提升50%，每个部件继承10%的勘探机生命值，状态持续10-20s。在本体上进行激化反应或其使被「真识波」命中，可解除该状态并使其瘫痪。"/>
	<mx:Text styleName="textStyle7" x="736" y="992" width="448" alpha="0.9" text="隐蔽状态下，若击破任意一个激光部件，则会使勘探机进入修复部件状态。"/>
	<mx:Text styleName="textStyle8" x="736" y="192" width="448" text="考古勘探-远程"/>
	<mx:Text styleName="textStyle8" x="736" y="416" width="448" text="间续照明-协同 	部件L"/>
	<mx:Text styleName="textStyle8" x="736" y="640" width="448" text="不可之视-隐蔽"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" text="部件检修-恢复"/>
	<mx:Text styleName="textStyle9" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="64" y="1068" width="448" alpha="0.75" text="激光部件：12盾量的10%生命值盾，继承召唤者的生命值上限，其他属性相同；每秒消耗0.2直至损毁。修复中的激光部件：4草盾，1次雷元素攻击即可，其他元素只反应不消耗。击破后瘫痪构装体。"/>
	<mx:Text styleName="textStyle11" x="64" y="544" width="416" text="砂原王都的建造者"/>
	<mx:Text styleName="textStyle12" x="64" y="587" width="395" alpha="0.75" text="Architect of the Desert Palace"/>
