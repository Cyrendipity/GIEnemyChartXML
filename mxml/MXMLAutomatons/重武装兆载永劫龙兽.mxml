	<mx:Text styleName="textStyle" x="64" y="576" width="508" text="重武装兆载永劫龙兽"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="1024" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1387" y="64" width="469" alpha="0.5" text="元素能量：WP[0x2],WO[66,33]"/>
	<mx:Text styleName="textStyle5" x="64" y="864" width="305" text="HP: 914027 (15.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="832" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="912" width="375" text="ATK: 18798 (7.2B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="960" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle7" x="64" y="628" width="395" alpha="0.75" text="Heavy Assault Pack Aeonblight Drake"/>
	<mx:Image source="Image14.png" x="64" y="1069" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="兆载龙兽使用两翼各朝前施放一排的子弹，命中造成60%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="兆载龙兽瞄准玩家，暴露腹部弱点，使用两翼施放总共28个追踪弹，造成80%,24%,8%,0.8%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="672" width="448" alpha="0.9" text="靠近兆载龙兽时，兆载龙兽使用头部进行挑击，左右各一次，每次造成60%伤害，每次挑击时扔出3块石头，造成80%,40%,16%伤害，极大概率接扫尾。"/>
	<mx:Text styleName="textStyle8" x="736" y="896" width="448" alpha="0.9" text="靠近兆载龙兽时，兆载龙兽原地旋转一圈，使用尾部齿轮造成75%伤害，可能接翼坠。"/>
	<mx:Text styleName="textStyle8" x="1408" y="896" width="448" alpha="0.9" text="兆载龙兽暴露头、胸部弱点，使用核心朝地上发射大范围冲击，造成100%伤害(闪避帧无效)，空地巡状态皆可施放。"/>
	<mx:Image source="Image15.png" x="1248" y="822" width="168" height="170"/>
	<mx:Image source="Image16.png" x="1248" y="598" width="168" height="170"/>
	<mx:Text styleName="textStyle8" x="1408" y="672" width="448" alpha="0.9" text="兆载龙兽使用双翼分别朝地面砸去，均造成75%伤害，每个翼落地后还将在外圈产生冲击波，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="1120" width="448" alpha="0.9" text="兆载龙兽暴露头部弱点，汲取元素锚栓的力量，向空中抛出20枚散弹，造成对应元素的100%,30%,10%伤害，每个散弹有33%概率留下元素氛，之后转换空地巡状态，降落地面造成30%伤害。"/>
	<mx:Text styleName="textStyle9" x="1317" y="1088" width="54" alpha="0.9" text="元素氛如右对应元素的"/>
	<mx:Text styleName="textStyle8" x="736" y="1375" width="1024" alpha="0.9" text="施放「散落洪流」前，会立即吸收元素填充元素螺栓，使该次技能附上元素伤害，元素的种类以上一周期所受总和最高的伤害为准(物伤则无属性)，不吸收附着的元素。元素吸收完毕后该元素抗性+60%，提升的抗性仅能通过吸收其他属性来转移。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="重式机枪-远程	空巡"/>
	<mx:Text styleName="textStyle10" x="736" y="384" width="448" text="高效打击-锁定	空巡"/>
	<mx:Text styleName="textStyle10" x="736" y="608" width="448" text="开岩碎土-输出	地巡"/>
	<mx:Text styleName="textStyle10" x="736" y="832" width="448" text="尾链牵旋-防卫	地巡"/>
	<mx:Text styleName="textStyle10" x="1408" y="832" width="448" text="震击荡波-警戒	地巡"/>
	<mx:Text styleName="textStyle10" x="1408" y="608" width="448" text="磅沉拓石-输出	地巡"/>
	<mx:Text styleName="textStyle10" x="736" y="1056" width="448" text="散落湍流-爆发"/>
	<mx:Text styleName="textStyle10" x="736" y="1311" width="448" text="能量泄溢-天赋"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="尾行摩托-位移	空巡"/>
	<mx:Text styleName="textStyle10" x="1408" y="384" width="448" text="低空游巡-位移	地巡"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="靠近兆载龙兽时，兆载龙兽用尾部齿轮碾过，暴露头部弱点，造成60%伤害，若命中玩家则立即扫尾造成60%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="兆载龙兽朝玩家冲来，暴露头部弱点，冲刺命中造成75%伤害，若命中玩家则立即扫尾造成75%伤害。"/>
	<mx:Text styleName="textStyle11" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle12" x="64" y="1260" width="448" alpha="0.75" text="元素锚栓：吸收元素后，增加60%该元素抗性。轻巡武装：升空后提供的护盾，2次特化次数盾，击破任意弱点-1次，耗尽后落地。重胄武装：升空后提供的护盾，不定次特化次数盾，击破双翼弱点需6次，击破头、胸弱点需3次，耗尽后落地。"/>
	<mx:Text styleName="textStyle13" x="64" y="736" width="416" text="永续永动·Gl-Faf"/>
	<mx:Text styleName="textStyle14" x="64" y="779" width="395" alpha="0.75" text="Perpetual Motion GL-Faf"/>
