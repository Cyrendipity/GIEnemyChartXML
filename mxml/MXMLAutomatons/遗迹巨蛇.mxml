	<mx:Text styleName="textStyle" x="64" y="384" width="448" text="遗迹巨蛇"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1387" y="64" width="469" alpha="0.5" text="元素能量：WO[66,33,0]"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="305" text="HP: 974962 (16.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="640" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="720" width="375" text="ATK: 15665 (6.0B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="768" width="375" text="Wt/Ed: 1000/4000"/>
	<mx:Text styleName="textStyle7" x="64" y="465" width="395" alpha="0.75" text="Ruin Serpent"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="遗迹巨蛇从地里冒出，使用尖尾扎地，造成击退无伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="遗迹巨蛇周期性钻入地下，带出黑泥在周围形成4个淤泥涌口，产生纯光结晶。"/>
	<mx:Text styleName="textStyle8" x="736" y="672" width="448" alpha="0.9" text="遗迹巨蛇倾倒身体，向前方的扇形区域来回碾压，倒下造成50%伤害，碾压造成40%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="896" width="448" alpha="0.9" text="遗迹巨蛇盘踞在淤泥涌口间进行充能，暴露弱点，不断旋转然后钻入地下，产生纯光结晶，此时炸弹爆炸，产生强追踪碎片，每个碎片造成40%/30%(1个涌口)伤害，并消耗淤泥涌口。"/>
	<mx:Text styleName="textStyle8" x="1408" y="896" width="448" alpha="0.9" text="遗迹巨蛇盘踞在淤泥涌口间进行充能，暴露弱点，抬着头蓄力，产生纯光结晶，此时施放激波，造成200%/100%(1个涌口)伤害，并消耗淤泥涌口。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="针矛钻戳-突袭"/>
	<mx:Text styleName="textStyle9" x="736" y="384" width="448" text="渊泥翻涌-埋伏"/>
	<mx:Text styleName="textStyle9" x="736" y="608" width="448" text="抻身陡落-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="832" width="448" text="污秽炸弹-爆发"/>
	<mx:Text styleName="textStyle9" x="1408" y="832" width="448" text="污秽激波-爆发"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="临渊之暗-天赋"/>
	<mx:Text styleName="textStyle9" x="1408" y="384" width="448" text="掘地三尺-输出"/>
	<mx:Text styleName="textStyle9" x="1408" y="608" width="448" text="翻砂涌石-牵引"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="进场强制削减流明石能量直至剩余2点。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="遗迹巨蛇朝玩家猛冲，造成30%伤害，接着钻入地下，钻出，用尾针扎地面，造成70%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="672" width="448" alpha="0.9" text="遗迹巨蛇钻入地下，在地面上产生砂石漩涡，持续造成10%伤害并牵引玩家，漩涡散去后钻出地面，紧接着又再次钻入地面，均造成70%伤害。"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="64" y="1068" width="448" alpha="0.75" text="纯光结晶：3岩盾，击破产生3个流明石能量。"/>
