	<mx:Text styleName="textStyle" x="64" y="384" width="510" text="恒常机关阵列"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1387" y="64" width="469" alpha="0.5" text="元素能量：WO[66,33,0]"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="305" text="HP: 974962 (16.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="640" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="720" width="375" text="ATK: 18798 (7.2B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="768" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle7" x="64" y="465" width="395" alpha="0.75" text="Perpetual Mechanical Array"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="机关阵列瞄准玩家，发射激光轰击地面，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="机关阵列化成火箭升空，随后瞄准，重重坠落，造成91.6%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="672" width="448" alpha="0.9" text="机关阵列化作一个旋转的锯片，倏的切向玩家，造成58.3%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="896" width="448" alpha="0.9" text="生命值达30%时或耗时较久后，机关阵列用自己的立方分裂出去召唤遗迹机兵，自己则处于无敌状态，击败被高亮的遗迹机兵以使其虚弱20s。"/>
	<mx:Text styleName="textStyle8" x="1408" y="896" width="448" alpha="0.9" text="当机兵存在过久、虚弱时间已到后，机关阵列回收自己的4个机兵，退出无敌状态，重新变为成本体。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="机关阵列化作一把大剑，扫向玩家，造成75%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="672" width="448" alpha="0.9" text="机关阵列化作一个巨大正方体，不断滚向玩家，滚动不造成伤害，到达玩家处猛烈爆炸，造成75%伤害，若滚动时间耗尽，同样爆炸，但造成91.6%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="引阵迫击-瞄准"/>
	<mx:Text styleName="textStyle10" x="736" y="384" width="448" text="陨灭之坠-控制"/>
	<mx:Text styleName="textStyle10" x="736" y="608" width="448" text="片芒掠影-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="832" width="448" text="绝对防御-防御"/>
	<mx:Text styleName="textStyle10" x="1408" y="832" width="448" text="重获新生-恢复"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="剑燊袭时-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="608" width="448" text="坚阵立方-碾压"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="烈光日烁-瞄准"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="机关阵列展开自身，从核心处持续发射激光，持续造成33.3%伤害。跑太远或绕后都会使其停止。"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle13" x="64" y="1068" width="448" alpha="0.75" text="遗迹机兵：只有被高亮的能击败，其他锁血；遗迹机兵在机关阵列虚弱后假死，机关阵列死亡后才真正死亡并产球。"/>
