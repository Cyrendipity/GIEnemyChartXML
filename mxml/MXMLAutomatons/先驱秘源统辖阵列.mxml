	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="先驱阵列将滚动而来，接触造成80%伤害。"/>
	<mx:Text styleName="textStyle11" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="距离较近时，先驱阵列原地起跳下落，造成70%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="512" width="448" alpha="0.9" text="距离较远时，先驱阵列向空中抛出5枚水弹，向目标随机洒落，造成55%,27.5%,11%,5.5%伤害。"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="迹循先望-位移"/>
	<mx:Text styleName="textStyle12" x="736" y="448" width="448" text="辽海微芒-远程"/>
	<mx:Text styleName="textStyle12" x="736" y="736" width="448" text="亘索流聚-爆发"/>
	<mx:Text styleName="textStyle12" x="1408" y="448" width="448" text="明露逐星-远程"/>
	<mx:Text styleName="textStyle12" x="1408" y="736" width="448" text="栗于未知-天赋"/>
	<mx:Text styleName="textStyle10" x="736" y="800" width="448" alpha="0.9" text="先驱阵列使用古月力启动「聚流力场」，并向空中依次丢出2枚大水泡，造成100%伤害。施放期间持续附着水元素。"/>
	<mx:Text styleName="textStyle10" x="1408" y="512" width="448" alpha="0.9" text="距离较远时，先驱阵列转出炮口，发射一枚普通水弹，造成70%伤害，随后再发射一枚强劲水弹，造成80%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="残躯跃铁-输出"/>
