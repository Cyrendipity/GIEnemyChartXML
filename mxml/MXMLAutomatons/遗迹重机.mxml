	<mx:Text styleName="textStyle" x="64" y="576" width="448" text="遗迹重机"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="1216" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1278" y="64" width="578" alpha="0.5" text="元素能量：WP[75,50,25],WO[75,50,25,0]"/>
	<mx:Text styleName="textStyle5" x="64" y="864" width="305" text="HP: 330886 (9.0H)"/>
	<mx:Text styleName="textStyle6" x="64" y="832" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="912" width="375" text="ATK: 17235 (7.0B1)"/>
	<mx:Text styleName="textStyle5" x="64" y="960" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle5" x="64" y="1056" width="305" text="HP: 340957 (14.0H)"/>
	<mx:Text styleName="textStyle6" x="64" y="1024" width="305" alpha="0.75" text="精英-特异体 Lv.90 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="1104" width="375" text="ATK: 13322 (7.0B1)"/>
	<mx:Text styleName="textStyle5" x="64" y="1152" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle7" x="64" y="657" width="395" alpha="0.75" text="Ruin Grader"/>
	<mx:Image source="Image4.png" x="64" y="1261" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="处在较远的地方时，遗迹重机侧身朝玩家处快速移动，期间碰到造成30%伤害，冲刺开始与结束时造成40%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="遗迹重机上半身快速旋转，并朝玩家走来，扫击范围内持续造成60%伤害，双腿核心大概率暴露。"/>
	<mx:Text styleName="textStyle8" x="736" y="672" width="448" alpha="0.9" text="遗迹重机短暂暴露头部核心，发射一枚大型混沌球，其分裂成3个小型混沌球，并呈三角状分布在玩家周围，触碰持续造成16%伤害。(特异体)大型混沌球连续分裂3次后消失。"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" alpha="0.9" text="遗迹重机迈出右脚踩下，造成40%伤害，随后暴露双腿核心，并产生一个更大范围的震波，造成70%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="1152" width="448" alpha="0.9" text="(特异体)遗迹重机进行右拳、左拳、转身、砸击共4段的普通攻击，依次造成30%,30%,30%,50%伤害，停留一下，使用激光对前方轰击，造成20%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="1376" width="448" alpha="0.9" text="(特异体)遗迹重机双手拼合，往地上插入形成推土机，造成40%伤害，期间不断冲向玩家，触碰造成30%伤害，接着拔起造成40%伤害，插入和拔起均短暂暴露双腿核心。"/>
	<mx:Text styleName="textStyle9" x="736" y="1632" width="448" alpha="0.9" text="(特异体)遗迹重机生命值为0时，其缓慢恢复生命值至满，每秒恢复12.5%生命值，期间无法被任何攻击伤及。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="侧转进锋-位移"/>
	<mx:Text styleName="textStyle10" x="736" y="384" width="448" text="大型耕地-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="608" width="448" text="混沌光种-远程"/>
	<mx:Text styleName="textStyle10" x="736" y="864" width="448" text="沉铁重震-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="1088" width="448" text="拳转踩踢-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="1312" width="448" text="土推机犁-位移"/>
	<mx:Text styleName="textStyle10" x="736" y="1568" width="448" text="脉华复生-回复"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="激光雕刻-远程"/>
	<mx:Text styleName="textStyle10" x="1408" y="384" width="448" text="砧合砌光-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="608" width="448" text="重获能机-恢复"/>
	<mx:Text styleName="textStyle10" x="1408" y="864" width="448" text="岩崩天砸-爆发"/>
	<mx:Text styleName="textStyle10" x="1408" y="1088" width="448" text="双掠重震-位移"/>
	<mx:Text styleName="textStyle10" x="1408" y="1312" width="448" text="光钉专毁-输出"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="遗迹重机暴露头部弱点，发射激光对玩家持续造成40%伤害，摧毁双腿核心后则坐在地上施放。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="遗迹重机低身，暴露头部核心，双掌合十，造成50%伤害，随后快速发射激光，从右到左扫射，造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="672" width="448" alpha="0.9" text="在遗迹重机的3个核心全部摧毁的一段时间后，3个弱点全部亮起并恢复，发射激光，旋转一圈；内圈造成100%伤害，外圈造成80%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="928" width="448" alpha="0.9" text="(特异体)遗迹重机举起双臂，3s后对着地面砸击造成70%伤害，之后使用激光对地轰击产生飞震波，造成10%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="1152" width="448" alpha="0.9" text="(特异体)遗迹重机抬起右脚，暴露双腿核心，冲向玩家并立即踩下造成70%伤害，然后再抬起左脚重复一遍。"/>
	<mx:Text styleName="textStyle9" x="1408" y="1376" width="448" alpha="0.9" text="(特异体)(仅对普尔希娜光钉使用)遗迹重机进行左转拳、左脚、右转拳、右脚共4段的普通攻击，依次造成30%,40%,30%,40%伤害。"/>
