	<mx:Text styleName="textStyle10" x="64" y="555" width="395" alpha="0.75" text="Ruin Grader"/>
	<mx:Image source="Image4.png" x="64" y="64" width="256" height="256"/>
	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="处在较远的地方时，遗迹重机侧身朝玩家处快速移动，期间碰到造成30%伤害，冲刺开始与结束时造成40%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" alpha="0.9" text="遗迹重机上半身快速旋转，并朝玩家走来，扫击范围内持续造成60%伤害，双腿核心大概率暴露。"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" alpha="0.9" text="遗迹重机短暂暴露头部核心，发射一枚大型混沌球，其分裂成3个小型混沌球，并呈三角状分布在玩家周围，触碰持续造成16%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="928" width="448" alpha="0.9" text="遗迹重机迈出右脚踩下，造成40%伤害，随后暴露双腿核心，并产生一个更大范围的震波，造成70%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="侧转进锋-位移"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="大型耕地-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="混沌光种-远程"/>
	<mx:Text styleName="textStyle12" x="736" y="864" width="448" text="沉铁重震-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="激光雕刻-远程"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="砧合砌光-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="608" width="448" text="重获能机-恢复"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="遗迹重机暴露头部弱点，发射激光对玩家持续造成40%伤害，摧毁双腿核心后则坐在地上施放。"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" alpha="0.9" text="遗迹重机低身，暴露头部核心，双掌合十，造成50%伤害，随后快速发射激光，从右到左扫射，造成80%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" alpha="0.9" text="在遗迹重机的3个核心全部摧毁的一段时间后，3个弱点全部亮起并恢复，发射激光，旋转一圈；内圈造成100%伤害，外圈造成80%伤害。"/>
