	<mx:Image source="Image8.png" x="64" y="781" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="歼灭机关进行剑劈、蹴劈至多2段的攻击，其依次造成30%,40%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="672" width="448" alpha="0.9" text="(强化)歼灭机关开局在身后召唤一个与自身芒荒属性相同的「机关·区域警戒型」。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="锋刃尖裁-近战"/>
	<mx:Text styleName="textStyle10" x="1408" y="608" width="448" text="战术辅助-召唤   芒荒"/>
	<mx:Text styleName="textStyle10" x="1408" y="384" width="448" text="湿刃漩舞-输出   荒"/>
	<mx:Text styleName="textStyle10" x="736" y="608" width="448" text="戏水飞轮-妨害   荒"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="歼灭机关使用左足。金鸡独立般不断进行旋水攻击，接触持续造成60%,30%,12%,6%伤害，该技能可连续施放2次。"/>
	<mx:Text styleName="textStyle8" x="736" y="672" width="448" alpha="0.9" text="歼灭机关进行2段飞踢，均造成50%伤害，随后后撤，朝前施放出3个水轮，接触造成35%伤害。"/>
	<mx:Text styleName="textStyle11" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Image source="Image9.png" x="576" y="150" width="168" height="170"/>
	<mx:Image source="Image10.png" x="1248" y="598" width="168" height="170"/>
	<mx:Text styleName="textStyle12" x="64" y="912" width="448" alpha="0.75" text="荒芒性质：2次芒荒攻击可以瘫痪相反属性的歼灭机关，约25s-30s后恢复荒芒属性。"/>
