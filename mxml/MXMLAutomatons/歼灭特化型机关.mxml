	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="雷驭腾极-输出   芒"/>
	<mx:Text styleName="textStyle10" x="736" y="384" width="448" text="散引线雷-控制   芒"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="歼灭机关使用雷剑，进行戳、旋、落至多3段的攻击，其依次造成50%,60%,70%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="歼灭机关使用雷剑，朝上放电，引出数道呈线性分布的落雷，造成70%,21%,7%伤害，该技能可连续施放2次。"/>
