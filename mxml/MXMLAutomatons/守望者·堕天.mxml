	<mx:Text styleName="textStyle" x="64" y="384" width="512" text="守望者·堕天"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="1128" width="448" alpha="0.75" text="监望之统摄：大招之前会施放2次，每次会分别记录火/水/雷/冰的攻击次数，首次施放时，当某一元素次数达3次时，即为记录完成，并作为元素星的属性储存；若第二次记录的元素与首次相同，则需要9次攻击才能被记录。元素星：生命值243740(4.0F)，为守望者的1/6；活性免疫对应元素伤害，惰性具有高抗；深渊内，若为异色元素星，则星星生命值降低至守望者的1/15。部分技能期间，抗打断80。"/>
	<mx:Text styleName="textStyle4" x="64" y="512" width="460" text="开眼者·世界望楼之守望"/>
	<mx:Text styleName="textStyle5" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle6" x="1216" y="64" width="640" alpha="0.5" text="元素能量：WP[75,50,25],WO[75,50,25,0]"/>
	<mx:Text styleName="textStyle7" x="64" y="672" width="305" text="HP: 1462443 (24.0F)"/>
	<mx:Text styleName="textStyle8" x="64" y="640" width="305" alpha="0.75" text="首领-尼西里塔 Lv.103 Data"/>
	<mx:Text styleName="textStyle7" x="64" y="720" width="375" text="ATK: 20886 (8.0B2)"/>
	<mx:Text styleName="textStyle7" x="64" y="768" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle9" x="64" y="465" width="395" alpha="0.75" text="Watcher: Fallen Vigil"/>
	<mx:Text styleName="textStyle10" x="64" y="555" width="407" alpha="0.75" text="The Open-Eyed: World Watch Sentry"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="守望者从门中扔下长矛进入战斗，造成20%伤害，随后从门中出现。"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" alpha="0.9" text="守望者持矛立即进行破击，造成41%伤害，随后翻身，驾驭着长矛继续冲击，造成47%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" alpha="0.9" text="守望者抬起长矛，朝前方的地上猛击，造成60%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="896" width="448" alpha="0.9" text="距离较远时，守望者扔起长矛，纵身一跃，在玩家处落下，造成60%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" alpha="0.9" text="守望者将长矛朝前方丢出，长矛经过将造成60%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="守望者进行2段左右划攻击，依次造成32%,34%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="896" width="448" alpha="0.9" text="守望者将长矛先转一圈，造成40%伤害，随后立即进入监望之统摄状态，持续5s；记录完毕后/未成功记录 将造成对应元素/岩元素的68%伤害。累计施放2次后立即准备大招「现象之谵妄」。"/>
	<mx:Text styleName="textStyle11" x="736" y="1152" width="1024" alpha="0.9" text="守望者移至场地中央，并进行蓄力，同时召唤2枚元素星，属性为先前两次所记录的元素，同时免疫对应元素伤害；难以破坏的惰性岩元素星不免疫伤害，但具有高抗；18s后，将根据场上剩余的元素星，依次造成对应元素的100%伤害。破坏第1/2颗元素星将对守望者造成2段3%/2段9%生命值的对应元素真伤(仅暴击的一段有附着)。深境螺旋内，若守望者召唤了不同的两枚元素星，则它们的生命值将大幅下降。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="遗世之流影-突袭"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="圣临之重奏-远程"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="苍际之鉴示-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="832" width="448" text="昂天之判谴-位移"/>
	<mx:Text styleName="textStyle12" x="1408" y="608" width="448" text="贯洗之负槊-远程"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="安守之斥逐-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="832" width="448" text="监摄之神筑-反击"/>
	<mx:Text styleName="textStyle12" x="736" y="1088" width="448" text="现象之谵妄-爆发"/>
