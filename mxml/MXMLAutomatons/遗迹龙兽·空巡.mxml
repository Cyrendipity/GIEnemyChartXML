	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="Ruin Drake: Skywatch"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="736" y="256" width="448" alpha="0.9" text="空巡龙兽使用两翼各朝前施放一排的子弹，造成60%,18%,6%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="480" width="448" alpha="0.9" text="空巡龙兽瞄准玩家，暴露腹部弱点，两翼后侧各施放5个追踪弹，造成60%,18%,6%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="704" width="448" alpha="0.9" text="靠近空巡龙兽时，空巡龙兽向前翻滚一圈，使用尾部齿轮造成80%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="928" width="448" alpha="0.9" text="空巡龙兽暴露头部弱点，使用两翼汲取元素力，向空中抛出13枚散弹，造成100%,30%,10%对应元素伤害并清空元素螺栓。"/>
	<mx:Text styleName="textStyle11" x="736" y="1152" width="448" alpha="0.9" text="空巡龙兽施放「散落洪流」后，会立即吸收元素填充元素螺栓，使下一次「散洪流落」技能附上元素伤害。瘫痪龙兽清空元素螺栓及提升的抗性。"/>
	<mx:Text styleName="textStyle12" x="736" y="192" width="448" text="链型机枪-远程"/>
	<mx:Text styleName="textStyle12" x="736" y="416" width="448" text="禁法制导-追踪"/>
	<mx:Text styleName="textStyle12" x="736" y="640" width="448" text="近身齿刽-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="864" width="448" text="散落洪流-爆发"/>
	<mx:Text styleName="textStyle12" x="736" y="1088" width="448" text="能量再造-天赋"/>
