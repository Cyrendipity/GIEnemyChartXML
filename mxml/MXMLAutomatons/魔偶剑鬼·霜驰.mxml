	<mx:Text styleName="textStyle9" x="736" y="256" width="448" alpha="0.9" text="霜驰左右双持，全身发亮朝地猛击，造成160%伤害，并留下持续20s的冰地面，接触持续造成25%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="480" width="448" alpha="0.9" text="霜驰进行横-斜-纵的普通攻击，共计3段，每段均造成50%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="704" width="448" alpha="0.9" text="霜驰斜上插刀鞘，随后快速突进，突进和终点处均造成60%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="928" width="448" alpha="0.9" text="霜驰平插刀鞘，产生真空场吸引玩家，随后挥刀造成小范围100%伤害，接下来在更大的范围再次造成100%伤害。"/>
