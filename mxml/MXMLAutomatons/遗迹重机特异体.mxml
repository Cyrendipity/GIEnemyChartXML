	<mx:Text styleName="textStyle7" x="64" y="446" width="395" alpha="0.75" text="Anomalous Model Ruin Grader"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="强化状态下，遗迹重机短暂暴露头部核心，发射一枚大型混沌球，其分裂成3个小型混沌球，并呈三角状分布在玩家周围，触碰持续造成16%伤害，大型混沌连续分裂3次后消失。"/>
	<mx:Text styleName="textStyle8" x="736" y="512" width="448" alpha="0.9" text="强化状态下，遗迹重机进行右拳、左拳、转身、砸击共4段的普通攻击，依次造成30%,30%,30%,50%伤害，停留一下，使用激光对前方轰击，造成20%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="448" alpha="0.9" text="强化状态下，遗迹重机双手拼合，往地上插入形成推土机，造成40%伤害，期间不断冲向玩家，触碰造成30%伤害，接着拔起造成40%伤害，插入和拔起均短暂暴露双腿核心。"/>
	<mx:Text styleName="textStyle8" x="736" y="992" width="448" alpha="0.9" text="强化状态下，且光钉未满时，遗迹重机生命值为0时，其缓慢恢复生命值至满，每秒恢复12.5%生命值，期间无法被任何攻击伤及。"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="混沌光种-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="448" width="448" text="拳转踩踢-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="672" width="448" text="土推机犁-位移"/>
	<mx:Text styleName="textStyle9" x="736" y="928" width="448" text="脉华复生-回复"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="机能重获-恢复"/>
	<mx:Text styleName="textStyle9" x="1408" y="448" width="448" text="岩崩天砸-爆发"/>
	<mx:Text styleName="textStyle9" x="1408" y="672" width="448" text="双掠重震-位移"/>
	<mx:Text styleName="textStyle9" x="1408" y="928" width="448" text="光钉专毁-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="在遗迹重机低于60%生命值时，或战斗开始50s后，遗迹重机将开始充能，永久进入强化状态。该状态下免疫控制效果，其将尝试攻击光钉；攻击弱点将不瘫痪。未处于强化状态下时，与一般遗迹重机 无异"/>
	<mx:Text styleName="textStyle8" x="1408" y="512" width="448" alpha="0.9" text="强化状态下，遗迹重机举起双臂，3s后对着地面砸击造成70%伤害，之后使用激光对地轰击产生飞震波，造成10%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="736" width="448" alpha="0.9" text="强化状态下，遗迹重机抬起右脚，暴露双腿核心，冲向玩家并立即踩下造成70%伤害，然后再抬起左脚重复一遍。"/>
	<mx:Text styleName="textStyle8" x="1408" y="992" width="448" alpha="0.9" text="强化状态下，遗迹重机进行左转拳、左脚、右转拳、右脚共4段的普通攻击，依次造成30%,40%,30%,40%伤害。(仅对普尔希娜光钉使用)"/>
