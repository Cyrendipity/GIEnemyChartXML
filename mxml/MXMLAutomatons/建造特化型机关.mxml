	<mx:Text styleName="textStyle" x="64" y="480" width="448" text="建造特化型机关"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1387" y="64" width="469" alpha="0.5" text="元素能量：WP[75,50,25],WO[0]"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="305" text="HP: 388220 (7.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="640" width="305" alpha="0.75" text="普通 Lv.100 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="720" width="375" text="ATK: 7387 (3.0B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="768" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle7" x="64" y="542" width="395" alpha="0.75" text="Construction Specialist Mek"/>
	<mx:Image source="Image11.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="建造机关使用右侧机械臂对玩家发射一枚小型导弹，造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="建造机关使用两个机械臂敲击地面，造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="建造机关使用锯齿机械臂，并不断旋转自身，持续造成100%,20%,10%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="672" width="448" alpha="0.9" text="建造机关纵劈锯齿，利用滚动的锯齿向前不断移动，接触造成50%,10%,5%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="1120" width="448" alpha="0.9" text="建造机关在闲置时，会挖出地面的石块并将其运送至后方，落下的石块会造成10%伤害；有20%的概率会挖出火史莱姆，史莱姆落下造成10%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="896" width="448" alpha="0.9" text="建造机关利用钩爪机械臂长时间不断对玩家发射低伤害的冰锥，冰锥造成10%,5%,2.5%,1%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="896" width="448" alpha="0.9" text="建造机关利用钩爪抓起冰块，旋转一圈，造成70%伤害，然后顺势砸下，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="672" width="448" alpha="0.9" text="建造机关使用锯齿进行一次纵向劈，并立即收回，纵劈与收回分别造成60%,40%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="小型引弹-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="384" width="448" text="双杆齐下-控制"/>
	<mx:Text styleName="textStyle9" x="1408" y="384" width="448" text="灼轮迂旋-输出   芒"/>
	<mx:Text styleName="textStyle9" x="736" y="608" width="448" text="压路神器-位移   芒"/>
	<mx:Text styleName="textStyle9" x="736" y="1056" width="448" text="造山垒石-待机"/>
	<mx:Text styleName="textStyle9" x="736" y="832" width="448" text="冰连霜锋-妨害   荒"/>
	<mx:Text styleName="textStyle9" x="1408" y="832" width="448" text="巨冻天寒-输出   荒"/>
	<mx:Text styleName="textStyle9" x="1408" y="608" width="448" text="炎齿辄切-输出   芒"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="经打戏算-击退"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="建造机关进行右切、左切、齐下3段攻击，依次造成50%,25%,12.5%伤害。"/>
