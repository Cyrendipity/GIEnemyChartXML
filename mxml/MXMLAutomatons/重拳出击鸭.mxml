	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="距离较远时，大鸭举着左手锯刃直冲过来下劈，造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="距离较远时，大鸭缩起自身，原地起飞并重重降落，起飞与降落分别造成50%,80%伤害，该技能也用来返回场地中央启用「歼灭模式」。"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" alpha="0.9" text="启用「歼灭模式」！，大鸭四肢招展，召唤5只冲鸭机关，短时间内大鸭在高频捶地，造成50%,40%,30%伤害，q期间大鸭的全抗大幅提升，该模式持续36s。冲鸭机关被击败后，将反击大鸭，对其造成5%生命值的伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="大鸭抄起右手大锤，用力朝前方砸下，造成80%伤害，若此时玩家处于后方，则立即自转一圈、外踢一脚，依次造成60%,70%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="处于其侧或后方时，大鸭利用左手锯刃自转一圈，造成60%伤害；。"/>
	<mx:Text styleName="textStyle10" x="1408" y="736" width="448" alpha="0.9" text="歼灭技其一，大鸭朝前方持续沿直线行进，同时进行混捶散打，持续造成40%,32%,24%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1056" width="448" alpha="0.9" text="歼灭技其三，大鸭朝附近的玩家发动一次拳击，造成90%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1056" width="448" alpha="0.9" text="歼灭技其二，大鸭朝前方持续沿直线行进，同时持续旋转，造成30%伤害，命中玩家或行至尽头时突然跃起坠落，造成100%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="擎刃削泥-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="416" width="448" text="摐地清尘-位移"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" text="深度蠲洁-防御"/>
	<mx:Text styleName="textStyle13" x="64" y="1188" width="448" alpha="0.75" text="冲鸭机关：充能条总量100，每次受到(月)感电反应伤害积攒10，攒满后反击大鸭；在大世界中，冷静一下鸭与薇尔琪塔的攻击能够额外积攒3充能。歼灭模式：5次特化次数盾，对应5只鸭子的反击，击破可使其瘫痪15s。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="执锤修葺-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="416" width="448" text="拧转尘浪-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" text="散拳惑眼-位移"/>
	<mx:Text styleName="textStyle11" x="1408" y="992" width="448" text="矩力强合-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="992" width="448" text="全位转碾-位移"/>
