	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="水丘丘游侠使用镰刀进行快速的两段攻击，分别造成80%,100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="水丘丘游侠使用镰刀进行一段较长时间的蓄力回旋，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="512" width="448" alpha="0.9" text="距离玩家较远时，水丘丘游侠追逐玩家并给一镰刀，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="800" width="448" alpha="0.9" text="水丘丘游侠将自身挂水，召唤出水史莱姆，使其发射3个水泡，触碰造成50%伤害，之后大水史莱姆变小，被水丘丘游侠踢出，造成100%伤害。用元素反应破除水史莱姆可瘫痪游侠。"/>
	<mx:Text styleName="textStyle10" x="1408" y="512" width="448" alpha="0.9" text="距离玩家较近时，水丘丘游侠掰直镰刀，戳击，造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="800" width="448" alpha="0.9" text="水丘丘游侠丢出3个小水史莱姆，造成80%,40%,20%伤害。"/>
