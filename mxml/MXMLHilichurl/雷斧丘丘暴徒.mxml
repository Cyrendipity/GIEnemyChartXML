	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="340" text="丘丘暴徒 · 雷斧"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：WP[75,50,25],WO[0]"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="375" text="HP: 110295 (3.0H)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 11819 (4.8B1)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 150/210"/>
	<mx:Text styleName="textStyle8" x="64" y="465" width="395" alpha="0.75" text="Crackling Axe Mitachurl"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="Mitachurl: Cracking Axe"/>
	<mx:Image source="Image3.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="雷斧进行至多3段的4种普通攻击：旋-劈；挑-劈；旋-旋-劈；挑-旋；每段攻击都造成50%/50%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="当雷斧的斧子存在附魔，而玩家又距离比较远时，雷斧从地里挖出两种史莱姆丢出：雷史莱姆造成62.5%伤害，变异雷史莱姆造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="雷斧横拿斧子转圈圈，触碰造成12.5%/12.5%伤害，持续3s，旋转结束后施放尾刀，造成50%/50%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="927" width="448" alpha="0.9" text="(仅雷雨天、秘境)雷斧举起斧子，马上被雷电晕，并在其周围电击造成50%伤害，总共被电2次，然后雷斧躺下。"/>
	<mx:Text styleName="textStyle12" x="1408" y="672" width="448" alpha="0.9" text="(仅附魔)雷斧用力将斧子往地上砸，造成50%伤害，顺势将自己挑起，然后落地坐下，造成75%伤害。强攻强化：落地时周围产生3道落雷，每道造成50%伤害。"/>
	<mx:Text styleName="textStyle13" x="1408" y="448" width="448" alpha="0.9" text="(仅强攻强化)距离玩家较远时，雷斧拿着斧子跳起来下落，造成100%/100%伤害。若斧子附带雷附魔，则周围产生5道落雷，每道造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="雷斧从地里挖出雷史莱姆，给斧子上雷附魔后丢出，造成37.5%伤害。"/>
	<mx:Text styleName="textStyle14" x="736" y="160" width="448" text="斧砍树-输出"/>
	<mx:Text styleName="textStyle14" x="736" y="384" width="448" text="布丁飞-远程"/>
	<mx:Text styleName="textStyle14" x="736" y="608" width="448" text="龙卷摧-猛攻"/>
	<mx:Text styleName="textStyle14" x="736" y="864" width="448" text="狮子祭-天赋"/>
	<mx:Text styleName="textStyle14" x="1408" y="608" width="448" text="虎鹰掠-妨害"/>
	<mx:Text styleName="textStyle14" x="1408" y="384" width="448" text="飞象坠-爆发"/>
	<mx:Text styleName="textStyle15" x="64" y="1008" width="448" alpha="0.75" text="雷附魔：2雷盾，熄灭后斧子只能打出物理伤害。该状态下，抗打断0.8。"/>
	<mx:Text styleName="textStyle14" x="1408" y="160" width="448" text="碎雷布丁-附魔"/>
