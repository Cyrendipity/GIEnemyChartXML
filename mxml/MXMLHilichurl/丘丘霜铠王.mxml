	<mx:Text styleName="textStyle10" x="1408" y="192" width="448" text="冰霜嵌-强化"/>
	<mx:Text styleName="textStyle10" x="1408" y="416" width="448" text="掌掴蝇-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="640" width="448" text="乌鸦坐-爆发"/>
	<mx:Text styleName="textStyle10" x="736" y="864" width="448" text="布丁飞-远程"/>
	<mx:Text styleName="textStyle11" x="1408" y="256" width="448" alpha="0.9" text="冰丘丘王进行扩胸运动，全身变冰霜发亮，进入魔化状态，并附属冰铠。"/>
	<mx:Text styleName="textStyle12" x="1408" y="480" width="448" alpha="0.9" text="(魔化)冰丘丘王左手蓄力一挥，造成37.5%伤害，并留下冰晶，冰晶迸裂造成50%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="704" width="448" alpha="0.9" text="(魔化)冰丘丘王侧身蓄力起跳，重重下落造成100%伤害，并留下结冰地面，接触造成15%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="928" width="1024" alpha="0.9" text="冰丘丘王从地上挖并抛出3只冰史莱姆，每个造成50%伤害。魔化状态：抛出一只大冰史莱姆，造成62.5%伤害；"/>
	<mx:Text styleName="textStyle13" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="736" y="256" width="448" alpha="0.9" text="冰丘丘王进行勾拳、捶地2段的普通攻击，分别造成37.5%,40%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="480" width="448" alpha="0.9" text="(魔化)冰丘丘王蓄力冲过来，造成50%伤害，并在其路径上留下6个冰簇，冰簇接触爆炸造成25%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="704" width="448" alpha="0.9" text="冰丘丘王进行1-2次的双手锤击地面攻击，两次分别造成50%,62.5%伤害，第二次锤击的范围更大。"/>
	<mx:Text styleName="textStyle10" x="736" y="192" width="448" text="黑虎掏-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="416" width="448" text="鹤捕虾-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="640" width="448" text="地震拳-输出"/>
