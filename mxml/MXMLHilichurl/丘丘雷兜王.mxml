	<mx:Image source="Image4.png" x="64" y="1069" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="256" width="448" alpha="0.9" text="雷丘丘王进行勾拳、捶地2段的普通攻击，分别造成37.5%,40%伤害。魔化状态：捶地产生2个电气碎石。"/>
	<mx:Text styleName="textStyle11" x="736" y="480" width="448" alpha="0.9" text="(魔化)雷丘丘王左手伏地冲过来，造成50%伤害，蓄力时间可长可短。"/>
	<mx:Text styleName="textStyle10" x="736" y="704" width="448" alpha="0.9" text="雷丘丘王侧身蓄力起跳，重重下落造成100%伤害，并留下1个电气碎石，形成碎石的落雷造成50%伤害：魔化状态：落地产生3个电气碎石。"/>
	<mx:Text styleName="textStyle11" x="736" y="928" width="448" alpha="0.9" text="(魔化)雷丘丘王蓄力进行飞扑，造成62.5%伤害，可突然进行飞扑攻击。"/>
	<mx:Text styleName="textStyle10" x="736" y="1152" width="1024" alpha="0.9" text="雷丘丘王从地上挖并抛出1只雷史莱姆或者变异雷史莱姆，均造成50%伤害。魔化状态：1.抛出一只大雷史莱姆，造成62.5%伤害；2.抛出一只变异大雷史莱姆，造成62.5%伤害，其产生3个碎屑，每个造成50%伤害；"/>
	<mx:Text styleName="textStyle10" x="1408" y="256" width="448" alpha="0.9" text="雷丘丘王进行扩胸运动，全身变雷晶发亮，进入魔化状态，并附属雷甲。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="雷丘丘王进行一次勾拳，朝任意方向挥一拳，造成37.5%伤害。魔化状态：使用左手蓄力一挥，造成37.5%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="704" width="448" alpha="0.9" text="雷丘丘王进行固定2次的双锤地攻击，两次分别造成50%,62.5%伤害，第二次锤击的范围更大。魔化状态：锤地产生2-3个电气碎石。"/>
	<mx:Text styleName="textStyle11" x="1408" y="928" width="448" alpha="0.9" text="处于魔化状态下的雷丘丘王的部分技能会留下电气碎石，一段时间后爆炸，造成50%伤害，也可被雷丘丘王的冲撞引爆。"/>
