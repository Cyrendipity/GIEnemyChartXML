	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="火斧从地里挖出火史莱姆，给斧子上火附魔后丢出，造成37.5%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="512" width="448" alpha="0.9" text="距离玩家较远时，火斧拿着斧子跳起来下落，造成100%/100%伤害。若斧子附带火附魔，则在前方扇形区产生5道火喷，每道造成16.5%伤害。强攻强化：落地时周围产生7道火喷。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="爆热布丁-附魔"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" text="飞象坠-爆发"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="火斧进行至多2段的2种普通攻击：旋-劈、旋-旋，每段攻击均造成50%/50%伤害，其中下劈攻击将在前方产生一道3段的火喷，造成16.5%伤害。强攻强化：下劈攻击时产生3道火喷。"/>
	<mx:Text styleName="textStyle10" x="736" y="512" width="448" alpha="0.9" text="当火斧的斧子存在附魔，而玩家又距离比较远时，火斧从地里挖出火史莱姆丢出，造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="800" width="448" alpha="0.9" text="火斧横拿斧子转圈圈，触碰造成12.5%/12.5%伤害，持续3s，旋转结束后施放尾刀，造成50%/50%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="斧砍树-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" text="布丁飞-远程"/>
	<mx:Text styleName="textStyle11" x="736" y="736" width="448" text="龙卷摧-猛攻"/>
