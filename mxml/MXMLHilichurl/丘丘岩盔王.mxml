	<mx:Text styleName="textStyle10" x="736" y="256" width="448" alpha="0.9" text="岩丘丘王进行勾拳、捶地2段的普通攻击，分别造成40%,53.3%伤害。魔化状态：捶地产生2道碎岩波，造成33.3%,16.6%,8.33%,3.33%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="512" width="448" alpha="0.9" text="岩丘丘王左手伏地冲过来，造成66.6%伤害，蓄力时间一般较短。"/>
	<mx:Text styleName="textStyle10" x="1408" y="256" width="448" alpha="0.9" text="岩丘丘王进行扩胸运动，全身变成金黄色，进入魔化状态，并附属岩铠。"/>
	<mx:Text styleName="textStyle10" x="1408" y="768" width="448" alpha="0.9" text="岩丘丘王进行1-3次的双手捶地攻击，每次造成33.3%伤害。捶地产生3道碎岩波；第三次碎岩波更大更迅速。"/>
	<mx:Text styleName="textStyle10" x="736" y="1024" width="1024" alpha="0.9" text="岩丘丘王从地上挖并抛出3只岩史莱姆，每个造成66.6%伤害。魔化状态：抛出一只大岩史莱姆，造成83.3%伤害；"/>
	<mx:Text styleName="textStyle10" x="736" y="768" width="448" alpha="0.9" text="岩丘丘王侧身起跳，重重下落造成100%伤害。魔化状态：落地产生4道坐标系方向碎岩波。"/>
	<mx:Text styleName="textStyle10" x="1408" y="512" width="448" alpha="0.9" text="岩丘丘王进行一次用力的勾拳，造成50%伤害。"/>
