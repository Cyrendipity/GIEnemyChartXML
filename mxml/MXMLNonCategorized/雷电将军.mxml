	<mx:Text styleName="textStyle" x="64" y="384" width="442" text="雷电将军"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="375" text="尘世七执政·雷之神"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：NA"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="305" text="HP: 2218401 (40.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="首领-薙刀形态-闭锁 Lv.100 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 22160 (9.0B1)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 150/500"/>
	<mx:Text styleName="textStyle8" x="64" y="465" width="395" alpha="0.75" text="Raiden Shogun"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="The Seven: Electro Archon"/>
	<mx:Image source="Image5.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="雷电将军使用手上的薙刀，进行至多6段的普通攻击，每段攻击分别造成25%,25%,33.3%,16.6%,16.6%,16.6%伤害，最后命中产生次元斩，造成12.5%,12.5%,25%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="雷电将军旋转薙刀冲向玩家，造成16.6%伤害，随后速斩3刀，前两刀均造成25%伤害，较大的第三刀，造成33.3%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="768" width="448" alpha="0.9" text="雷电将军用薙刀划过，划出一道雷刃，造成33.3%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="992" width="448" alpha="0.9" text="在场上拖得足够久时，雷电将军的眼狩令的权能显现：产生雷震击飞附近玩家，造成16.6%伤害，并永久禁用除旅行者外的角色的元素战技及元素爆发。"/>
	<mx:Text styleName="textStyle10" x="1408" y="768" width="448" alpha="0.9" text="处于雷电将军身后时，雷电将军转身划薙刀，造成50%伤害，随后爆破一下，造成50%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="992" width="448" alpha="0.9" text="雷电将军的生命值下降至70%左右时，进行剧情杀神罚，弹开附近玩家造成16.6%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="雷电将军旋转薙刀，随后产生大范围的落雷，造成66.6%伤害(闪避帧无效)。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="雷电将军拿薙刀，震开附近玩家，造成16.6%伤害，召唤三个祸津之雷眼在场地上，一段时间后同时爆炸，被1/2/3个祸眼命中时，将造成133.3%/2段33.3%/3段13.3%伤害，以上伤害闪避帧均无效。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="奔雷流电-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="416" width="448" text="忿怨之断-位移"/>
	<mx:Text styleName="textStyle12" x="736" y="704" width="448" text="无想一槊-远程"/>
	<mx:Text styleName="textStyle12" x="736" y="928" width="448" text="神权狩眼-禁令"/>
	<mx:Text styleName="textStyle12" x="1408" y="704" width="448" text="震厄裁决-防卫"/>
	<mx:Text styleName="textStyle12" x="1408" y="928" width="448" text="神令罚威-决斗"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="万雷归葬-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="416" width="448" text="三重祸眼-召唤"/>
	<mx:Text styleName="textStyle13" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle14" x="64" y="1008" width="448" alpha="0.75" text="祸津之雷眼：7次次数盾，击破可阻止其爆炸。"/>
