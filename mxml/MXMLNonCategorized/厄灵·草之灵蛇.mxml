	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="叶轮舞者与草之灵蛇一同进行：草之灵蛇在玩家处产生临时屏障，并在其中撒下大量花弹，造成30%,15%,3%伤害，随后屏障破碎；叶轮舞者则施放「轮飞廻斜」。"/>
	<mx:Text styleName="textStyle9" x="736" y="512" width="448" alpha="0.9" text="草之灵蛇朝前方突进，造成60%伤害，接着甩尾攻击，造成70%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="736" width="448" alpha="0.9" text="草之灵蛇转将自己盘成环状，发射一枚草棱镜弹，造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="960" width="448" alpha="0.9" text="草之灵蛇闪现，然后出现在玩家处，使用充满能量的尾针用力扎地，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="192" width="448" text="茵幕种牢-协同爆发"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" text="驱场斥击-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" text="翡晶掷射-远程"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" text="灵螯伏针-位移"/>
