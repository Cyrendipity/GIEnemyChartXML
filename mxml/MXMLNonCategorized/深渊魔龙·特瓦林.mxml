	<mx:Image source="Image11.png" x="1268" y="619" width="128" height="128"/>
	<mx:Image source="Image12.png" x="596" y="395" width="128" height="128"/>
	<mx:Text styleName="textStyle11" x="736" y="896" width="448" alpha="0.9" text="特瓦林倒地时会展开「深黯护盾」，该护罩继承15%生命值，后续出现则为7.5%生命值，只接受元素伤害；破坏后失去15%生命值。"/>
	<mx:Text styleName="textStyle12" x="736" y="832" width="448" text="未竟的命运-天赋"/>
