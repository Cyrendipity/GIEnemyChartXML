	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="剧情  Lv.98 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 7151 (3.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 20000/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="436" width="395" alpha="0.75" text="Abyssal Stormterror - Dvalin"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="Freedom Comes Even Through the Destruction of All Things"/>
	<mx:Image source="Image5.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="64" y="1008" width="448" alpha="0.75" text="枯风之佑：生命盾，继承25%特瓦林生命值。"/>
	<mx:Image source="Image6.png" x="64" y="64" width="256" height="256"/>
	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="特瓦林从远处猛地冲来，用爪子划过平台，造成100%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" alpha="0.9" text="特瓦林将头甩上平台，造成100%伤害，停留数秒后离去。"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" alpha="0.9" text="特瓦林下潜，并从对面超远处平台冒出，蓄力施放巨大的黯渊球，对整个平台造成100%伤害(闪避帧无效)。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="渐进的低咒-位移"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="魔龙的追忿-防御"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="乌风的哀郁-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="608" width="448" text="深邃的悲楚-爆发"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="昏黑的号恸-猛攻"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="夜穹的谵呓-远程"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="特瓦林趴在平台上，吐出漆黑龙息，持续造成50%伤害，从一侧开始扫过平台大部分区域。"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" alpha="0.9" text="特瓦林离开平台，一左一右地发射黑渊弹，每次2个，每个造成50%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" alpha="0.9" text="特瓦林怒吼，在所有平台周期性产生6道星门阵，每个星门阵于玩家所在平台降下蚀星，造成30%伤害；特瓦林倒地则暂停施放，恢复后继续；破坏2次护盾后施放。"/>
	<mx:Image source="Image7.png" x="1268" y="395" width="128" height="128"/>
	<mx:Image source="Image8.png" x="597" y="171" width="128" height="128"/>
	<mx:Image source="Image9.png" x="596" y="619" width="128" height="128"/>
