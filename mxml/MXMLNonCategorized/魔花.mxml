	<mx:Text styleName="textStyle7" x="64" y="529" width="395" alpha="0.75" text="Fellflower"/>
	<mx:Image source="Image4.png" x="64" y="909" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="1408" y="160" width="448" text="魔实冰璃-协同远程"/>
	<mx:Text styleName="textStyle8" x="1408" y="384" width="448" text="魔实晶粹-反噬"/>
	<mx:Text styleName="textStyle8" x="1408" y="608" width="448" text="浮风坠雪-定点"/>
	<mx:Text styleName="textStyle8" x="1408" y="832" width="448" text="根巡·雪覆-位移"/>
	<mx:Text styleName="textStyle8" x="1408" y="1056" width="448" text="升雹落雪-远程"/>
	<mx:Text styleName="textStyle9" x="1408" y="224" width="448" alpha="0.9" text="魔花果实发射碎片袭击玩家，每个碎片造成50%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="448" width="448" alpha="0.9" text="击碎魔花果实后，会反噬并暂时瘫痪魔花，同时掉落5个魔花精粹；一段时间后魔花会吸收魔花精粹并恢复。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="(缩小前)魔花不断产生雪球下坠，每个造成50%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="896" width="448" alpha="0.9" text="(缩小后)魔花钻入地面，再在玩家处快速钻出，造成100%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="1120" width="448" alpha="0.9" text="(缩小后)魔花朝玩家扔出3个雪球，每个造成60%伤害。"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle9" x="736" y="224" width="448" alpha="0.9" text="魔花果实对玩家进行连续的下落攻击，每次造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="448" width="448" alpha="0.9" text="魔花果实召唤1-2个大型冰史莱姆，无伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="672" width="448" alpha="0.9" text="魔花旋转其花叶，造成100%伤害，不论大小状态均会施放。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="(缩小前)魔花使用花冠不断放出3排的雪球滚落，接触造成100%,50%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="1120" width="448" alpha="0.9" text="(缩小后)魔花朝玩家连续发射总计9个的冰弹，每个造成20%伤害。"/>
