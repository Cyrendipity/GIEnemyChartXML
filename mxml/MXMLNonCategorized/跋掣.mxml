	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="跋掣一支发射6个水珠追踪玩家，每个造成40%伤害。"/>
	<mx:Image source="Image4.png" x="596" y="171" width="128" height="128"/>
	<mx:Image source="Image5.png" x="576" y="150" width="168" height="170"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="跋掣一支在边缘不断移动，使用口部吸引玩家，之后喷出巨大喷流，造成70%伤害，继续接触喷流则额外再造成3段40%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="512" width="448" alpha="0.9" text="跋掣一支后倾，然后用力朝前方撞去，造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="800" width="448" alpha="0.9" text="当跋掣只剩下一支时，每15s，在场上产生8个下落的水弹，每个造成40%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="512" width="448" alpha="0.9" text="跋掣一支在场地中间产生一个漩涡，吸引玩家并持续造成40%伤害，5s后漩涡喷发，造成100%伤害。"/>
