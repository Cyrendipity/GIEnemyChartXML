	<mx:Text styleName="textStyle9" x="736" y="448" width="448" alpha="0.9" text="玻瑞亚斯在落地的位置产生寒气，随后跳跃至此，造成83.3%伤害(闪避帧无效)，并产生一个冰元素晶球。"/>
	<mx:Text styleName="textStyle8" x="736" y="384" width="448" text="御阵流冰-位移"/>
