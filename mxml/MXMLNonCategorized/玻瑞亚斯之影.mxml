	<mx:Text styleName="textStyle9" x="736" y="672" width="448" alpha="0.9" text="玻瑞亚斯抬起身子在途经上产生霜面，走在霜面上减速30%，并附着冰元素，随后霜面开始起爆，造成41.6%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="608" width="448" text="白草凇花-妨害"/>
	<mx:Image source="Image26.png" x="596" y="619" width="128" height="128"/>
	<mx:Image source="Image27.png" x="576" y="598" width="168" height="170"/>
	<mx:Text styleName="textStyle9" x="736" y="1152" width="448" alpha="0.9" text="低于60%生命值时，玻瑞亚斯绕场地边缘跑动，跑3圈，前两圈跑完3/4圈将直接发起冲撞，最后一圈跑完起跳下落至场地中央。触碰跑动的玻瑞亚斯或遭其冲撞，将造成60%伤害；安德留斯跃入场地中央造成20%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="1088" width="448" text="雾隐遄行-位移"/>
