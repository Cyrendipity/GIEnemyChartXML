	<mx:Text styleName="textStyle9" x="1408" y="448" width="448" alpha="0.9" text="玻瑞亚斯突然朝前方进行一次疾冲，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="384" width="448" text="驰间疾袭-位移"/>
