	<mx:Text styleName="textStyle9" x="1408" y="896" width="448" alpha="0.9" text="玻瑞亚斯在原地晃动全身，凝聚空气中的水汽，不断产生冰锥下坠，造成25%伤害(闪避帧无效)，持续15s。"/>
	<mx:Text styleName="textStyle8" x="1408" y="832" width="448" text="陨息冻雨-妨害"/>
	<mx:Image source="Image24.png" x="1268" y="843" width="128" height="128"/>
