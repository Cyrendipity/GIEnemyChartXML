	<mx:Text styleName="textStyle12" x="1408" y="448" width="448" text="灰流烬泪-蓄力"/>
	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="奥奇坎进行右划攻击，其分别造成40%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="512" width="448" alpha="0.9" text="奥奇坎身转一圈，造成50%,25%伤害，接着朝玩家方向突进一段距离，造成55%,11%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="800" width="448" alpha="0.9" text="奥奇坎朝前方扇形区域喷吐怨流焚火，持续造成60%伤害。"/>
