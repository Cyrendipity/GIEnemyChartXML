	<mx:Text styleName="textStyle12" x="1408" y="224" width="448" alpha="0.9" text="魔龙连续发射4枚火球，每枚造成50%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="800" width="448" alpha="0.9" text="魔龙伏地进行蓄力，在其周围产生3枚凝露，此时其身覆有虚界护罩；10s后吸收凝露并发动震地攻击，造成80%伤害，爆炸还将扩散到凝露所在的位置。"/>
	<mx:Text styleName="textStyle13" x="1408" y="160" width="448" text="烬星飞火-远程"/>
	<mx:Text styleName="textStyle13" x="736" y="736" width="448" text="秽炎凝露-蓄力"/>
	<mx:Text styleName="textStyle12" x="736" y="224" width="448" alpha="0.9" text="魔龙进行右划攻击，其分别造成40%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="512" width="448" alpha="0.9" text="处于魔龙侧方或后方时， 魔龙自身转一圈，造成50%伤害。"/>
	<mx:Text styleName="textStyle12" x="1408" y="512" width="448" alpha="0.9" text="魔龙朝前方扇形区域喷吐怨流焚火，持续造成60%伤害。"/>
