	<mx:Text styleName="textStyle3" x="1408" y="224" width="448" alpha="0.9" text="若上述技能被小龙遏制，则该爪与小龙将对峙10s，期间另外一爪化为大炮，持续向角色发射火球，造成30%伤害。对峙结束后猛地造成100%伤害。对峙期间若进行5次攻击，可直接使护罩-85%。"/>
	<mx:Text styleName="textStyle4" x="736" y="160" width="448" text="型装擘爪-输出"/>
	<mx:Text styleName="textStyle4" x="1408" y="160" width="448" text="峙以烬攻-远程"/>
