	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="巴窟纳瓦重重锤下右拳，对玩家进行重拳出击，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="失去双臂后，巴窟纳瓦从断臂处射出数十枚冰棘，并朝着玩家如数散落，造成70%伤害(难以命中)；冰棘在一段时间后引爆，造成50%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="霜炙随巨浪-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="608" width="448" text="霏雪压荒渊-爆发"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="寒锋遮晴霁-远程"/>
