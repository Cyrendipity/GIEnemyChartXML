	<mx:Text styleName="textStyle" x="64" y="352" width="484" text="深邃拟态·风行丘丘游侠"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="544" width="340" text="虚界浮灭气泡"/>
