	<mx:Image source="Image4.png" x="64" y="941" width="484" height="124"/>
	<mx:Text styleName="textStyle9" x="1408" y="800" width="448" alpha="0.9" text="拟态风丘丘游侠将进行一次闪现，显形时立即无视条件施放以下1个技能的强化版本：「风旋居合」。"/>
	<mx:Text styleName="textStyle10" x="1408" y="736" width="448" text="真伪未归-强化"/>
	<mx:Text styleName="textStyle9" x="736" y="224" width="448" alpha="0.9" text="风丘丘游侠快速发射3个风手里剑，前两个较小的均造成60%伤害，第三枚较大的造成85%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="512" width="448" alpha="0.9" text="风丘丘游侠使用匕首进行居合旋斩，每段分别造成80%伤害。强化版本命中将施加12级「蚀破」。"/>
	<mx:Text styleName="textStyle9" x="736" y="800" width="448" alpha="0.9" text="风丘丘游侠借助风史莱姆悬浮空中，在空中用匕首进行3段普通攻击，每段分别造成80%,80%,100%伤害，每段还会斩出伤害相同的风刃。用非风元素攻击风史莱姆可瘫痪游侠。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="风行忍镖-远程"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" text="风旋居合-远程"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" text="断界刀风-远程"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="俎玉短刃-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" text="巨刃回旋-输出"/>
	<mx:Text styleName="textStyle9" x="1408" y="224" width="448" alpha="0.9" text="风丘丘游侠使用匕首进行至多3段的普通攻击，每段分别造成60%,60%,80%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="512" width="448" alpha="0.9" text="风丘丘游侠扔出一枚较大的风手里剑，其会飞回来，接触造成85%伤害。"/>
