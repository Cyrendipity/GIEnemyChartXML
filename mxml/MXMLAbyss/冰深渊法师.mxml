	<mx:Text styleName="textStyle8" x="64" y="1008" width="448" alpha="0.75" text="冰护罩：12冻盾，击破后打断并虚弱，可伤害转化。该状态下，抗打断0，免疫风场力。"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="冻冰结嶂-防御"/>
	<mx:Text styleName="textStyle9" x="1408" y="416" width="448" text="寒旋之仪-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="靠近施法的冰法时，冰法生成一个12元元素量的冰护罩，火元素破盾最快。防护强化：护盾盾量x2，玩家攻击护盾会被附着冰元素。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="冰法施法恢复冻盾，期间产生3层旋转的冰锥，接触造成70%伤害，每层3个冰锥，旋转方向互不相同，盾生成后施放冲击波造成150%伤害，若处在近处，则额外再受到200%伤害。"/>
	<mx:Text styleName="textStyle11" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="冰法施放一个冰块，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="冰法施法，在玩家处召唤下落的冰锥，造成100%伤害，持续3次。强攻强化：冰锥下落产生持续20s的冰雾，接触持续造成30%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" alpha="0.9" text="冰法传送，出现在玩家正前方，同时造成100%伤害，近处受玩家攻击时概率传送远离玩家，盾破之后持续攻击有小概率闪现。灵动强化：闪现前后位置均造成相同伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="冰棘锐刺-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="凝华祭法-爆发"/>
