	<mx:Text styleName="textStyle" x="64" y="384" width="436" text="深渊咏者·渊火"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="416" text="漆黑渊薮的噬身之火"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：PP[0x2],PO[66,33]"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="305" text="HP: 294121 (8.0H)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 11080 (4.5B1)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 150/840"/>
	<mx:Text styleName="textStyle8" x="64" y="446" width="415" alpha="0.75" text="Abyss Lector: Fathomless Flames"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="The Devouring Benthic Flame"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="渊火伸手从天落下大火球，掷向玩家，造成66.6%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="燔土焦痕-输出"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="渊火召唤5个小火球，依次朝玩家发射，每个火球都造成26.6%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="渊火汇聚火元素力量，蓄力产生爆炸，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="当渊火的生命值低于20%时，踉跄并释放大范围的爆炸，造成133.3%伤害，并附属赤烬加护，使用水破盾最有效，盾破后渊火立即死亡。"/>
	<mx:Text styleName="textStyle10" x="736" y="992" width="448" alpha="0.9" text="渊火持续操作黯火炉心，其不断在场上产生3批一组的火喷，火喷的效果同样会造成「烙火」效果。施放10组火喷后停止施放并摧毁黯火炉心。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="渊火从空中降下炎心之陨，坠地爆炸，造成66.6%伤害，并留下黯火炉心。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="烬燃余焰-远程"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="曝灰成烬-猛攻"/>
	<mx:Text styleName="textStyle11" x="1408" y="608" width="448" text="灼渊之火-防护"/>
	<mx:Text styleName="textStyle11" x="736" y="928" width="448" text="黯之炉火-爆发"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="嗔理天兆-召唤"/>
	<mx:Text styleName="textStyle13" x="64" y="1008" width="448" alpha="0.75" text="赤烬加护：72火盾，击破后渊火立即死亡，可伤害转化。该状态下，抗打断0，免疫风场力。黯火炉心：12火盾，击破后反噬渊火12盾量，并暂时打断技能施放。"/>
