	<mx:Text styleName="textStyle" x="64" y="384" width="467" text="深渊咏者·紫电"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="417" text="降下紫电的福音使者"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：EP[0x2],EO[66,33]"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="305" text="HP: 294121 (8.0H)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 11080 (4.5B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 150/840"/>
	<mx:Text styleName="textStyle8" x="64" y="446" width="395" alpha="0.75" text="Abyss Lector: Violet Lightning"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="Evangelist of Striking Thunder"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="紫电进行吟唱，发动1-2道沿直线行进的落雷，造成53.3%,26.65%伤害；二阶段后有2道落雷。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="紫电拨动法器，发动1至4道落雷，落雷会预判玩家位置，每道落雷造成66.6%伤害；处在第几阶段就施放几道落雷。"/>
	<mx:Text styleName="textStyle10" x="736" y="800" width="448" alpha="0.9" text="当紫电的生命值低于20%时，踉跄并施放大范围雷爆造成133.3%伤害，并附属紫霆加护，使用火、冰和草破盾更快，盾破后紫电立即死亡。"/>
	<mx:Text styleName="textStyle10" x="1408" y="800" width="448" alpha="0.9" text="紫电召唤8个雷球，围绕自己旋转，之后向八个方向飞出，均造成33.3%伤害，雷球命中同样造成「紊雷」效果。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="靠近紫电时，紫电进行短暂吟唱，然后产生雷暴，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="紫电在召唤3个雷球，从左向右依次朝玩家发射，依次造成33.3%,16.6%,8.33%伤害，命中造成「紊雷」效果：命中角色后，若角色未被护盾有效庇护，则扣除20元素能量(特殊能量不受影响)。1s内至多触发一次效果。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="织线络雷-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="416" width="448" text="翻卷覆雷-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="736" width="448" text="斫渊之雷-防护"/>
	<mx:Text styleName="textStyle11" x="1408" y="736" width="448" text="雳索八方-爆发"/>
	<mx:Image source="Image5.png" x="1268" y="747" width="128" height="128"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="曝虚成影-猛攻"/>
	<mx:Text styleName="textStyle11" x="1408" y="416" width="448" text="化能霰珠-妨害"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle13" x="64" y="1008" width="448" alpha="0.75" text="紫霆加护：36雷盾，击破后紫电立即死亡，可伤害转化。该状态下，抗打断0，免疫风场力。"/>
