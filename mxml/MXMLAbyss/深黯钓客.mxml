	<mx:Text styleName="textStyle5" x="64" y="816" width="375" text="SHD: 332760 (200%)"/>
	<mx:Text styleName="textStyle5" x="64" y="768" width="375" text="Wt/Ed: 75/150"/>
	<mx:Text styleName="textStyle7" x="64" y="465" width="395" alpha="0.75" text="Fisher of Hidden Depths"/>
	<mx:Image source="Image4.png" x="64" y="909" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="钓客进行一段爪击，造成40%伤害。增幅后，强化为颃以辉翼，进行一段爪击与一段敲击，依次造成50%,70%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="钓客发射长程激光，持续造成60%,18%,6%伤害。增幅后，强化为恒晦危光，并可发射两次，第一次造成75%,22.5%,7.5%伤害，第二次造成90%,27%,9%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="448" alpha="0.9" text="钓客进行一段冲刺，造成80%伤害。强化为衍妄之羁，冲刺距离加长，造成100%伤害；非强化状态下为罕见技。"/>
	<mx:Text styleName="textStyle9" x="736" y="192" width="448" text="颉以盔翎-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="长喙微光-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="672" width="448" text="自绐之行-位移"/>
	<mx:Text styleName="textStyle10" x="64" y="512" width="305" text="异界栖兽"/>
	<mx:Text styleName="textStyle11" x="64" y="555" width="395" alpha="0.75" text="Eyrie Beast of Another World"/>
	<mx:Text styleName="textStyle12" x="0" y="991" width="64" text="正常"/>
	<mx:Text styleName="textStyle8" x="736" y="960" width="448" alpha="0.9" text="钓客会一同展开「深黯护盾」，该护盾为生命盾，并且只接受元素伤害，免疫物理伤害；月曜伤害将造成原来300%的伤害。在场钓客少于2个时不能开启护盾，且进攻性下降；非深渊特化的个体，第二次及之后展开护盾，盾量只有原来的1/4。"/>
	<mx:Text styleName="textStyle13" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
