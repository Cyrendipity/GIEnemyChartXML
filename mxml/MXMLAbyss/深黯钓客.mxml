	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="864" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="576" y="128" width="549" alpha="0.5" text="元素能量：WP[66,33,0] ; NA(黯主召唤)"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="305" text="HP: 166380 (3.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="640" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
