	<mx:Image source="Image4.png" x="64" y="941" width="484" height="124"/>
	<mx:Text styleName="textStyle9" x="736" y="1152" width="448" alpha="0.9" text="拟态遗迹守卫将进行一次闪现，显形时立即无视条件施放以下2个技能的随机一个强化版本：「占位并掌」/「古法制导」。"/>
	<mx:Text styleName="textStyle10" x="736" y="1088" width="448" text="虚魂之偃-强化"/>
	<mx:Image source="Image5.png" x="64" y="64" width="256" height="256"/>
	<mx:Text styleName="textStyle9" x="736" y="256" width="448" alpha="0.9" text="遗迹守卫进行3段普通攻击：右拳挥、转身挥、落地，其依次造成50%,75%,100%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="480" width="448" alpha="0.9" text="遗迹守卫进行至多2段的攻击：跺脚、拍击，其依次造成62.5%,87.5%伤害。强化版本命中将施加15级「蚀破」。"/>
	<mx:Text styleName="textStyle9" x="736" y="704" width="448" alpha="0.9" text="处在较远处时，遗迹守卫转身，瞄准玩家发射6枚导弹，均造成31.25%伤害。强化版本命中将施加4级「蚀破」。"/>
	<mx:Text styleName="textStyle9" x="736" y="928" width="448" alpha="0.9" text="遗迹守卫旋转上半身，不断朝玩家走来，触碰高频造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="192" width="448" text="身旋机坠-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="416" width="448" text="占位并掌-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="640" width="448" text="古法制导-远程"/>
	<mx:Text styleName="textStyle10" x="736" y="864" width="448" text="耕土犁地-输出"/>
