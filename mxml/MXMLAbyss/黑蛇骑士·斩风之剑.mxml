	<mx:Text styleName="textStyle" x="64" y="384" width="479" text="黑蛇骑士·斩风之剑"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1387" y="64" width="469" alpha="0.5" text="元素能量：AP[66x2,33x2,0x2]"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="305" text="HP: 388220 (7.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="640" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="720" width="375" text="ATK: 12311 (5.0B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="768" width="375" text="Wt/Ed: 150/210"/>
	<mx:Text styleName="textStyle7" x="64" y="436" width="458" alpha="0.75" text="Black Serpent Knight: Windcutter"/>
	<mx:Image source="Image3.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="斩风侧举大剑，进行至多3段的普通攻击，依次造成60%,80%,80%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="斩风扯开大剑，转身甩出6个旋转的碎片，造成40%,16%,4%伤害，然后再收回，甩出和收回均造成60%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="448" alpha="0.9" text="斩风抖开大剑，然后朝前方猛击，每个造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="风挥净除-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="刃开面裁-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="672" width="448" text="重链碎击-输出"/>
	<mx:Image source="Image4.png" x="596" y="683" width="128" height="128"/>
	<mx:Image source="Image5.png" x="576" y="662" width="168" height="170"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="倏走风剑-输出"/>
	<mx:Text styleName="textStyle9" x="1408" y="416" width="448" text="追风碎刃-远程"/>
	<mx:Text styleName="textStyle9" x="1408" y="672" width="448" text="挟风斩雨-天赋"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="斩风拿着大剑蓄力，进行至多2段的普通攻击，都造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="480" width="448" alpha="0.9" text="斩风正举大剑，将6个剑刃碎片依次发射出来，每个造成30%伤害。该状态下，抗打断0。"/>
	<mx:Text styleName="textStyle8" x="1408" y="736" width="448" alpha="0.9" text="当斩风的攻击命中护盾庇护下的的玩家时，扣除当前15%生命值，自己将获得一层「敏捷」：受攻击时闪现免伤，闪现后获得30%攻击力提升，该提升在造成一次伤害或施放完一次技能后消失。「敏捷」会在闪现一次后或者持续10s后消失，至多叠加一层。"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="64" y="512" width="458" text="「曾经行于微风之中…」"/>
	<mx:Text styleName="textStyle12" x="64" y="555" width="395" alpha="0.75" text="“Once Upon a Gentle Wind...”"/>
