	<mx:Text styleName="textStyle" x="64" y="384" width="447" text="嗜岩·兽境猎犬"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="305" text="隙间侵入的异兽"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：GP[66x2,33x2,0x2]"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="305" text="HP: 388220 (7.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 7879 (3.2B1)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 150/210"/>
	<mx:Text styleName="textStyle8" x="64" y="446" width="395" alpha="0.75" text="Rockfond Rifthound"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="Gap-Infiltrating Aliens"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="猎犬突然后撤，随后直接冲向玩家咬合，造成90%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="猎犬后空翻消失，传送至玩家身后使用尾部击打造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="每受到一次直接岩元素伤害，其怒气值就增长20%，值满时猎犬的外观发生明显变化，永久进入嗜魔状态，以岩抗减至-40%为代价提升攻击频率。"/>
	<mx:Text styleName="textStyle11" x="736" y="896" width="448" alpha="0.9" text="(幼兽在场时施放)猎犬朝空中咆哮一下，赋予30m附近的任意幼兽25%的攻击力提升，持续10s，可叠加2层，每层持续时间独立计算。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="猎犬在近处进行左右两段划击攻击，两段攻击均造成85%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="距离玩家较远时，猎犬使蓄力吐出一枚弱追踪岩晶，造成95%伤害。"/>
	<mx:Text styleName="textStyle12" x="1408" y="672" width="448" alpha="0.9" text="(嗜魔施放)猎犬后空翻朝玩家快速冲过来，造成85%伤害，持续3轮。"/>
	<mx:Text styleName="textStyle13" x="736" y="160" width="448" text="涎齿啮合-位移"/>
	<mx:Text styleName="textStyle13" x="736" y="384" width="448" text="长尾蛰击-位移"/>
	<mx:Text styleName="textStyle14" x="736" y="608" width="448" text="嗜岩之碿-天赋"/>
	<mx:Text styleName="textStyle13" x="736" y="832" width="448" text="群狼天嗥-辅助"/>
	<mx:Text styleName="textStyle13" x="1408" y="160" width="448" text="兽性抓划-输出"/>
	<mx:Text styleName="textStyle14" x="1408" y="384" width="448" text="琢瑀衔晶-输出"/>
	<mx:Text styleName="textStyle13" x="1408" y="608" width="448" text="卷啸腾涌-妨害"/>
