	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="雷法施放一个雷球，造成60%伤害。强攻强化：施放的雷球有弱追踪性。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="雷法施法，召唤一个雷环造成80%伤害，雷环围绕自己，持续3s，接触造成80%伤害。强攻强化：接触伤害提升至100%伤害，持续时间延长至6s。"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="448" alpha="0.9" text="雷法传送，出现在玩家正前方，同时造成100%伤害，近处受玩家攻击时概率传送远离玩家，盾破之后持续攻击有小概率闪现。强攻强化：有盾情况下，闪现完毕即产生雷环。"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="靠近施法的雷法时，雷法生成一个8元素量的雷护罩，火元素、冰元素、草元素均可快速破盾。防护强化：护盾盾量x2，玩家攻击护盾会被附着雷元素。"/>
	<mx:Text styleName="textStyle8" x="1408" y="480" width="448" alpha="0.9" text="雷法施法恢复雷盾，期间不断召唤产生四方向的雷球，造成40%伤害，盾生成后施放冲击波造成120%伤害，若处在近处，则额外再受到160%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="球状闪电-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="缠光祭法-爆发"/>
	<mx:Text styleName="textStyle9" x="736" y="672" width="448" text="霄闪-位移"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="气雷晕嶂-防御"/>
	<mx:Text styleName="textStyle9" x="1408" y="416" width="448" text="滚骤之仪-输出"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="64" y="1008" width="448" alpha="0.75" text="雷护罩：8雷盾，击破后打断并虚弱，可伤害转化。该状态下，抗打断0，免疫风场力。"/>
