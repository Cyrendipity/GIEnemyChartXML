	<mx:Text styleName="textStyle9" x="736" y="224" width="448" alpha="0.9" text="狂狩士将手中的蚀斧丢出，造成80%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="224" width="448" alpha="0.9" text="狂狩士从敞开心扉持续发射魔火，持续造成50%,25%,12.5%,6%,5%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="512" width="448" alpha="0.9" text="狂狩士突然握爪朝前突进袭击玩家，造成80%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="800" width="448" alpha="0.9" text="狂狩士抻直斧头，进行两段重击，依次造成60%,100%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="512" width="448" alpha="0.9" text="狂狩士先是发出嘲吼，紧接着利用蚀斧和利爪进行旋、抓、扫至多3段的普通攻击，依次造成80%,60%,100%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="800" width="448" alpha="0.9" text="狂猎血条清空之后不会立即死亡，而是进入临界状态，持续10s；期间受到的部分伤害会削减生命上限，状态结束后狂猎将直接恢复至生命上限，将不再能削减上限。月兆处于「满辉」的队伍，进行被「满辉」强化的攻击能直接使其进入10s的「失色哀恸」状态。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="猎火将狩-远程"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="敞阔心怀-远程"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" text="褫心厄爪-位移"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" text="弑意灾魂-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" text="幽狂秽舞-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="736" width="448" text="消逝哀色-天赋"/>
	<mx:Text styleName="textStyle11" x="64" y="1040" width="448" alpha="0.75" text="临界状态：见「荒野幽徒」。"/>
