	<mx:Text styleName="textStyle11" x="1408" y="1632" width="448" alpha="0.9" text="(雷元素盾)深罪浸礼者离场地较远时，或者要返回中心，安置核心时，会通过倒三角的传送门闪现(类似于藏镜仕女)。"/>
	<mx:Text styleName="textStyle15" x="1408" y="1568" width="448" text="待轻静的隐逸-闪避"/>
