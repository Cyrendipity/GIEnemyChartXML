	<mx:Text styleName="textStyle9" x="1408" y="800" width="448" alpha="0.9" text="拟态寻捕械将进行一次闪现，显形时立即无视条件施放以下3个技能的随机一个强化版本：「旧阳皆彗」/「啮铁流星」/「月余辉烨」。"/>
	<mx:Text styleName="textStyle10" x="1408" y="736" width="448" text="玄影残闪-强化"/>
	<mx:Text styleName="textStyle9" x="736" y="224" width="448" alpha="0.9" text="寻捕械推出一个排满尖牙的排斥装甲，造成80%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="224" width="448" alpha="0.9" text="寻捕械朝天发射一束高能脉冲，其持续打击地面，持续造成70%,35%,14%,7%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="512" width="448" alpha="0.9" text="寻捕械朝玩家发射连续的集中热能激光，持续造成60%伤害，至多3次。强化版本命中将施加12级「蚀破」。"/>
	<mx:Text styleName="textStyle9" x="1408" y="512" width="448" alpha="0.9" text="距离较远时，寻捕械突然朝玩家发动赤牙合击，造成80%伤害。强化版本命中将施加18级「」。"/>
	<mx:Text styleName="textStyle9" x="736" y="800" width="448" alpha="0.9" text="寻捕械发射持续5s的集束激光，持续造成100%,10%伤害。强化版本命中将施加6级「蚀破」。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="炽烙赤遣-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="日煜天基-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" text="月余辉烨-远程"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" text="啮铁流星-位移"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" text="旧阳皆彗-爆发"/>
