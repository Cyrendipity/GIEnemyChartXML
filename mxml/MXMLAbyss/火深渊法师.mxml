	<mx:Image source="Image3.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="靠近施法的火法时，火法生成一个12元元素量的火护罩，水元素破盾最快。防护强化：护盾盾量x2，玩家攻击护盾会被附着火元素。"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="敕火戒嶂-防御"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="火法施放一个贴近地面的火团，造成50%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="火法施法，召唤三个一组的灼面，灼面朝中间吐火，造成66.6%,33.3%,16.6%伤害，持续5次。强攻强化：召唤3组灼面进行攻击。"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="448" alpha="0.9" text="火法传送，出现在玩家正前方，同时造成66.6%伤害，近处受玩家攻击时概率传送远离玩家，盾破之后持续攻击有小概率闪现。灵动强化：闪现前后位置均造成相同伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="480" width="448" alpha="0.9" text="火法施法恢复火盾，期间不断召唤火喷造成100%伤害，盾生成后施放冲击波造成100%伤害，若处在近处，则额外再受到133.3%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="炎心焰波-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="灼面祭法-爆发"/>
	<mx:Text styleName="textStyle9" x="736" y="672" width="448" text="嚣闪-位移"/>
	<mx:Text styleName="textStyle9" x="1408" y="416" width="448" text="焰涌之仪-输出"/>
	<mx:Text styleName="textStyle11" x="64" y="1008" width="448" alpha="0.75" text="火护罩：12火盾，击破后打断并虚弱，可伤害转化。该状态下，抗打断0，免疫风场力。本体免疫燃烧伤害。"/>
	<mx:Text styleName="textStyle12" x="64" y="512" width="416" text="火之咏者"/>
