	<mx:Text styleName="textStyle" x="64" y="480" width="460" text="黄金王兽"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="1224" width="448" alpha="0.75" text="兽王加冕：3次特化次数盾，仅能使用兽境犬首击破，需要3只，击破后瘫痪黄金王兽10s。兽境犬首：75岩充能盾，岩攻击+25/次，非岩攻击+2/次。"/>
	<mx:Text styleName="textStyle4" x="64" y="608" width="434" text="无名的兽境之王"/>
	<mx:Text styleName="textStyle5" x="64" y="928" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle6" x="1216" y="64" width="640" alpha="0.5" text="元素能量：WP[75,50,25,0],WO[75,50,25,0]"/>
	<mx:Text styleName="textStyle7" x="64" y="768" width="305" text="HP: 731221 (12.0F)"/>
	<mx:Text styleName="textStyle8" x="64" y="736" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle7" x="64" y="816" width="375" text="ATK: 20886 (8.0B2)"/>
	<mx:Text styleName="textStyle7" x="64" y="864" width="375" text="Wt/Ed: 1000/4000"/>
	<mx:Text styleName="textStyle9" x="64" y="561" width="395" alpha="0.75" text="Golden Wolflord"/>
	<mx:Text styleName="textStyle10" x="64" y="651" width="407" alpha="0.75" text="Nameless King of the Rift"/>
	<mx:Image source="Image4.png" x="64" y="973" width="484" height="124"/>
	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="黄金王兽蓄力向地面冲去，在地面进行8字形擦地移动，碰到造成50%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" alpha="0.9" text="黄金王兽蓄力，贴近地面喷吐渊之岩，接触持续造成50%,12.5%,5%伤害，可与某些技能形成连招。"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" alpha="0.9" text="黄金王兽升空停顿，连续召唤3个「黄金犬首」追踪玩家，每个犬首造成25%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="928" width="448" alpha="0.9" text="黄金王兽飞到高空，高速下落坠入地面造成巨大范围的100%伤害，片刻后钻出，造成无侵蚀的25%伤害，随后在场地内产生9个小岩喷造成25%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="928" width="448" alpha="0.9" text="由黄金王兽召唤的「兽境犬首」，其会周期性喷吐蓝色的「渊弹」，「渊弹」发射1s后开始追踪玩家，碰到造成12.5%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="1152" width="448" alpha="0.9" text="兽境类原魔造成的伤害都会附带「侵蚀」效果。黄金王兽的效果为：每层每秒扣除玩家(1%HP+25)的生命值，每层持续9.5s，持续时间独立计算，可叠加。"/>
	<mx:Text styleName="textStyle11" x="736" y="1152" width="448" alpha="0.9" text="黄金王兽在破盾眩晕后起身旋会击飞附近的玩家，造成无侵蚀的10%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" alpha="0.9" text="黄金王兽移至场地中央，获得兽王加冕，进入嗜魔状态，外观发生变化，并于场地边缘安置3个「兽境犬首」，若被该犬首命中则造成50%伤害，嗜魔后的黄金王兽的攻击力提升30%。"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="黄金王兽原地开始旋转，形成巨大的龙卷风，在场地内来游动，碰到造成50%,12.5%,5%伤害，旋转结束时会额外造成12.5%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" alpha="0.9" text="黄金王兽升空，在空中悬停一会后立即使用尾部扫击，造成50%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="岩游遗迹-位移"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="蚀岩之流-迫害"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="黄金犬首-追踪"/>
	<mx:Text styleName="textStyle12" x="736" y="864" width="448" text="铄金天罚-爆发	 嗜魔"/>
	<mx:Text styleName="textStyle12" x="736" y="1088" width="448" text="怅然复起-恢复	 嗜魔"/>
	<mx:Text styleName="textStyle12" x="1408" y="608" width="448" text="兽境王权-强化	 嗜魔"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="蚀尘龙卷-强攻"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="返后倾尾-防卫"/>
