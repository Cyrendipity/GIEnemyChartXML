	<mx:Text styleName="textStyle" x="64" y="352" width="506" text="愚人众·藏镜仕女"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle3" x="1387" y="64" width="469" alpha="0.5" text="元素能量：WO[66,33,0]"/>
	<mx:Text styleName="textStyle4" x="64" y="672" width="305" text="HP: 332760 (6.0F)"/>
	<mx:Text styleName="textStyle5" x="64" y="640" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle4" x="64" y="720" width="375" text="ATK: 5909 (2.4B1)"/>
	<mx:Text styleName="textStyle4" x="64" y="768" width="375" text="Wt/Ed: 80/150"/>
	<mx:Text styleName="textStyle6" x="64" y="465" width="428" alpha="0.75" text="Fatui Mirror Maiden"/>
	<mx:Image source="Image3.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle7" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle8" x="736" y="160" width="448" text="依附之潮-妨害"/>
	<mx:Text styleName="textStyle8" x="736" y="384" width="448" text="苦水之牢-限制"/>
	<mx:Text styleName="textStyle8" x="736" y="608" width="448" text="净水之弹-追踪"/>
	<mx:Text styleName="textStyle8" x="736" y="832" width="448" text="水光破镜-天赋"/>
	<mx:Text styleName="textStyle8" x="1408" y="160" width="448" text="排斥之水-反击"/>
	<mx:Text styleName="textStyle8" x="1408" y="384" width="448" text="寒凛之花-反击"/>
	<mx:Text styleName="textStyle9" x="1408" y="608" width="448" text="折镜迴光-爆发"/>
	<mx:Text styleName="textStyle8" x="1408" y="832" width="448" text="镜洁之刻-位移"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="镜女扔出3个水镖，落在附近地面上，然后水镖爆炸造成62.5%伤害，并标记玩家。"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" alpha="0.9" text="「水光破镜」状态下，镜女在玩家脚下生成水纹，1s后生成水笼包裹玩家造成12.5%伤害，然后紧接着再施放一个技能。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="镜女扔出1-2个直线水弹，各造成62.5%伤害；若处于「水光破镜」状态下，则扔出3个强追踪水弹，各造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="镜女成功标记玩家后，即永久进入「水光破镜」状态。该状态下，镜女免疫风场力，抗打断0.1。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="10s内，持续攻击镜女7次及以上时，镜女会进行反击，在身边产生一次水爆，造成93.75%伤害，并标记玩家。"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" alpha="0.9" text="「水光破镜」状态下，镜女召唤下落的水花，造成62.5%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" alpha="0.9" text="「水光破镜」状态下，镜女召唤水棱镜阵瞄准玩家，折射水线造成8段16.25%伤害，最后产生水爆造成97.5%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="896" width="448" alpha="0.9" text="若镜女离玩家太远，则会后退进入水镜中再出现在玩家面前，若镜女就在玩家面前，则会后退进入水镜中大概率出现在玩家身后。"/>
	<mx:Text styleName="textStyle12" x="64" y="512" width="417" text="冬国仕女·水镜的使者"/>
	<mx:Text styleName="textStyle13" x="64" y="555" width="395" alpha="0.75" text="Snezhnayan Maiden: Mirror Envoy"/>
