	<mx:Text styleName="textStyle" x="64" y="352" width="519" text="愚人众先遣队·雷锤前锋军"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle" x="64" y="768" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle3" x="576" y="128" width="469" alpha="0.5" text="元素能量：EP[66x2,33x2,0x2]"/>
	<mx:Text styleName="textStyle4" x="64" y="608" width="305" text="HP: 147060 (4.0H)"/>
	<mx:Text styleName="textStyle5" x="64" y="576" width="305" alpha="0.75" text="普通 Lv.100 Data"/>
	<mx:Text styleName="textStyle4" x="64" y="656" width="375" text="ATK: 14773 (6.0B1)"/>
	<mx:Text styleName="textStyle4" x="64" y="704" width="375" text="Wt/Ed: 150/210"/>
	<mx:Text styleName="textStyle6" x="64" y="465" width="395" alpha="0.75" text="Fatui Skirmishers: Electrohammer Vanguard"/>
	<mx:Image source="Image4.png" x="64" y="813" width="484" height="124"/>
	<mx:Text styleName="textStyle7" x="736" y="256" width="448" alpha="0.9" text="雷锤举起大锤，进行3段的普通攻击，三段普攻分别造成46.6%,46.6%,66.6%伤害。强化技：三段普攻分别造成66.6%,66.6%,100%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="512" width="448" alpha="0.9" text="距离雷锤较远时，雷锤抡锤冲来并锤击；冲刺造成33.3%伤害，锤击造成66.6%伤害。强化技：冲刺造成50%伤害，锤击造成100%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="768" width="448" alpha="0.9" text="开场一段时间后，或雷锤半血以下，雷锤进入元素增幅状态：全抗提升100%，附属雷御特化盾，有效元素是冰。"/>
	<mx:Text styleName="textStyle8" x="736" y="192" width="448" text="震光雷锤-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" text="曳光雷袭-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" text="马上了结-强化"/>
	<mx:Text styleName="textStyle9" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="64" y="1004" width="448" alpha="0.75" text="雷御：8雷盾，雷冰为1:1，其他所有反应均是1:10；免疫感电；击破可暂时瘫痪。该状态下，抗打断为0，重量翻6倍。"/>
