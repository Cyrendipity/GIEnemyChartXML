	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="靠近火刃时，中尉立即一个拔刀突袭，造成70%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="火刃架起火长枪，朝玩家发射连续3波的火焰弹，前两波造成50%,5%伤害，第三波造成80%,8%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" alpha="0.9" text="火刃冲击而来，并顺势对地猛击，依次造成50%,90%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" alpha="0.9" text="火刃启动武器，进行长达6段的持续攻击，依次造成40%,50%,40%,50%,70%,100%伤害。武器属「单极」物件，可被月矩力干扰。"/>
