	<mx:Text styleName="textStyle" x="64" y="352" width="466" text="超重型陆巡舰·机动战垒"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="544" width="416" text="全地形战争机关"/>
	<mx:Text styleName="textStyle" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1387" y="64" width="469" alpha="0.5" text="元素能量：WO[75,50,25,0]"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="384" text="HP: 1340572 (22.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="640" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="720" width="375" text="ATK: 20886 (8.0B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="768" width="375" text="Wt/Ed: 20000/4000"/>
	<mx:Text styleName="textStyle7" x="64" y="465" width="395" alpha="0.75" text="Super-Heavy Landrover: Mechanized Fortress"/>
	<mx:Text styleName="textStyle8" x="64" y="587" width="395" alpha="0.75" text="All-Terrain Combat Mek"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle9" x="1408" y="224" width="448" alpha="0.9" text="陆巡舰使用攻坚锯进行两次来回挥锯，依次造成50%,60%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="768" width="448" alpha="0.9" text="处于陆巡舰后方时，陆巡迅速使用攻坚锯挥舞一圈，造成1-2次60%伤害，随后起飞并转身面朝玩家，缓缓落地，造成70%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="1056" width="448" alpha="0.9" text="自身存在「高热」计量条，满计量600点。陆巡舰在受到火元素攻击后，将积攒5高热，每额外n单位火元素额外积攒5n高热，计量过半后进入「红温过载」状态，计量满后进行「降控温御」，持续减少高热计量。本高热计量不受冰水影响。"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="赤铦华光-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="704" width="448" text="逆折穿壑-位移"/>
	<mx:Text styleName="textStyle11" x="1408" y="992" width="448" text="温变热媒-天赋"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle9" x="736" y="224" width="448" alpha="0.9" text="交替进行下列两种攻击：陆巡舰使用舰炮轰击，造成70%伤害；陆巡舰使用攻坚锯进行一次挥锯，造成60%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="1056" width="448" alpha="0.9" text="未成功击破护罩时，陆巡舰升空，利用舰炮轰击，造成100%伤害并留下冰地面；随后利用攻坚锯下劈重重坠落，造成150%伤害；落地后持续切锯造成25%伤害；坠落时将冰地面替换为持续12s的火地面，并持续造成6%伤害；升空与坠落伤害闪避帧均无法躲避。"/>
	<mx:Text styleName="textStyle13" x="64" y="1128" width="448" alpha="0.75" text="深渊抗性：正常150%，红温过载状态50%，瘫痪为-20%。高热：满计量600点。受到火元素攻击后，积攒0.833%(5)高热，每额外1U火元素量积攒0.833%(5)高热，计量过半后进入「红温过载」状态，计量满后进行「降控温御」。散热套件：28冻盾，持续18s，存在期间将持续减少高热计量条，击破后瘫痪16s，填满热量，全抗下降，恢复后清空热量。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="烈铓残霜-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="992" width="448" text="断明颓敝-爆发"/>
