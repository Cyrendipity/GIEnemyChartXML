	<mx:Text styleName="textStyle9" x="736" y="480" width="448" alpha="0.9" text="陆巡舰使用舰炮朝空中发射2枚迫击弹，依次在玩家处落下，造成80%伤害并飞溅出10枚霜核，接触造成40%伤害；此外命中处留下冰地面，持续造成6%伤害，持续12s。"/>
	<mx:Text styleName="textStyle9" x="1408" y="768" width="448" alpha="0.9" text="高热计量满时，陆巡舰立即展开持续18s 的散热套件护罩，持续减少高热计量；若成功击破护罩，则其将立即受到当前30%生命值的火元素真伤并瘫痪15s；否则施放「断明颓敝」，期间抗性不变。"/>
	<mx:Text styleName="textStyle11" x="736" y="416" width="448" text="冰期谶辞-定点"/>
	<mx:Text styleName="textStyle11" x="1408" y="704" width="448" text="降控温御-防护"/>
	<mx:Text styleName="textStyle9" x="1408" y="480" width="448" alpha="0.9" text="处于较远的位置时，陆巡舰起飞并缓缓降落至预警位置，造成100%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="416" width="448" text="驰越崔嵬-位移"/>
