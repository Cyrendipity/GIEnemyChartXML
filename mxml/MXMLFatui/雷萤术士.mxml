	<mx:Text styleName="textStyle9" x="736" y="224" width="448" alpha="0.9" text="场上无雷萤存在时，雷萤术士使用雾虚草灯召唤3只雷萤。"/>
	<mx:Text styleName="textStyle9" x="736" y="480" width="448" alpha="0.9" text="雷萤术士使用雾虚草灯命令雷萤突进，造成20%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="736" width="448" alpha="0.9" text="雷萤术士杀死召唤的雷萤，缓慢升空并附属特斯拉线圈同时产生爆炸，造成100%伤害，并以较快的速度移动，向玩家进行高频电击持续造成25%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="224" width="448" alpha="0.9" text="雷萤术士召唤的雷萤间歇性的向玩家喷吐雷球，造成20%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="480" width="448" alpha="0.9" text="雷萤术士使用雾虚草灯唤出1道落雷，造成100%伤害，落雷留下雷痕地面，接触持续造成25%伤害。攻击强化：召唤至多6道的落雷。"/>
	<mx:Text styleName="textStyle9" x="1408" y="736" width="448" alpha="0.9" text="距离玩家较远时，雷萤术士进行连续4段的传送；距离玩家太近时，传送至玩家后方。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="雷云紫集-召唤"/>
	<mx:Text styleName="textStyle10" x="736" y="416" width="448" text="急速全进-号令"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" text="缠绵之雷-爆发"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="萦雷绕逐-号令"/>
	<mx:Text styleName="textStyle10" x="1408" y="416" width="448" text="循雷迷霄-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" text="电闪烁光-位移"/>
