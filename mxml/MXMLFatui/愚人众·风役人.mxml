	<mx:Text styleName="textStyle" x="64" y="384" width="448" text="愚人众·风役人"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1387" y="64" width="469" alpha="0.5" text="元素能量：AP[75,50,25,0x2]"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="305" text="HP: 388220 (7.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="640" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="720" width="375" text="ATK: 14773 (6.0B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="768" width="375" text="Wt/Ed: 85/100"/>
	<mx:Text styleName="textStyle7" x="64" y="446" width="458" alpha="0.75" text="Wind Operative"/>
	<mx:Image source="Image3.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="风役人施放风弹，进行至多3段的连续攻击，对敌人分别造成50%,50%,60%x2伤害，第三段攻击带有追踪性；攻击造成的伤害带有(1,0.5)的衰减。"/>
	<mx:Text styleName="textStyle8" x="736" y="448" width="448" alpha="0.9" text="风役人展开风嶂，当敌人对其施放攻击时，无视此次伤害并发动反击：闪现至敌人上方投下权杖，造成70%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="1120" alpha="0.9" text="风役人瞄准目标，消耗5%生命值，2s后发动攻击，对目标敌人降下翠雨利叶，造成90%伤害并施加生命之契，若成功施加，则发动追加「猎杀」攻击：翠叶之诀的场地将产生爆炸，造成100%伤害并施加生命之契。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="普通攻击·风余-追踪"/>
	<mx:Text styleName="textStyle9" x="736" y="384" width="448" text="元素战技·杜屏-反击"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" text="元素爆发·玦风翠流-爆发"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="重击·陬花忆现-输出"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="风役人旋转权杖，进行一段重击，在敌人的下方产生风泽域，产生似花棘物，造成100%伤害。"/>
	<mx:Text styleName="textStyle11" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Image source="Image4.png" x="68" y="64" width="252" height="256"/>
	<mx:Text styleName="textStyle8" x="1408" y="448" width="448" alpha="0.9" text="风役人的元素爆发命中所累加的生命之契大小等同于自身16%的攻击力，且在该生命之契的影响下，目标敌人将每秒流失(0.4%HP+72)的生命值(后台停5%)，其与生命之契同生共死，持续10min。"/>
	<mx:Text styleName="textStyle9" x="1408" y="384" width="448" text="固有天赋·入扉-妨害"/>
