	<mx:Text styleName="textStyle6" x="64" y="465" width="395" alpha="0.75" text="Fatui Skirmishers: Hydrogunner Legionnaire"/>
	<mx:Text styleName="textStyle7" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="水胖掏出水枪，瞄准发射一枚水弹，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="水胖拿出水枪，朝附近受伤最多的先遣队队友发射愈疗弹，被治疗目标每0.5s恢复10%生命值，抢断愈疗水球无任何效果。"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" alpha="0.9" text="开场一段时间后，或水胖半血以下，水胖进入元素增幅状态：全抗提升100%，附属水御特化盾，有效元素是雷。"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" alpha="0.9" text="处于增幅前状态时接近水胖，水胖撞出去造成100%伤害。"/>
