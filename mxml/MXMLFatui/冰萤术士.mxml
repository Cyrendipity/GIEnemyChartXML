	<mx:Text styleName="textStyle7" x="64" y="465" width="395" alpha="0.75" text="Fatui Cryo Cicin Mage"/>
	<mx:Text styleName="textStyle8" x="64" y="555" width="395" alpha="0.75" text="Cicin Mage: Hoarfrost Wielder"/>
	<mx:Image source="Image3.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle9" x="64" y="1008" width="448" alpha="0.75" text="萤霜流华：4×(冰萤数量)冻盾，击破没效果。该状态下，抗打断0，免疫风场力。"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="冰眩寒环-号令"/>
	<mx:Text styleName="textStyle10" x="1408" y="416" width="448" text="白绽冰花-爆发"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" text="爱屋及乌-位移"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="冰萤术士召唤的冰萤间歇性的向玩家喷吐冰块，造成20%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="480" width="448" alpha="0.9" text="冰萤术士用雾虚草灯砸击地面，产生范围冰刺，造成75%伤害。攻击强化：产生的冰刺向四个方向溅射，额外造成75%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="736" width="448" alpha="0.9" text="冰萤术士与冰萤一同进行传送位移，传送完毕后冰萤将在原地产生一次冰爆，造成20%伤害。"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="场上无冰萤存在时，冰萤术士使用雾虚草灯召唤3只冰萤。"/>
	<mx:Text styleName="textStyle11" x="736" y="480" width="448" alpha="0.9" text="冰萤术士使用雾虚草灯指挥冰萤，围住玩家或者依次冲向玩家，产生爆破造成20%伤害。此外碰到冲刺中的冰萤也造成20%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="736" width="448" alpha="0.9" text="冰萤术士根据场上自己召唤的冰萤数量，附属不同厚度的萤霜流华护盾，并且场上的冰萤会间歇性为冰萤术士恢复盾量。"/>
	<mx:Text styleName="textStyle13" x="736" y="160" width="448" text="游雾洊冰-召唤"/>
	<mx:Text styleName="textStyle10" x="736" y="416" width="448" text="阵锢集令-号令"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" text="御寒萤华-防御"/>
