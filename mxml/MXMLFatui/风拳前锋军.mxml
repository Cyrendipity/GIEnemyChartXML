	<mx:Text styleName="textStyle6" x="736" y="256" width="448" alpha="0.9" text="风拳朝前打出一拳，造成33.3%伤害。"/>
	<mx:Text styleName="textStyle6" x="736" y="480" width="448" alpha="0.9" text="风拳前锋军立即移动至最近的先遣队队友，并架起风嶂，为后方的队友提供保护，持续5s后放下。"/>
	<mx:Text styleName="textStyle6" x="736" y="704" width="448" alpha="0.9" text="援场聚风蓄力期间，若风嶂受到了火/水/雷/冰/风的攻击，则立即发动反击，吸引前方目标并打出强力一拳，造成对应元素的100%伤害。"/>
	<mx:Text styleName="textStyle6" x="736" y="928" width="448" alpha="0.9" text="当场上存在盾破虚弱的先遣队队友时，风拳走近并打地上一拳，振作队友。"/>
	<mx:Text styleName="textStyle7" x="736" y="192" width="448" text="驱风拳击-输出"/>
	<mx:Text styleName="textStyle7" x="736" y="416" width="448" text="援场聚风-支援"/>
	<mx:Text styleName="textStyle7" x="736" y="640" width="448" text="逆风镇拳-反击"/>
	<mx:Text styleName="textStyle7" x="736" y="864" width="448" text="鼓击打场-支援"/>
