	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="秘源机龙立即进行划、砸2段普通攻击，依次造成75%,70%伤害；第二段攻击可与小龙共鸣展开护罩，遏制攻击行动。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="若上述技能被小龙遏制，则该爪与小龙将对峙10s，期间另外一爪化为大炮，持续向角色发射火球，造成30%伤害。对峙结束后猛地造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" alpha="0.9" text="秘源机龙朝场地内持续喷吐烈焰，逐渐造成15%,20%,30%伤害；可与小龙共鸣展开护罩。"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" alpha="0.9" text="秘源机龙先放射出大量金光织火命中玩家，均造成30%伤害，随后将玩家禁锢，并逐渐持续造成20%,30%,40%伤害。需与小龙共鸣方可解除禁锢状态。"/>
	<mx:Text styleName="textStyle8" x="736" y="1152" width="448" alpha="0.9" text="秘源机龙初始持有秘源护罩，遭受小龙攻击时会额外失去15%，且在小龙对峙期间尝试破盾则会直接损失50%，护罩破坏后秘源机龙损失20%生命值并瘫痪。"/>
	<mx:Text styleName="textStyle9" x="736" y="192" width="448" text="型装擘爪-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="峙以烬攻-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="640" width="448" text="镌焰浊焚-猛攻"/>
	<mx:Text styleName="textStyle9" x="736" y="864" width="448" text="樊金滞纹-限制"/>
	<mx:Text styleName="textStyle9" x="736" y="1088" width="448" text="深古燃铭-天赋"/>
