	<mx:Text styleName="textStyle" x="64" y="480" width="410" text="无相之冰"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="608" width="305" text="「塔勒特」"/>
	<mx:Text styleName="textStyle4" x="64" y="928" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1247" y="64" width="609" alpha="0.5" text="元素能量：CP[0x2],CO[66,33]"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="305" text="HP: 275905 (7.0H)"/>
	<mx:Text styleName="textStyle7" x="64" y="736" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="816" width="375" text="ATK: 15665 (6.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="864" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="561" width="395" alpha="0.75" text="Cryo Hypostasis"/>
	<mx:Text styleName="textStyle9" x="64" y="651" width="395" alpha="0.75" text="「Daleth」"/>
	<mx:Image source="Image5.png" x="64" y="973" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="无相之冰化成棘轮，不断朝玩家处滚动，接触造成50%伤害，滚到太边上会破碎暴露核心，持续1-3轮。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="无相之冰悬于空中，向地面连续轰炸冰刺，共轰炸3次，每次造成100%伤害，第三次轰炸留下霜覆地面，接触造成30%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="928" width="448" alpha="0.9" text="无相之冰抛出3个霜之实，落地造成25%伤害，依次落在玩家的中、右、左处，用重击将霜之实打回无相之冰处以破盾阻止恢复生命值。"/>
	<mx:Text styleName="textStyle11" x="64" y="1104" width="448" alpha="0.75" text="极冰外壳：88冻盾，击破使无相之冰虚弱。霜之实：用于破除极冰外壳，使用重击以启动，命中时-40冻。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="无相之冰脱去外壳，生成数簇围绕其的冰棘，接触造成50%伤害，另有在圈外追踪玩家的冰棘，同样造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="无相之冰生命值低于5%时进行复苏，收拢并形成极冰外壳，复苏持续30s，当复苏次数为1/2/&gt;2时，无相之冰每3s恢复5%/2.5%/1.25%生命值，最大恢复至50%/25%/12.5%生命值。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="寒轶棘轮-碾压"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="寒花冰绽-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="864" width="448" text="复苏霜实-辅助"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="寒蕨蔓生-限制"/>
	<mx:Text styleName="textStyle12" x="1408" y="608" width="448" text="濒亡·封冻-复苏"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="织寒交锋-追踪"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="墙封·极冰-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="864" width="448" text="镇覆交锋-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="无相之冰开阵，8个冰立方外壳围一圈暴露核心，从上到下发射8根追踪玩家的冰锥，每个冰锥造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="无相之冰将外壳化为成两面墙，随后夹击，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="928" width="448" alpha="0.9" text="无相之冰在其侧方产生7个冰锥追踪玩家，每个冰锥造成50%伤害，若某个冰锥为这一轮中第一个命中玩家的冰锥，则造成两段50%伤害。"/>
