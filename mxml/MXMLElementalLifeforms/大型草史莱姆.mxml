	<mx:Text styleName="textStyle7" x="64" y="465" width="395" alpha="0.75" text="Large Dendro Slime"/>
	<mx:Image source="Image3.png" x="64" y="781" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="在失花的大型草史莱姆面前时，大型草史莱姆撞击玩家，造成50%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="大型草史莱姆扔出3个草苗，其迅速生成埋伏的草史莱姆，可使用火元素提前破坏，草史莱姆最多可同时存在6个，与大型草史莱姆同生共死，无掉落物。"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="448" alpha="0.9" text="大型草史莱姆在身边产生毒雾，持续造成10%伤害，于其范围内的原魔每秒持续恢复5%生命值。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="胶质撞击-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="萌蔓葳蕤-召唤"/>
	<mx:Text styleName="textStyle9" x="736" y="672" width="448" text="孢子菌雾-妨害"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="凝浆坠地-控制"/>
	<mx:Text styleName="textStyle9" x="1408" y="416" width="448" text="燃气毒种-远程"/>
	<mx:Text styleName="textStyle9" x="1408" y="672" width="448" text="繁盛之草-天赋"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="大型草史莱姆起跳，重重下落，造成100%伤害。背对埋伏的大型草史莱姆也会触发此技能，诱导其离开地下。强攻强化：该技能的使用更加频繁。"/>
	<mx:Text styleName="textStyle8" x="1408" y="480" width="448" alpha="0.9" text="大型草史莱姆扔出3个毒草种，停留于地面，接触持续造成10%伤害，这些草种遇火则发生爆炸，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="736" width="448" alpha="0.9" text="大型草史莱姆一般躲在地下，背对它或使用火元素攻击均可唤出。其初始附属蔷花，不会再生。当蔷花被火元素引燃时，大型草史莱姆会不断尝试掐灭火焰，有概率成功。"/>
