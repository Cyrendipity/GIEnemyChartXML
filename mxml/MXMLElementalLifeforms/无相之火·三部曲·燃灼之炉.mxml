	<mx:Text styleName="textStyle9" x="736" y="224" width="448" alpha="0.9" text="燃烧状态下的无相之火形成无殚焰胄，当复燃次数为1/2/&gt;2时，无相之火每5s恢复5%/2.5%/0%生命值，最大恢复至50%/25%/不恢复生命值。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="无情常燃-防护"/>
