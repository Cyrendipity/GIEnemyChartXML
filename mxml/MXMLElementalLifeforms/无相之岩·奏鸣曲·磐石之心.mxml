	<mx:Text styleName="textStyle" x="64" y="544" width="460" text="无相之岩·奏鸣曲磐石之心"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="1200" width="448" alpha="0.75" text="玄武岩柱：24岩盾，击破可产生1-2个岩元素晶球；受到突刺/穿刺-0.2岩，切割-0.28岩。复苏玄武岩柱：8岩盾，击破可产生1-2个岩元素晶球；受到突刺/穿刺-0.24岩，切割-0.32岩。黄岩块：3岩盾，击破可产生持续14.4s的护罩；受到突刺/穿刺-0.2岩，切割-0.28岩。岩棱：2岩盾，全部击破以打断鎏金岩潮。"/>
	<mx:Text styleName="textStyle4" x="64" y="704" width="305" text="「贝撒纳」"/>
	<mx:Text styleName="textStyle" x="64" y="1024" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：GO[75,50,25,0]"/>
	<mx:Text styleName="textStyle6" x="64" y="864" width="305" text="HP: 433564 (11.0H)"/>
	<mx:Text styleName="textStyle7" x="64" y="832" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="912" width="375" text="ATK: 18665 (6.0B1)"/>
	<mx:Text styleName="textStyle6" x="64" y="960" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="657" width="395" alpha="0.75" text="Geo Hypostasis: Stone Heart Sonata"/>
	<mx:Text styleName="textStyle9" x="64" y="747" width="395" alpha="0.75" text="「Besanar」"/>
	<mx:Image source="Image4.png" x="64" y="1069" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="无相之岩脱去外壳，短暂暴露核心，在自身和周围3个位置升起玄武岩柱，生成玄武岩柱的区域造成25%伤害(无数字)。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="无相之岩暴露核心，施放岩封印标记同步于玩家，随后岩封印触发3次崩破，前两次造成50%伤害，第三次造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="928" width="448" alpha="0.9" text="无相之岩化作成大锤，蓄力后重重砸下，造成150%伤害，锤击处扩散出3个碎岩波，每个造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="928" width="448" alpha="0.9" text="无相之岩升空，激发其下方的玄武岩柱，使其产生一个冲击波，造成100%伤害(闪避帧无效)，但据说可以跳起来躲冲击波。"/>
	<mx:Text styleName="textStyle10" x="736" y="1152" width="448" alpha="0.9" text="无相之岩升空，脱去外壳，激发其下方的玄武岩柱，使其破裂爆炸造成100%伤害，留下一片流沙持续造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1376" width="448" alpha="0.9" text="无相之岩的玄武岩柱被强化后，其周期性朝玩家发射砂砾弹，每个造成25%,17.5%,12.5%,5%,2.5%伤害，可被护罩抵挡。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="无相之岩盘旋升空，激发所有玄武岩柱，玄武岩柱产生共鸣波，每次造成100%伤害(闪避帧无效)，持续8-9次，其下方会产生一个黄岩块，击破以获得躲避冲击波的护罩。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="玄岩立阵-辅助"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="奭岩之罚-瞄准"/>
	<mx:Text styleName="textStyle11" x="1408" y="864" width="448" text="隳岳之锤-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="864" width="448" text="柱石晶振-控制"/>
	<mx:Text styleName="textStyle11" x="736" y="1088" width="448" text="均晶崩破-摧毁"/>
	<mx:Text styleName="textStyle11" x="736" y="1312" width="448" text="挟晶砂弹-协同输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="608" width="448" text="晶岩谐鸣-爆发"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="尘露岩华-强化"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="墙封·裂石-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="1312" width="448" text="濒亡·散沙-复苏"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="无相之岩升空开阵，8个岩立方围一圈暴露核心，将岩立方粉碎成为岩元素晶华，强化在场的玄武岩柱进行攻击。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="无相之岩将外壳化为成两面墙，随后夹击，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1376" width="448" alpha="0.9" text="生命值低于5%时，无相之岩召唤3个玄武岩柱，复苏持续15s，每个玄武岩柱恢复无相之岩15%生命值。"/>
	<mx:Text styleName="textStyle13" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
