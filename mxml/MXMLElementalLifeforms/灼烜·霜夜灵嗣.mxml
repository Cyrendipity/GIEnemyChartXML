	<mx:Text styleName="textStyle" x="64" y="384" width="448" text="灼烜·霜夜灵嗣"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="704" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1387" y="64" width="469" alpha="0.5" text="元素能量：PP[66x2,33x2,0x2]"/>
	<mx:Text styleName="textStyle5" x="64" y="544" width="305" text="HP: 720980 (13.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="512" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="592" width="375" text="ATK: 14773 (6.0B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="640" width="375" text="Wt/Ed: 150/210"/>
	<mx:Text styleName="textStyle7" x="64" y="446" width="435" alpha="0.75" text="Blazing Brilliance: Frostnight Scion"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="灵嗣飞起，腾跃至空中，在玩家处进行下落攻击，造成100%伤害；「晦隐」状态下会连续下落3次，在第3次落地后产生焰波，造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="512" width="448" alpha="0.9" text="灵嗣转身翻越，进入「晦隐」状态，该状态下灵嗣施放技能前后都会闪现，并且全抗提升，解除对火元素的免疫。不处于「晦隐」状态下持续附着火元素。"/>
	<mx:Text styleName="textStyle8" x="1408" y="800" width="448" alpha="0.9" text=""/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="暝染熛骑-位移"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" text="蔽以霞烟-天赋"/>
	<mx:Text styleName="textStyle9" x="1408" y="736" width="448" text="蔑以煟明-防御"/>
	<mx:Text styleName="textStyle11" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="灵嗣使用赤翼进行至多3段的普通攻击，均造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="512" width="448" alpha="0.9" text="灵嗣张翅，发射烈叶弹，造成90%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="800" width="448" alpha="0.9" text="灵嗣抬起前身向前跺下，造成70%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="赤翎交映-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" text="焰轮长曳-远程"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" text="授以炎炬-输出"/>
