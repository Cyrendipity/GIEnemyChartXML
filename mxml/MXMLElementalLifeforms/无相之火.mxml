	<mx:Text styleName="textStyle" x="64" y="480" width="410" text="无相之火"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="608" width="305" text="「亚因」"/>
	<mx:Text styleName="textStyle4" x="64" y="928" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：PO[75,50,25,0]"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="305" text="HP: 275905 (7.0H)"/>
	<mx:Text styleName="textStyle7" x="64" y="736" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="816" width="375" text="ATK: 15665 (6.0B1)"/>
	<mx:Text styleName="textStyle6" x="64" y="864" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="561" width="395" alpha="0.75" text="Pyro Hypostasis"/>
	<mx:Text styleName="textStyle9" x="64" y="651" width="395" alpha="0.75" text="「Ayin」"/>
	<mx:Image source="Image4.png" x="64" y="973" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="无相之火拳击地面，拳击后从内向外扩散出3道震波，锤击与震波均造成100%,50%,20%,10%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="无相之火朝向玩家并化成球滚动，造成80%伤害；总共来回滚向玩家最多3次，接触造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="896" width="448" alpha="0.9" text="无相之火包围核心，从「贯地千炎」技能留下的不灭熔口中升起3个火种，熄灭所有火种可中断其复燃进程。复燃成功后将恢复复燃值，其值遵循该式：27%+20%火种数量。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="无相之火移到场地中央，蜷缩成球状，8s后爆炸，造成250%大范围伤害(闪避帧无效)。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="热火之赞-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="608" width="448" text="焚燃熔珠-碾压"/>
	<mx:Text styleName="textStyle11" x="1408" y="832" width="448" text="濒亡·复燃-复苏"/>
	<mx:Text styleName="textStyle11" x="1408" y="608" width="448" text="焚净诸事-爆发"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="炽炎森蚺-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="三连拟态-化形"/>
	<mx:Text styleName="textStyle11" x="736" y="1088" width="448" text="焰光错闪-追踪"/>
	<mx:Text styleName="textStyle11" x="1408" y="1088" width="448" text="墙封·烬热-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="无相之火化成蛇，向玩家喷出火球，喷球落地位置依次为玩家左、中、右处，每次喷3个火球，每个火球造成100%,50%,20%,10%伤害。"/>
	<mx:Text styleName="textStyle10" x="1407" y="448" width="448" alpha="0.9" text="无相之火依次变形呈成公牛、鲤鱼、蝴蝶进行攻击，公牛顶造成100%伤害，鲤鱼跃出和跃入造成100%伤害，出地爆炸造成100%伤害，蝴蝶舞造成33%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1152" width="448" alpha="0.9" text="无相之火开阵，8个火立方外壳围一圈暴露核心，一次性发射所有火立方追踪玩家，每个造成50%,25%,12.5%,5%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1152" width="448" alpha="0.9" text="无相之火将外壳化为成两面墙，随后夹击，造成100%伤害。"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle13" x="64" y="1104" width="448" alpha="0.75" text="无殚焰胄：28火盾，击破可熄灭无相之火。火种：2火盾，全部击破阻止无相之火复燃。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="无相之火移到场地中央，暴露核心，不断产生炎柱，造成100%伤害，炎柱在距离无相之火一定范围外会追踪玩家生成。首次升起3根炎柱，并留下3个不灭熔口。"/>
	<mx:Text styleName="textStyle11" x="736" y="832" width="448" text="贯地千炎-辅助"/>
