	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="无相之风脱去外壳暴露核心，在周围产生真空场牵引玩家，持续造成25%伤害，之后产生剧烈爆炸，造成150%伤害(闪避帧无效)。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="无相之风化成风晶蝶，在其前方吹飞玩家，造成75%伤害，之后施放十字斩击，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="928" width="448" alpha="0.9" text="无相之风蜕去外壳，将风立方从空中坠下，风立方落地产生风场，每个造成100%伤害，共计下落3个风立方。"/>
	<mx:Text styleName="textStyle11" x="64" y="1008" width="448" alpha="0.75" text="元素之微粒：触碰产生6个对应元素微粒。复苏风晶球：触碰产生3个风元素微粒。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="无相之风盘旋升空，于空中向地面注入风元素气旋，持续造成25%伤害，同时场地出现8个游离的龙卷风，龙卷风可被火/水/雷/冰染色，接触造成对应元素的75%伤害，最终形成对应元素之微粒。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="无相之风在地面高速旋转，在其周围持续造成10%伤害，并开始吸收元素之微粒，产生大范围冲击波，造成对应元素的100%伤害(闪避帧无效)，吸收3个微粒后停止攻击，暴露核心。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="气蓄空爆-牵引"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="蝶振微风-控制"/>
	<mx:Text styleName="textStyle12" x="736" y="864" width="448" text="天坠风渠-辅助"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="飓风临陆-辅助"/>
	<mx:Text styleName="textStyle12" x="1408" y="608" width="448" text="覆地残流-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="翠星一煜-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="墙封·疾巡-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="864" width="448" text="濒亡·气集-复苏"/>
	<mx:Image source="Image5.png" x="596" y="171" width="128" height="128"/>
	<mx:Image source="Image6.png" x="576" y="150" width="168" height="170"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="无相之风开阵，8个风立方外壳围一圈暴露核心，发射3个风弹，每个风弹造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="无相之风将外壳化为成两面墙，随后夹击，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="928" width="448" alpha="0.9" text="生命值低于5%时，无相之风召唤4个复苏风晶球，周围产生4个风场，复苏持续15s，每个风之晶球恢复无相之风12.5%生命值，无晶球时恢复5%生命值。"/>
