	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="在大型火史莱姆面前时，大型火史莱姆撞击玩家，造成50%伤害，熄灭状态下撞击则只有33.3%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="480" width="448" alpha="0.9" text="燃烧状态的大型火史莱姆死亡时，爆炸，造成66.6%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="高温撞击-输出"/>
	<mx:Text styleName="textStyle9" x="1408" y="416" width="448" text="过热涌泄-亡语"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="大型火史莱姆蓄力喷出3个火焰弹，每个造成25%伤害，熄灭状态无法喷出，喷吐过程中若被熄灭则火球也会熄灭。"/>
	<mx:Text styleName="textStyle8" x="736" y="736" width="448" alpha="0.9" text="大型火史莱姆常驻火息，耗尽后会转为熄灭状态，一段时间或受到任意火元素伤害后(可无元素附着)，当无元素附着时会尝试复燃。"/>
	<mx:Text styleName="textStyle11" x="64" y="912" width="448" alpha="0.75" text="火息：8火盾，浇熄后转为熄灭状态，一段时间后恢复。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="大型火史莱姆起跳，重重下落，造成100%伤害，熄灭状态下下落则只造成66.6%伤害。强攻强化：该技能的使用更加频繁。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="熔涌之刻-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="672" width="448" text="流烁之火-天赋"/>
