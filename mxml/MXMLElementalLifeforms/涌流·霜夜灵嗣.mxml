	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="川泽交汇-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" text="歌泉露沫-远程"/>
	<mx:Text styleName="textStyle11" x="736" y="736" width="448" text="授以甘露-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="幽光拂浪-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="448" width="448" text="蔽以零瀼-天赋"/>
	<mx:Text styleName="textStyle11" x="1408" y="736" width="448" text="蔑以浊污-防御"/>
	<mx:Text styleName="textStyle13" x="736" y="224" width="448" alpha="0.9" text="灵嗣利用巨尾进行至多2段的横扫攻击，均造成80%伤害。"/>
	<mx:Text styleName="textStyle13" x="736" y="512" width="448" alpha="0.9" text="灵嗣操控巨尾，抛出3枚水泡，水泡落地造成30%伤害并继续向前弹跳2次，随后消失。"/>
	<mx:Text styleName="textStyle13" x="736" y="800" width="448" alpha="0.9" text="灵嗣抬起前身向前跺下，造成70%伤害。"/>
	<mx:Text styleName="textStyle13" x="1408" y="224" width="448" alpha="0.9" text="灵嗣将尾部掷向地面，造成80%伤害；「晦隐」状态下还会产生一枚水泡，落地造成30%伤害，弹起2次后消失。"/>
	<mx:Text styleName="textStyle13" x="1408" y="512" width="448" alpha="0.9" text="灵嗣转身翻越，进入「晦隐」状态，该状态下灵嗣施放技能前后都会闪现，并且全抗提升，解除对水元素的免疫。不处于「晦隐」状态下持续附着水元素。"/>
	<mx:Text styleName="textStyle13" x="1408" y="800" width="448" alpha="0.9" text="灵嗣背对玩家用后肢猛踢，造成70%伤害。"/>
