	<mx:Text styleName="textStyle" x="64" y="384" width="410" text="无相之草"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="305" text="「扎因」"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1247" y="64" width="609" alpha="0.5" text="元素能量：DP[0x2],DO[75,50,25]"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="305" text="HP: 354734 (9.0H)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 15665 (6.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="465" width="395" alpha="0.75" text="Dendro Hypostasis"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="「Zayin」"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="无相之草用荆棘束缚，升空朝玩家进行3次下落攻击，前两次造成70%伤害，最后一次造成100%伤害。下落攻击坠地时，可使用火元素攻击外壳暴露核心。"/>
	<mx:Text styleName="textStyle10" x="736" y="544" width="448" alpha="0.9" text="无相之草化为肮脏花苞，喷出草球，每个造成40%伤害，总共分3批喷出，批次为2/3/4，每个草球落地后留下腐殖质，接触持续造成5%伤害。"/>
	<mx:Text styleName="textStyle11" x="64" y="1008" width="448" alpha="0.75" text="荆棘锥：2木盾，可被烧毁。荆棘：2木盾，可被烧毁，全部烧毁阻止无相之草技能。朽木秽质：48木逆盾，受到草伤+0.88木，受到正常草芯净化+1.04木，受到活化草芯净化+3.20木，燃烧-0.4木持续10s后熄灭。"/>
	<mx:Text styleName="textStyle10" x="736" y="832" width="448" alpha="0.9" text="无相之草化为一个树苗，暴露核心，场地边缘形成一圈的荆棘，其将不断接近无相之草，接触造成10%伤害，到达后引发无相之草的一次爆炸，造成250%伤害(闪避帧无效)。荆棘可被烧毁，全部烧毁后继续暴露核心而不爆炸。"/>
	<mx:Text styleName="textStyle10" x="1408" y="832" width="448" alpha="0.9" text="无相之草生命值低于5%时进行净化，其周围将生成3个「愈疗草芯」，初始为枯焦状态，使用草元素以激活并开始净化流程，可再使用雷元素以加速进程。净化期间无相之草自身附着朽木秽质，且会间歇抛出枯萎弹，造成60%伤害，其会将「愈疗草芯」转化为枯焦状态。当净化次数为1/2/&gt;2时，无相之草恢复50%/25%/12.5%生命值。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="棘缚连落-碾压"/>
	<mx:Text styleName="textStyle12" x="736" y="480" width="448" text="含孢初绽-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="768" width="448" text="枯木复春-爆发"/>
	<mx:Text styleName="textStyle12" x="1408" y="768" width="448" text="濒亡·净化-复苏"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="毒荆交集-妨害"/>
	<mx:Text styleName="textStyle12" x="1408" y="480" width="448" text="松闪笞鞭-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="无相之草形成一个刺锥深入地面，并暴露核心，此后追踪玩家生成3-4个荆棘锥，每个造成20%伤害，可被烧毁，2s后各荆棘锥依次进行放刺针扎，造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="544" width="448" alpha="0.9" text="无相之草化为一个草鞭，进行纵击、甩击、旋转共3段的攻击，其依次造成40%,60%,80%伤害。"/>
	<mx:Text styleName="textStyle13" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
