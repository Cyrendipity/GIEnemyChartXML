	<mx:Text styleName="textStyle9" x="1408" y="224" width="448" alpha="0.9" text="灵主飞速旋转双翼，造成80%伤害；「晦隐」状态下倍率提升，造成100%伤害。吸收元素后可被附魔。"/>
	<mx:Text styleName="textStyle9" x="1408" y="480" width="448" alpha="0.9" text="灵主合翼，高高飞起，朝我方角色位置坠下，造成100%伤害；「晦隐」状态下不施放。吸收元素后可被附魔。"/>
	<mx:Text styleName="textStyle9" x="1408" y="736" width="448" alpha="0.9" text="「晦隐」状态下，距离较远时，灵主蓄力，并突然重坠，惊起地浪，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="160" width="448" text="霜染白莹-防御"/>
	<mx:Text styleName="textStyle10" x="1408" y="416" width="448" text="击风止影-位移"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" text="幕作惊汐-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="224" width="448" alpha="0.9" text="灵主进行至多3段的普通攻击，每段均造成50%伤害；「晦隐」状态下倍率提升，每段造成70%伤害。吸收元素后可被附魔。"/>
	<mx:Text styleName="textStyle9" x="736" y="480" width="448" alpha="0.9" text="灵主唤来纯皎的凝晶，朝我方角色如数发射，造成50%,25%,5%伤害；「晦隐」状态下不施放。吸收元素后可被附魔。"/>
	<mx:Text styleName="textStyle9" x="736" y="736" width="448" alpha="0.9" text="「晦隐」状态下，距离较远时，灵主飞快地挥舞两次，产生两道剑气，分别造成70%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="992" width="448" alpha="0.9" text="生命值低于70%时，灵主将移至场地中央，进入「晦隐」状态并清除自身元素及附着；召唤16道高速移动的流光，造成70%伤害；最后收尾产生爆破，造成100%伤害。此外，「晦隐」状态下，场地内会随机出现1-3枚落月，落地造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="160" width="448" text="轻跹悠摇-输出"/>
	<mx:Text styleName="textStyle10" x="736" y="416" width="448" text="皎光悬玉-远程"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" text="昏见交痕-远程"/>
	<mx:Text styleName="textStyle10" x="736" y="928" width="448" text="百羽垂曜-爆发"/>
