	<mx:Text styleName="textStyle8" x="64" y="465" width="395" alpha="0.75" text="Hydro Tulpa: Flashflood"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="Manifest Will of the Waters"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="184"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="幻人扔出纯水制成的标枪，落地造成60%伤害，并产生内外2层激波，造成60%伤害，可连续施放3次；强化：伤害倍率提升，造成90%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="512" width="448" alpha="0.9" text="幻人用左手拍向玩家，造成50%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="512" width="448" alpha="0.9" text="幻人旋转纯水制成的榔锤，进行3次攻击，依次造成60%,62.5%,65%伤害；第三段攻击产生激波，造成90%伤害。强化：伤害倍率提升，挥舞造成90%,92.5%,95%伤害，不产生激波。"/>
	<mx:Text styleName="textStyle11" x="1408" y="800" width="448" alpha="0.9" text="幻人蓄力，附属白盾；12s后白盾消失，幻人掀起澜海激潮，在场地内下起小雨，造成20%伤害；溅起的潮水凝结成3把水枪，并一起在自身周围降下，造成100%伤害，并产生一道冲击波引爆所有半幻人，造成100%伤害，冲击波将会秒杀在场非无敌状态的角色。"/>
	<mx:Text styleName="textStyle11" x="736" y="800" width="448" alpha="0.9" text="场地内将不断生成半幻人，数量维持在3个；在战斗中水形幻人会吸收所有半幻人，施放4个技能或进行瞬移后结束强化状态。"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="幻人挥舞纯水制成的短刀，进行2次攻击，依次造成60%,65%伤害；第一段攻击产生剑气，造成50%伤害。强化：伤害倍率提升，挥舞造成90%,95%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="濯漾梭枪-远程"/>
	<mx:Text styleName="textStyle12" x="1408" y="448" width="448" text="幻泉终拳-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="448" width="448" text="净域洄榔-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="736" width="448" text="坏蔑锋雨-必杀技"/>
	<mx:Text styleName="textStyle12" x="736" y="736" width="448" text="幻蜃交融-强化"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="涤浸青刃-输出"/>
	<mx:Text styleName="textStyle13" x="64" y="1068" width="448" alpha="0.75" text="半幻人：4.8水盾，击破后消失；其继承幻人28%的攻击力。白盾：依词条数目，继承9.35%/11.69%/10.79%/14.76%/23.38%生命值，破坏后扣除幻人护盾等量生命值。"/>
