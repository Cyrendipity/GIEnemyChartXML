	<mx:Text styleName="textStyle11" x="1408" y="640" width="448" text="悉数禁灭-重置"/>
	<mx:Text styleName="textStyle9" x="1408" y="704" width="448" alpha="0.9" text="无相之草组装成类似于三脚架的装置，数秒后将场上的「愈疗草芯」全部转变为枯焦状态。"/>
	<mx:Image source="Image14.png" x="1268" y="939" width="128" height="128"/>
