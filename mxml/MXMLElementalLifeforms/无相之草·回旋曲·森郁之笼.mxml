	<mx:Text styleName="textStyle" x="64" y="448" width="449" text="无相之草·回旋曲森郁之笼"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="608" width="305" text="「扎因」"/>
	<mx:Text styleName="textStyle" x="64" y="928" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1247" y="64" width="609" alpha="0.5" text="元素能量：DP[0x2],DO[75,50,25]"/>
	<mx:Text styleName="textStyle5" x="64" y="768" width="305" text="HP: 548416 (9.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="736" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="816" width="375" text="ATK: 15665 (6.0B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="864" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle7" x="64" y="561" width="395" alpha="0.75" text="Dendro Hypostasis: Rondo of the Forest Corral"/>
	<mx:Text styleName="textStyle8" x="64" y="651" width="395" alpha="0.75" text="「Zayin」"/>
	<mx:Image source="Image4.png" x="64" y="973" width="484" height="124"/>
	<mx:Text styleName="textStyle9" x="736" y="224" width="448" alpha="0.9" text="无相之草用荆棘束缚，升空朝玩家进行3次下落攻击，前两次造成70%伤害，最后一次造成100%伤害。下落攻击坠地时，可使用火元素攻击外壳暴露核心。"/>
	<mx:Text styleName="textStyle9" x="736" y="480" width="448" alpha="0.9" text="无相之草化为肮脏花苞，喷出草球，每个造成40%伤害，总共分3批喷出，批次为2/3/4，每个草球落地后留下腐殖质，接触持续造成5%伤害。"/>
	<mx:Text styleName="textStyle10" x="64" y="1104" width="448" alpha="0.75" text="荆棘锥：2木盾，可被烧毁。荆棘：2木盾，可被烧毁，全部烧毁阻止无相之草技能。朽木秽质：48木逆盾，受到草伤+0.24(极限0.16)木，受到正常草芯净化+0.32(极限0.20)木，受到活化草芯净化+0.96(极限0.60)木，燃烧-0.4木持续10s后熄灭。侵蚀草晶球：非盾，返回核心-0.4木，被雷元素活化后返回核心+0.8木。"/>
	<mx:Text styleName="textStyle9" x="1408" y="992" width="448" alpha="0.9" text="无相之草生命值低于5%时进行净化，利用现存的「愈疗草芯」进行净化。净化期间无相之草自身附着朽木秽质，且会间歇抛出枯萎弹，造成60%伤害，其会将「愈疗草芯」转化为枯焦状态。枯萎弹落地会留下侵蚀草晶球， 一段时间后将返回核心处削减净化进度。当净化次数为1/2/&gt;2时，无相之草恢复50%/25%/12.5%生命值。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="棘缚连落-碾压"/>
	<mx:Text styleName="textStyle11" x="736" y="416" width="448" text="含孢初绽-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="928" width="448" text="濒亡·净化-复苏"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="毒荆交集-妨害"/>
	<mx:Text styleName="textStyle11" x="1408" y="416" width="448" text="松闪笞鞭-输出"/>
	<mx:Text styleName="textStyle9" x="1408" y="224" width="448" alpha="0.9" text="无相之草形成一个刺锥深入地面，并暴露核心，此后追踪玩家生成3-4个荆棘锥，每个造成20%伤害，可被烧毁，2s后各荆棘锥依次进行放刺针扎，造成50%伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="480" width="448" alpha="0.9" text="无相之草化为一个草鞭，进行纵击、甩击、旋转共3段的攻击，其依次造成40%,60%,80%伤害。"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
