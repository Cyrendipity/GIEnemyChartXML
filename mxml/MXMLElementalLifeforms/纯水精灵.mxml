	<mx:Text styleName="textStyle11" x="736" y="1280" width="448" text="净水濯洗-追踪"/>
	<mx:Text styleName="textStyle11" x="736" y="1504" width="448" text="巨浪喷流-锁定"/>
	<mx:Text styleName="textStyle11" x="1408" y="1280" width="448" text="浑水抓鱼-追踪"/>
