	<mx:Image source="Image4.png" x="64" y="1133" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="纯水精灵砸向平台，使该平台沉入水下，被纯水精灵砸到造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="幻形蛙或幻形雀被击败后，被消灭后产生水弹，爆炸造成等同于纯水精灵83.3%攻击力的伤害(闪避帧无效)。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="水土流失-妨害"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="凝幻水弹-亡语"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle13" x="64" y="1264" width="448" alpha="0.75" text="纯水幻形：水弹落在角地砖，召唤3个一组的幻形鹤或幻形飞鸢；水弹落在边地砖，召唤1个一组的幻形雀或幻形蛙；水弹落在中心地砖，召唤2个一组的幻形游禽、幻形豕兽、幻形花鼠、幻形蟹；"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="纯水精灵吐出1或2个水泡，水泡在平台上形成对应的纯水幻形。第三次及之后喷吐2个水泡。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="若长时间未击败纯水幻形，纯水精灵在玩家位置生成漩涡，持续造成50%伤害，3s后爆炸，造成200%伤害，以上伤害闪避帧均无效。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="纯水精灵挥动左/右鳍部向下猛击，造成66.6%伤害，二阶段后会在此位置产生水爆，造成66.6%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="纯水精灵翻空，挥动尾鳍部向下猛击，造成100%伤害，二阶段后会在此位置产生3道水爆，各造成66.6%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1120" width="448" alpha="0.9" text="纯水精灵后空翻贴地冲刺，造成1-2段33.3%伤害，可重复2-4次。"/>
	<mx:Text styleName="textStyle10" x="736" y="1344" width="448" alpha="0.9" text="纯水精灵用双鳍汇聚出1-3个追踪水弹，水弹可被攻击打碎，水弹接触爆炸造成80%,40%,20%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1568" width="448" alpha="0.9" text="纯水精灵开始蓄力，标记玩家，片刻后喷出巨大喷流，持续造成33.3%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1344" width="448" alpha="0.9" text="纯水精灵潜地后冒出，并携带2-4个追踪小水泡后发射，水泡可被攻击击碎，造成66.6%,33.3%,16.6%,6.66%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1568" width="448" alpha="0.9" text="纯水精灵蓄力产生巨大的水球，几秒后落地，产生巨大水波，水波造成两段133.3%伤害(闪避帧无效)。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1120" width="448" alpha="0.9" text="纯水精灵召唤3或5个水漩涡，漩涡将持续造成13.3%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="纯水精灵挥动左/右鳍部转身猛击，造成66.6%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="896" width="448" alpha="0.9" text="生命值低于81%时，纯水精灵召唤4个纯水幻形，然后隐蔽身形。每击败一个纯水幻形，就会使纯水精灵扣除5%生命值，全击败使其现形进入二阶段。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="林野百态-召唤"/>
