	<mx:Text styleName="textStyle10" x="0" y="831" width="64" text="正常"/>
	<mx:Text styleName="textStyle10" x="0" y="891" width="64" text="晦隐"/>
	<mx:Text styleName="textStyle11" x="0" y="942" width="64" text="深渊晦隐"/>
	<mx:Text styleName="textStyle12" x="64" y="998" width="448" alpha="0.75" text="晦隐：抗打断0，全抗性提升60%/120%，允许受到岩元素伤害；充能条总量100/150(深渊)，受到岩元素攻击后根据岩元素的量积攒20n或3，受到月反应伤害积攒3，充满退出状态。"/>
	<mx:Text styleName="textStyle13" x="736" y="224" width="448" alpha="0.9" text="灵嗣利用背身的琥珀环进行至多两次的攻击，均造成80%伤害。"/>
	<mx:Text styleName="textStyle13" x="736" y="512" width="448" alpha="0.9" text="灵嗣召集晶石，在自身附近施放三波岩陨，每次施放时都会闪到玩家附近，岩陨波造成60%伤害；该技能仅在「晦隐」状态下施放。"/>
	<mx:Text styleName="textStyle13" x="736" y="800" width="448" alpha="0.9" text="灵嗣抬起前身向前跺下，造成70%伤害。"/>
	<mx:Text styleName="textStyle13" x="1408" y="224" width="448" alpha="0.9" text="灵嗣凝结晶石，并朝玩家丢出，造成100%伤害；「晦隐」状态下落地的晶石还会溅射出5枚碎片，造成10%伤害。"/>
	<mx:Text styleName="textStyle13" x="1408" y="512" width="448" alpha="0.9" text="灵嗣转身翻越，进入「晦隐」状态，该状态下灵嗣施放技能前后都会闪现，并且全抗提升，解除对岩元素的免疫。"/>
	<mx:Text styleName="textStyle13" x="1408" y="800" width="448" alpha="0.9" text="灵嗣背对玩家用后肢猛踢，造成70%伤害。"/>
