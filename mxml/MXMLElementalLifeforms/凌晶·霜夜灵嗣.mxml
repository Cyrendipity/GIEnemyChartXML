	<mx:Text styleName="textStyle" x="64" y="384" width="519" text="凌晶·霜夜灵嗣"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="704" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="1216" y="64" width="640" alpha="0.5" text="元素能量：CP[66x2,33x2,0x2]"/>
	<mx:Text styleName="textStyle5" x="64" y="446" width="395" alpha="0.75" text="Icy Crystal: Frostnight Scion"/>
	<mx:Image source="Image3.png" x="64" y="749" width="484" height="124"/>
	<mx:Text styleName="textStyle6" x="736" y="224" width="448" alpha="0.9" text="灵嗣利用背身的霜环进行至多两次的攻击，均造成80%伤害。"/>
	<mx:Text styleName="textStyle6" x="736" y="512" width="448" alpha="0.9" text="灵嗣召集冰簇，在自身周围降下三次冰雨，每次施放时都会闪到玩家附近，造成60%伤害；该技能仅在「晦隐」状态下施放。"/>
	<mx:Text styleName="textStyle6" x="736" y="800" width="448" alpha="0.9" text="灵嗣抬起前身向前跺下，造成70%伤害。"/>
	<mx:Text styleName="textStyle6" x="1408" y="224" width="448" alpha="0.9" text="灵嗣凝结冰簇，并朝玩家丢出，造成100%伤害；「晦隐」状态下还会额外发射5枚追踪冰凌，造成20%伤害。"/>
	<mx:Text styleName="textStyle6" x="1408" y="512" width="448" alpha="0.9" text="灵嗣转身翻越，进入「晦隐」状态，该状态下灵嗣施放技能前后都会闪现，并且全抗提升，解除对冰元素的免疫。不处于「晦隐」状态下持续附着冻冰元素。"/>
	<mx:Text styleName="textStyle6" x="1408" y="800" width="448" alpha="0.9" text="灵嗣背对玩家用后肢猛踢，造成70%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="160" width="448" text="晶翎相辉-输出"/>
	<mx:Text styleName="textStyle7" x="736" y="448" width="448" text="冰雨偕行-输出"/>
	<mx:Text styleName="textStyle7" x="736" y="736" width="448" text="授以凛寒-输出"/>
	<mx:Text styleName="textStyle7" x="1408" y="160" width="448" text="凌光追影-远程"/>
	<mx:Text styleName="textStyle7" x="1408" y="448" width="448" text="蔽以严霜-天赋"/>
	<mx:Text styleName="textStyle7" x="1408" y="736" width="448" text="蔑以残霜-防御"/>
