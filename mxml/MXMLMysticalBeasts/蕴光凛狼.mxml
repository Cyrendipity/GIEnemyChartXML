	<mx:Text styleName="textStyle" x="64" y="384" width="519" text="蕴光凛狼"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="736" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="576" y="128" width="640" alpha="0.5" text="元素能量：CP[66x2,33x2,0x2]"/>
	<mx:Text styleName="textStyle5" x="64" y="465" width="395" alpha="0.75" text="Radiant Glacial Wolf"/>
	<mx:Image source="Image4.png" x="64" y="781" width="484" height="124"/>
	<mx:Text styleName="textStyle6" x="736" y="256" width="448" alpha="0.9" text="凛狼对玩家进行至多抓，咬，咬3段攻击，依次造成50%,40%,70%伤害，可单独施放。"/>
	<mx:Text styleName="textStyle6" x="736" y="480" width="448" alpha="0.9" text="凛狼迅速高跳至玩家处，并踉跄一下，造成100%伤害。"/>
	<mx:Text styleName="textStyle6" x="736" y="704" width="448" alpha="0.9" text="孤狼朝前方猛地喷吐狂风，造成造成80%伤害。"/>
	<mx:Text styleName="textStyle6" x="736" y="928" width="448" alpha="0.9" text="凛狼展开半径15m的蕴光领域，朝玩家凶猛袭来，并用力切割两次，每次造成70%伤害，可连续施放2次。"/>
	<mx:Text styleName="textStyle6" x="736" y="1152" width="448" alpha="0.9" text="凛狼展开半径15m的蕴光领域，用利爪用力劈开一刀冰刃，造成90%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="192" width="448" text="苍牙啖啮-输出"/>
	<mx:Text styleName="textStyle7" x="736" y="416" width="448" text="孤踪飞猎-位移"/>
	<mx:Text styleName="textStyle7" x="736" y="640" width="448" text="秋阑风冽-远程"/>
	<mx:Text styleName="textStyle7" x="736" y="864" width="448" text="狂逐碎灭-输出"/>
	<mx:Text styleName="textStyle7" x="736" y="1088" width="448" text="拨霜斫捩-远程"/>
	<mx:Text styleName="textStyle8" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle9" x="64" y="576" width="305" text="HP: 610060 (11.0F)"/>
	<mx:Text styleName="textStyle10" x="64" y="544" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle9" x="64" y="624" width="375" text="ATK: 16251 (6.6B2)"/>
	<mx:Text styleName="textStyle9" x="64" y="672" width="375" text="Wt/Ed: 150/210"/>
	<mx:Text styleName="textStyle11" x="64" y="912" width="448" alpha="0.75" text="蕴光领域：展开时施加「蕴光之茧」状态，扣除全队角色10%+1800点生命值，若角色生命值低于7200点，则改为扣除35%生命值，可致命但可开大招躲避；主动治疗清除后获得「出缠」效果。若范围内前台角色仍处于「蕴光之茧」状态，凛狼不会施放「狂逐碎灭」、「拨霜斫捩」。蕴光之茧：暴击率-10%，造成的伤害-10%，受治疗加成-10%。出缠：暴击率+15%，造成的伤害+50%，持续15s。"/>
