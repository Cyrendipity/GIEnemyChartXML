	<mx:Text styleName="textStyle6" x="64" y="465" width="395" alpha="0.75" text="Radiant Bladehorn"/>
	<mx:Text styleName="textStyle7" x="736" y="256" width="448" alpha="0.9" text="刃犀用角进行至多2次的顶击，边顶边冲，依次造成60%,80%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="480" width="448" alpha="0.9" text="刃犀抬起前身，然后重重拍下，依次造成80%,100%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="704" width="448" alpha="0.9" text="刃犀展开半径15m的蕴光领域，依次朝玩家发射背上尖锐的3个嵴刃，每枚造成30%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="928" width="448" alpha="0.9" text="刃犀展开半径15m的蕴光领域，其从远处执角冲来，接触造成40%伤害；行至目标处立即重重拍下，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="192" width="448" text="钩犀斗角-位移"/>
	<mx:Text styleName="textStyle8" x="736" y="416" width="448" text="风起石落-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="640" width="448" text="锋嵴磔刃-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="864" width="448" text="牴风长袭-位移"/>
