	<mx:Text styleName="textStyle8" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle9" x="736" y="192" width="448" text="潮花轻蘸-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="洄水飞浪-位移"/>
	<mx:Text styleName="textStyle9" x="736" y="640" width="448" text="抽滔断水-位移"/>
	<mx:Text styleName="textStyle9" x="736" y="864" width="448" text="断浪长袭-远程"/>
	<mx:Text styleName="textStyle9" x="736" y="1088" width="448" text="露流彩沫-位移"/>
	<mx:Text styleName="textStyle10" x="736" y="256" width="448" alpha="0.9" text="璇蛸轻轻地扒拉两下，依次造成40%,60%伤害，容易后接「洄水飞浪」。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="璇蛸划拉转圈袭来，持续造成20%伤害，最后用力再转一圈，造成90%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="704" width="448" alpha="0.9" text="璇蛸突然朝玩家袭来，用力砸一下，造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="928" width="448" alpha="0.9" text="璇蛸展开半径15m的蕴光领域，朝玩家方向斩出两道水刃，造成60%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1152" width="448" alpha="0.9" text="璇蛸展开半径15m的蕴光领域，并且朝玩家钻旋袭来，途径造成30%伤害，行至目标处释放水涌，造成100%伤害。"/>
