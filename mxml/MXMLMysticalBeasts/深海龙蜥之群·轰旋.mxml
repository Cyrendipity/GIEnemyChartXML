	<mx:Text styleName="textStyle" x="64" y="480" width="510" text="深海龙蜥之群·轰旋"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="608" width="305" text="珊瑚的守护者"/>
	<mx:Text styleName="textStyle4" x="64" y="928" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1330" y="64" width="526" alpha="0.5" text="元素能量：EP/CP[75,50,25],EO/CO[0]"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="448" text="HP: 830703 (13.633F) (单只)"/>
	<mx:Text styleName="textStyle7" x="64" y="736" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="816" width="375" text="ATK: 13054 (5.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="864" width="375" text="Wt/Ed: 250/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="561" width="395" alpha="0.75" text="Booming Bathysmal Vishap Herd"/>
	<mx:Text styleName="textStyle9" x="64" y="655" width="395" alpha="0.75" text="Coral Defender"/>
	<mx:Image source="Image4.png" x="64" y="973" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="两个深海龙蜥面对面用尾部架阵，从阵中发射总计34枚的冰刺与雷针，不论冰与雷，都造成对应元素的20%,10%,5%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="704" width="448" alpha="0.9" text="唳霜或啸霆蓄力发射一枚带刺冰球，造成对应元素的5%伤害，并扣除角色30点能量，若能量不足则无视护盾额外扣除一定比例的生命值。"/>
	<mx:Text styleName="textStyle10" x="1408" y="704" width="448" alpha="0.9" text="唳霜后撤一步。随后向前翻滚，用尾部扫两圈，造成两段30%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="928" width="448" alpha="0.9" text="啸霆使用尾部产生雷球，雷球破裂产生3个雷刺，造成30%,15%,7.5%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="928" width="448" alpha="0.9" text="啸霆将尾部插入地面，在一定区域内不断生成雷棘，造成60%,30%,15%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1152" width="448" alpha="0.9" text="唳霜后撤一步。先用右爪扫，造成30%伤害，再用左爪扫，造成50%伤害，最后双爪敲，造成80%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="1152" width="448" alpha="0.9" text="(强化)当某个龙蜥濒死时，另一种龙蜥将在10s后回复其50%的生命值使其重新加入战斗。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="当某个龙蜥濒死时，两只龙蜥跳到场地中央，缠绕尾部，产生超导场持续造成50%+50%伤害，随后两只龙蜥均发射对应的激光，造成对应元素的100%,50%,25%,10%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="两个深海龙蜥爬上中央的糙岩石柱，不断朝玩家发射涤魔子弹，都造成对应元素的5%伤害并扣除角色30点能量。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="冰潮雷涌-协同妨害"/>
	<mx:Text styleName="textStyle12" x="736" y="640" width="448" text="涤魔喷吐-妨害"/>
	<mx:Text styleName="textStyle12" x="1408" y="640" width="448" text="袭卷白霜-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="864" width="448" text="闪电引弹-追踪"/>
	<mx:Text styleName="textStyle12" x="1408" y="864" width="448" text="彻地千雷-追踪"/>
	<mx:Text styleName="textStyle12" x="736" y="1088" width="448" text="左右开攻-输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="1088" width="448" text="生死之恋-回复"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="彼岸双蜥-协同输出"/>
	<mx:Text styleName="textStyle12" x="1408" y="416" width="448" text="霆海重滨-协同妨害"/>
	<mx:Text styleName="textStyle13" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle14" x="64" y="1164" width="448" alpha="0.75" text="糙岩石柱：8岩盾，受到近战攻击-0.08岩，击破可击落位于其上的吞雷。"/>
