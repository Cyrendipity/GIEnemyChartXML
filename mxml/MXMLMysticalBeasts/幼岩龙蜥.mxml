	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="幼岩龙蜥使用双爪划击，造成55.5%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="512" width="448" alpha="0.9" text="幼岩龙蜥在原地不断旋转，造成44.4%伤害，旋转结束后施放强力尾刀，造成66.6%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="800" width="448" alpha="0.9" text="幼岩龙蜥蜷缩身子，朝玩家冲过来，造成83.3%伤害，若命中玩家则立即弹开坠落，坠落造成100%伤害。若命中玩家身上的护盾，则会造成一段时间的眩晕。"/>
	<mx:Text styleName="textStyle10" x="1408" y="512" width="448" alpha="0.9" text="距离玩家较远时，幼岩龙蜥会直接高空跳跃过来，造成83.3%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="撕峰之爪-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" text="掀地迂旋-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="736" width="448" text="龙径危卷-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" text="若龙崩空-输出"/>
