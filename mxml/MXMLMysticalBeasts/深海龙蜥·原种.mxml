	<mx:Text styleName="textStyle10" x="736" y="288" width="448" alpha="0.9" text="原种蓄力发射一枚水球，造成50%伤害，并扣除角色10点元素能量，若能量不足则扣除一定比例的生命值，扣除公式见左下角。"/>
	<mx:Text styleName="textStyle11" x="736" y="512" width="448" alpha="0.9" text="(仅成体)原种将尾部插入地面，在一定区域内不断生成水喷，造成60%,30%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" alpha="0.9" text="原种后撤，向前翻滚，用尾部扫两圈，造成2段30%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="960" width="448" alpha="0.9" text="原种翘起尾部，聚集水花，产生3个水轮，每个水轮造成30%,15%,7.5%伤害。"/>
