	<mx:Text styleName="textStyle8" x="64" y="447" width="395" alpha="0.75" text="Gluttonous Yumkasaur Mountain Lord"/>
	<mx:Text styleName="textStyle9" x="64" y="548" width="410" alpha="0.75" text="Kongamanto the Mountain King "/>
	<mx:Image source="Image5.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="山王至多进行践踏、甩尾2段攻击，分别造成50%,65%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="山王借助长舌纵身一跃，重重下落造成80%伤害，并产生一次相同伤害的振波。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="山王喷吐一枚草弹，造成50%伤害，可重复施放3次。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="掷步衔尾-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="引索垂星-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="608" width="448" text="丛庞涎芬-远程"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="樊林倬影-位移"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="难支鞠硕-位移"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="山王拍拍肚子，扑倒并朝玩家方向开始旋转，持续造成35%,17.5%,8.75%,3.5%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="山王借助长舌抵达高处，缓慢下落，造成80%伤害。"/>
