	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="雷海马进行一次环转，造成60%伤害；无珍珠时进行则造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="512" width="448" alpha="0.9" text="雷海马从远处迅速冲向玩家，造成80%伤害；途经将留下雷曜地面，持续造成6%伤害；无珍珠时进行则造成65%伤害，且不会留下雷曜地面。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="雷海马迅速翻滚至多3圈，分别造成60%,60%,50%伤害；无珍珠时进行则造成50%,50%,40%伤害；攻击造成的伤害带有(1,0.5)的衰减。"/>
	<mx:Text styleName="textStyle10" x="1408" y="512" width="448" alpha="0.9" text="雷海马释放出大群的游鱼，游鱼在飞出一小会后冲向玩家，造成35%,17.5%,6.3%~3.5%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="800" width="448" alpha="0.9" text="雷海马登天，朝玩家猛地下戳，造成95%伤害，并引起地裂喷涌，造成50%伤害，留下雷曜地面。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1088" width="448" alpha="0.9" text="当珍珠盾量&lt;=7时施放；雷海马登天，唤临3枚共鸣珊瑚珠，并不断降下总计5道的落雷，均造成100%伤害。破坏所有珊瑚珠可以使其瘫痪陷入无珠状态，未及时破除会修复珍珠。"/>
	<mx:Text styleName="textStyle10" x="736" y="800" width="448" alpha="0.9" text="雷海马瞄准并锁定玩家，数秒后在玩家处产生喷涌，造成50%伤害，留下雷曜地面，持续造成5%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1088" width="448" alpha="0.9" text="陷入无珠状态约30s/20s(深境螺旋)后，雷海马即将再度生成异海珍珠！生成时施放雷暴，造成90%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="尾羽环转-防卫"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" text="掣海无影-位移"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="尾羽交扇-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" text="群鱼天游-追踪"/>
	<mx:Text styleName="textStyle11" x="1408" y="736" width="448" text="麟凌疾空-猛攻"/>
	<mx:Text styleName="textStyle11" x="1408" y="1024" width="448" text="原海古雷-爆发"/>
	<mx:Text styleName="textStyle11" x="736" y="736" width="448" text="始海之泉-锁定"/>
	<mx:Text styleName="textStyle11" x="736" y="1024" width="448" text="明珠鸣雷-再生"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle13" x="64" y="1188" width="448" alpha="0.75" text="异海珍珠：19雷盾，击破使其进入无珠状态；免疫扩散附着；第二次及后续再生时只有11.4雷盾。共鸣珊瑚珠：0.4雷盾，击破扣除异海珍珠当前剩余-当前/3雷，若未及时破除，每个珍珠则将恢复异海珍珠当前/3+2雷。"/>
