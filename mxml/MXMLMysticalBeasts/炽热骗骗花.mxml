	<mx:Image source="Image3.png" x="64" y="781" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="火骗骗花消耗一个火之实进行蓄力，蓄力时附属星火胄甲，破坏即眩晕，蓄力完成后朝玩家连续抛射12个火焰弹，每个造成40%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="512" width="448" alpha="0.9" text="常发生在拔假植物、突然刷出时施放。火骗骗花从地下钻出，对地面上单位造成200%伤害，即将钻出时地面会有对应特效。一般闪现不会造成伤害。"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="焚原百焰-爆发"/>
	<mx:Text styleName="textStyle9" x="1408" y="448" width="448" text="根巡·灼光-突袭"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="火骗骗花持续发射1-3个持续追踪的火焰弹，造成22%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="512" width="448" alpha="0.9" text="火骗骗花旋转花瓣，造成3段33.3%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="800" width="448" alpha="0.9" text="火骗骗花初始附属3枚「火之实」，每施放一次爆发就消耗1个「火之实」。当「火之实」全部消耗后，其会停止攻击，钻地并重新装填3个「火之实」。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="微蕴光火-追踪"/>
	<mx:Text styleName="textStyle9" x="736" y="448" width="448" text="风扇·流炎-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="736" width="448" text="暖焰火实-天赋"/>
