	<mx:Text styleName="textStyle7" x="736" y="256" width="448" alpha="0.9" text="疾叶化身标记玩家，在原地进行吟唱，并在标记处产生爆炸，爆炸产生额外的2道振波，这些都造成90%,22.5%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="480" width="448" alpha="0.9" text="疾叶化身释放一枚魔咒，坠落在玩家处并留下毒化迷雾，迷雾持续造成20%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="704" width="448" alpha="0.9" text="疾叶化身朝玩家方向蓄力，迸发草元素脉冲，造成70%伤害。"/>
	<mx:Text styleName="textStyle7" x="736" y="928" width="448" alpha="0.9" text="疾叶化身即刻展开试炼领域，并获得白护盾，从领域内不断产生向外的互相垂直的4道亡蓟涟漪，造成50%伤害(闪避帧无效)，重复3回，最后收回领域并产生旋蔓崩破，造成100%伤害，所剩的护盾将转为等量悬木之灵御。"/>
	<mx:Text styleName="textStyle8" x="736" y="192" width="448" text="梢驰杪张-输出"/>
	<mx:Text styleName="textStyle8" x="736" y="416" width="448" text="翠柳垂阴-定点"/>
	<mx:Text styleName="textStyle8" x="736" y="640" width="448" text="咒阵流韵-远程"/>
	<mx:Text styleName="textStyle8" x="736" y="864" width="448" text="浮灵亡蓟-强化"/>
	<mx:Text styleName="textStyle9" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
