	<mx:Text styleName="textStyle" x="64" y="480" width="410" text="焚天爆炎树"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="608" width="332" text="温顺的潜在伙伴"/>
	<mx:Text styleName="textStyle4" x="64" y="928" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：PO[75,50,25,0]"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="305" text="HP: 603258 (9.9F)"/>
	<mx:Text styleName="textStyle7" x="64" y="736" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="816" width="375" text="ATK: 36376 (13.933B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="864" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="561" width="395" alpha="0.75" text="Sky-Searing Pyro Regisvine"/>
	<mx:Text styleName="textStyle9" x="64" y="651" width="395" alpha="0.75" text="Gentle Potential Companion"/>
	<mx:Image source="Image4.png" x="64" y="973" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="瘫痪恢复后，爆炎树在原地快速旋转一圈半，造成85%伤害，旋转之前的砸地也造成85%伤害。"/>
	<mx:Image source="Image5.png" x="1268" y="171" width="128" height="128"/>
	<mx:Image source="Image6.png" x="1248" y="150" width="168" height="170"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="双炎轮转-苏醒"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle13" x="64" y="1224" width="448" alpha="0.75" text="冠部核心：36火盾(削弱词条26火)，击破后转至根部；根部核心：4火盾(削弱词条2火)，击破可瘫痪爆炎树15s(削弱词条21s)。"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="爆炎树朝地面猛锤，锤点造成85%伤害，形成3道冲击波，各造成50%伤害，该技能可连续进行3次锤击。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="处在爆炎树后方时，爆炎树向玩家方向迅速旋转半圈，造成85%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="爆炎树使用藤条在空中召出8个火球，火球缓慢追踪玩家，造成12.5%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="爆炎树使用藤条对着玩家，藤条迅速发射8组火焰弹，火焰弹造成20%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1120" width="448" alpha="0.9" text="爆炎树的花冠垂直收缩下压，造成100%伤害，并在其周身生成熔岩，持续造成30%伤害；后立即在近地面喷射烈火，瞬间造成90%伤害，火焰持续喷射造成70%,17.5%,1.75%,0.7%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="896" width="448" alpha="0.9" text="爆炎树朝前方扇形区域喷射大量火球，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1120" width="448" alpha="0.9" text="爆炎树首先在冠部形成核心，被击破后直接转移到根部形成核心，击破后则将再次在冠部形成核心。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="爆炎树进行左砸划-右砸划-锤击三段连击，砸击造成75%伤害，划击造成85%伤害，产生的震波造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="破除冠部核心后，爆炎树的花冠朝天，在场地边缘连续召唤绕场地逆时针旋转的7排火喷，均造成60%伤害，并产生强斥力风场排开玩家。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="炎花热浪-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="余焰未熄-防卫"/>
	<mx:Text styleName="textStyle11" x="736" y="608" width="448" text="星焰光火-追踪"/>
	<mx:Text styleName="textStyle11" x="736" y="832" width="448" text="流星火迹-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="1056" width="448" text="焚风炙金-猛攻"/>
	<mx:Text styleName="textStyle11" x="1408" y="832" width="448" text="俱焱一隅-猛攻"/>
	<mx:Text styleName="textStyle11" x="1408" y="1056" width="448" text="赤心炉火-转换"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="飒光红流-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="608" width="448" text="赤潮劫阵-爆发"/>
