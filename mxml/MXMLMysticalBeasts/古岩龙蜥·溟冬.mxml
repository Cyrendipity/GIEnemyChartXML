	<mx:Text styleName="textStyle" x="64" y="384" width="483" text="古岩龙蜥·溟冬"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="305" text="圆滚滚肚皮"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="64" y="672" width="405" text="HP: 1554760 (25.515F)"/>
	<mx:Text styleName="textStyle6" x="64" y="640" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="720" width="375" text="ATK: 33778 (12.938B2)"/>
	<mx:Text styleName="textStyle5" x="64" y="768" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle7" x="64" y="446" width="395" alpha="0.75" text="Wintry Primo Geovishap"/>
	<mx:Text styleName="textStyle8" x="64" y="555" width="395" alpha="0.75" text="Round Tummy Tum Tum"/>
	<mx:Text styleName="textStyle9" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Image source="Image4.png" x="64" y="64" width="256" height="256"/>
	<mx:Text styleName="textStyle10" x="1387" y="64" width="469" alpha="0.5" text="元素能量：WP[66,33],WO[0x2]"/>
	<mx:Text styleName="textStyle11" x="736" y="224" width="448" alpha="0.9" text="古岩龙蜥使用右爪挥扫，造成对应元素的40%伤害；古岩龙蜥使用左爪敲地，后拔扯，敲地和拔扯依次造成对应元素的35%,15%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" alpha="0.9" text="古岩龙蜥进行右爪扫-左爪划-双爪拍三段攻击，其依次造成对应元素的40%,50%,62.5%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" alpha="0.9" text="处于古岩龙蜥身后时，古岩龙蜥使用尾部旋扫一圈，造成80%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" alpha="0.9" text="古岩龙蜥凝聚自身元素，朝前方扇形区域扫过，造成对应元素的40%,20%,10%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="928" width="448" alpha="0.9" text="古岩龙蜥会依据自身属性产生「龙鳞」，不同元素的攻击方式不同：清涟：朝玩家方向产生7~8次水喷，每个水喷造成16%伤害；青霜：产生三波冰棘，依次造成25%,25%,37.5%伤害。「龙鳞」将在古岩龙蜥施放「原岩喷吐」或「晶鳞四处」或被某些攻击打断时立即消失。"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" alpha="0.9" text="古岩龙蜥抖动全身，飞出8个对应元素的「龙鳞」，落地后绕龙蜥围成一圈，然后敲一下地板造成对应元素的80%伤害。施放后可转换元素属性，顺序为冰水。"/>
	<mx:Text styleName="textStyle11" x="1408" y="224" width="448" alpha="0.9" text="古岩龙蜥大跳移步，落地造成对应元素的70%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="爪犁寒池-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="左右开攻-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="浮金飘尘-防卫"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="南寒吐息-妨害"/>
	<mx:Text styleName="textStyle12" x="1408" y="864" width="448" text="龙灵残煜-天赋"/>
	<mx:Text styleName="textStyle12" x="1408" y="608" width="448" text="晶鳞四处-埋伏"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="步潭履冰-位移"/>
	<mx:Image source="Image5.png" x="596" y="619" width="128" height="128"/>
