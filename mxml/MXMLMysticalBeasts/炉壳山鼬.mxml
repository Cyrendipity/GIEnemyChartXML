	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="山鼬进行抓划、尾扫、纵尾至多3段的攻击，依次造成45%,60%,75%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="距离较远时，山鼬蜷尾迅速翻滚而来，触碰持续造成10%伤害；抵达玩家处或超时后接甩尾，造成100%伤害。可被「突角龙」的能力打断而不受伤。"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" alpha="0.9" text="距离较远时，山鼬利用尾部的秘源机核发射激光，造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" alpha="0.9" text="山鼬钻入地下，原地留下秘源机核保护，其持续施放秘源金浪，造成80%伤害，最多重复4/6(深渊)回后钻出地面。实际上就是开了个盾。"/>
	<mx:Text styleName="textStyle9" x="736" y="192" width="448" text="茹炙弥身-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="圣山碎阳-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="640" width="448" text="镌纹金束-定点"/>
	<mx:Text styleName="textStyle9" x="736" y="864" width="448" text="灼械之下-防御"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="64" y="541" width="416" text="远古圣山的巡猎者"/>
	<mx:Text styleName="textStyle12" x="64" y="584" width="395" alpha="0.75" text="Hunter of the Ancient Sacred Mountain"/>
