	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="圣骸毒蝎进行右劈、左劈、十字劈三段攻击，分别造成30%,30%,50%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="512" width="448" alpha="0.9" text="距离玩家较远时，圣骸毒蝎钻入地下，在玩家处突然出现并咬合双钳，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="800" width="448" alpha="0.9" text="每45s-60s，圣骸毒蝎旋转自身扔出14个碎鳞片，自身旋转造成30%伤害，随后敲击地面，使碎鳞片下落，敲击造成70%伤害，甩出和下落的碎鳞片都造成100%伤害，并形成「噬骸能量块·雷」；此时毒蝎失去强化，6s后则会被毒蝎吸收恢复强化。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="圣骸毒蝎进行十字斩、左右交互扎地、尾电毒针三段复杂攻击，分别造成60%,30%x4,80%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="512" width="448" alpha="0.9" text="圣骸毒蝎将自己的尾部和钳插入地面，在周围按顺时针或逆时针方向产生数个电爪，每个电爪造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="800" width="448" alpha="0.9" text="圣骸毒蝎从开局、瘫痪恢复后或者吸收「噬骸能量块·雷」之后，将进行抗性强化：雷抗+60%，其他抗性+30%，并且全身变亮；该效果持续到其施放「地虾钻」技能后，或被携带有「噬骸能量块·雷」的玩家命中后失效。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="蝎爪功-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="448" width="448" text="龙蝎爪-位移"/>
	<mx:Text styleName="textStyle11" x="736" y="736" width="448" text="地虾钻-噬骸爆发"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="蝎子钩-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="448" width="448" text="螃蟹钳-妨害"/>
	<mx:Text styleName="textStyle11" x="1408" y="736" width="448" text="蝎子触电-天赋"/>
