	<mx:Text styleName="textStyle8" x="64" y="465" width="395" alpha="0.75" text="Radiant Moongecko"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="407" alpha="0.75" text="Moonseeker Drake"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="0" y="959" width="64" text="正常"/>
	<mx:Text styleName="textStyle11" x="0" y="1010" width="64" text="深渊大招后"/>
	<mx:Text styleName="textStyle12" x="736" y="224" width="448" alpha="0.9" text="鳞蜥进行右咬、左咬、下扑至多3段的普攻，依次造成40%,50%,65%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="512" width="448" alpha="0.9" text="鳞蜥凝聚力量，用凝晶的尾部发射岩流，造成75%伤害。"/>
	<mx:Text styleName="textStyle12" x="736" y="800" width="448" alpha="0.9" text="开局或瘫痪恢复后施放，鳞蜥为自身附上晖岩之护，岩抗提升60%；展开半径25m的蕴光领域；清除任意角色的「蕴光之茧」时，晖岩之护将被立即破坏。施放「行虚空荡」之前，全队的「蕴光之茧」会被移除(仅移除，无增益)。"/>
	<mx:Text styleName="textStyle13" x="736" y="160" width="448" text="峰岩残响-输出"/>
	<mx:Text styleName="textStyle13" x="736" y="448" width="448" text="断尾棱光-远程"/>
	<mx:Text styleName="textStyle13" x="736" y="736" width="448" text="鎏月余晖-妨害"/>
	<mx:Text styleName="textStyle14" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle12" x="1408" y="224" width="448" alpha="0.9" text="距离太近或处于后方时，鳞蜥迅速自转扫尾，造成100%伤害。"/>
	<mx:Text styleName="textStyle12" x="1408" y="512" width="448" alpha="0.9" text="鳞蜥在场地内促生多个岩蕨，每个造成35%伤害。"/>
	<mx:Text styleName="textStyle12" x="1408" y="800" width="448" alpha="0.9" text="鳞蜥移动到场地中央，展开穹顶，隐匿自身，并留下「月锚岩」；穹顶上有三只鳞蜥，其中一只会间歇性发射岩流，造成75%伤害；25s后月锚岩爆炸，造成200%伤害。"/>
	<mx:Text styleName="textStyle13" x="1408" y="160" width="448" text="窟明回鉴-防御"/>
	<mx:Text styleName="textStyle13" x="1408" y="448" width="448" text="嵴生石蕨-定点"/>
	<mx:Text styleName="textStyle13" x="1408" y="736" width="448" text="行虚空荡-召唤"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 300/4000"/>
