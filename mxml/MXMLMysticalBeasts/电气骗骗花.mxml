	<mx:Text styleName="textStyle7" x="64" y="465" width="395" alpha="0.75" text="Electro Whopperflower"/>
	<mx:Image source="Image3.png" x="64" y="781" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="224" width="448" alpha="0.9" text="雷骗骗花喷出3个电磁球，落地造成33%伤害，持续接触造成10%伤害，其会作为障碍，一直抵挡弹射物攻击直至其消失。"/>
	<mx:Text styleName="textStyle8" x="736" y="512" width="448" alpha="0.9" text="雷骗骗花旋转花瓣，造成3段50%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="800" width="448" alpha="0.9" text="雷骗骗花初始附属3枚「雷之实」，每施放一次爆发就消耗1个「雷之实」。当「雷之实」全部消耗后，其会停止攻击，钻地并重新装填3个「雷之实」。"/>
	<mx:Text styleName="textStyle8" x="1408" y="224" width="448" alpha="0.9" text="雷骗骗花消耗一个雷之实进行蓄力，并附属薄雷胄甲，破坏即眩晕。蓄力完成后发射激光，直接命中造成50%伤害，激光可能产生连续爆炸，每下造成100%伤害。"/>
	<mx:Text styleName="textStyle8" x="1408" y="512" width="448" alpha="0.9" text="常发生在拔假植物、突然刷出时施放。雷骗骗花从地下钻出，对地面上单位造成300%伤害。即将钻出时地面会有对应特效。一般闪现不会造成伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="160" width="448" text="斥场磁球-防卫"/>
	<mx:Text styleName="textStyle9" x="736" y="448" width="448" text="风扇·漏电-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="736" width="448" text="微光雷实-天赋"/>
	<mx:Text styleName="textStyle9" x="1408" y="160" width="448" text="伏雷裂电-爆发"/>
	<mx:Text styleName="textStyle9" x="1408" y="448" width="448" text="根巡·紫光-突袭"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="64" y="972" width="448" alpha="0.75" text="薄雷胄甲：0.4雷盾，击破使其眩晕一段时间。该状态下，质量翻6倍。"/>
