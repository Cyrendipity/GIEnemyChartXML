	<mx:Text styleName="textStyle9" x="64" y="651" width="395" alpha="0.75" text="Ancient Lord of the Mountains"/>
	<mx:Image source="Image4.png" x="64" y="973" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="猊兽凌空翻卷，朝玩家发射2刀水镜波刃，均造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="猊兽蜷尾，扫吹出数个锦标，与风蚀沙虫类似，其环围有余，每个均造成60%,30%,12%,6%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="992" width="448" alpha="0.9" text="猊兽前足一蹬，扬起暴风，造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="猊兽使唤风之仙力，召唤3个逆时针旋转的灵风珠，猊兽在原地持续鼓风，造成60%伤害；10s后，猊兽施放碎玉翠尘，造成大范围的200%伤害。尚存的灵风珠将转为移动的风涡，持续控制玩家的同时持续造成30%伤害。生命值低于40%时，会施放一次。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="镜水清刃-远程"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="猊兽击尾，在玩家处生成一个泉喷，造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="猊兽进行宁神嚣灭，汲取水之仙力，在原地产生的泉眼处，泉眼持续造成70%伤害；泉眼还将在周围不断产生泉涌，造成70%伤害；10s后，猊兽降下涂炭怒涛，生成7波潮涌，造成200%伤害。生命值低于70%时，会施放一次。"/>
	<mx:Text styleName="textStyle10" x="1408" y="992" width="448" alpha="0.9" text="猊兽进行一次宁神嚣灭，朝玩家处游走一段距离，该技能也可作为技能「鸿泷山涧」的前摇。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="猊兽引风凌空，造成80%伤害，后以迅雷之势下落，一发激起千层浪，造成100%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="粼泉潮湃-定点"/>
	<mx:Text styleName="textStyle11" x="736" y="608" width="448" text="鸿泷山涧-爆发"/>
	<mx:Text styleName="textStyle11" x="1408" y="928" width="448" text="游川行泽-位移"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="纵云缀波-输出"/>
