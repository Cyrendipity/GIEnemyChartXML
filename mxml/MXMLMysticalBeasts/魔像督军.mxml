	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle6" x="64" y="864" width="305" text="HP: 865176 (15.6F)"/>
	<mx:Text styleName="textStyle7" x="64" y="832" width="305" alpha="0.75" text="首领-「福波斯」 Lv.100 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="912" width="375" text="ATK: 22160 (9.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="960" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="465" width="395" alpha="0.75" text="Legatus Golem"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="439" alpha="0.75" text="“Statue of Marble and Brass”"/>
	<mx:Image source="Image4.png" x="64" y="1069" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="开局入战时，站在石台上的督军突然跃下，造成50%伤害。本技能仅督军位于石台雕像状态下，开局入战施放。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="阶下威马-突袭"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="切弦低语-位移"/>
	<mx:Text styleName="textStyle11" x="1408" y="416" width="448" text="曲终成律-召唤"/>
	<mx:Text styleName="textStyle11" x="1408" y="704" width="448" text="弦断麾时-位移"/>
	<mx:Text styleName="textStyle11" x="1408" y="960" width="448" text="四弦三声-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="704" width="448" text="嘈弦急雨-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="960" width="448" text="铜骑枪鸣-爆发"/>
	<mx:Text styleName="textStyle11" x="736" y="1216" width="448" text="急弦转促-突袭"/>
	<mx:Text styleName="textStyle11" x="736" y="416" width="448" text="五调三音-输出"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="督军利用盾与剑作一曲消愁。演奏过程中，督军会不断散落轻音，造成40%伤害；曲终之时拨一重音，声声入耳，造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="督军唤出一枚谐振器，并进行终曲调谐。调谐一完毕，谐振器立即销毁，产生激荡的虹波，造成90%伤害。提前摧毁谐振器可以打断督军攻击。"/>
	<mx:Text styleName="textStyle10" x="1408" y="768" width="448" alpha="0.9" text="距离较远时，督军放下乐器进行追逐，直到目标之处，激奏上挑，造成70%伤害。一般后接「转急促弦」。"/>
	<mx:Text styleName="textStyle10" x="1408" y="1024" width="448" alpha="0.9" text="距离较远时，督军怒而一拨，四弦一声如裂帛，出现三刀火刃，均造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="768" width="448" alpha="0.9" text="督军剑指上方，从里向外奏鸣出数个轻音，如数下落，造成70%,7%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1024" width="448" alpha="0.9" text="督军置剑于地，从内向外奏响三拍激昂之调，造成100%伤害；之后跳起，作曲一拍之终，造成200%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1280" width="448" alpha="0.9" text="督军进行至多2段的多种攻击：跺-盾、跺-切；其中盾、跺、切分别依次造成60%,70%,80%伤害，进行盾攻击之后还会产生音律地波，造成60%,6%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="督军进行至多3段的多种攻击：左-右-盾、左-跺-切、左-右-切；其中左、右、盾、跺、切分别依次造成50%,60%,60%,70%,80%伤害，进行盾攻击之后还会产生音律地波，造成60%,6%伤害。"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
