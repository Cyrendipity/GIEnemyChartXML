	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="(仅盾)泡泡雄海马使用硬壳质的雷元素力量，凝聚雷元素闪电球，造成80%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="(仅盾)泡泡雄海马使用尖角序列，发射雷电弧，造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="928" width="448" alpha="0.9" text="泡泡雄海马使用尖角发射气泡水弹，造成100%伤害。"/>
