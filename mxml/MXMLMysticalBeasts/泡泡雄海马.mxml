	<mx:Text styleName="textStyle11" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle12" x="64" y="1164" width="448" alpha="0.75" text="硬壳质：7.2雷盾，击破后将不会使用部分技能，不恢复。该状态下，抗打断0.7。"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" alpha="0.9" text="(仅盾)泡泡雄海马甩出2个雷棘，其追踪玩家，均造成35%伤害。"/>
	<mx:Text styleName="textStyle13" x="736" y="1152" width="448" alpha="0.9" text="(固有天赋)泡泡雄海马处于陆地上时，会打开元素护甲使用元素力，而进入水下则会暂时关闭护甲，保留关前盾量。"/>
