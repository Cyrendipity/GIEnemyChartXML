	<mx:Text styleName="textStyle" x="64" y="384" width="410" text="翠翎恐蕈"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="305" text="深居幽林的蕈王"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1247" y="64" width="609" alpha="0.5" text="元素能量：DP[0],DO[66,33,0]"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="305" text="HP: 853091 (14.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 18275 (7.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 250/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="465" width="395" alpha="0.75" text="Jadeplume Terrorshroom"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="Deepwood Shroomlord"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="翠翎恐蕈进行左划、啄地、起跳至多三段的普通攻击，起跳自身附着草，左划与啄地造成60%伤害，起跳造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="翠翎恐蕈进行左扫、右扫、翻扫至多三段的攻击。每一扫都扔出5个孢弹，且均自身附着草，每个孢弹造成30%,15%,3%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="翠翎恐蕈产生菌雾，向空中吟叫3次后产生爆炸(前2次自身挂草)，造成50%伤害，并向外产生2道扩散震波，也造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="当翠翎恐蕈自身被触发燃烧时，其会变黑，然后发射3个大型孢子，只能使用火和雷摧毁，每个孢子爆炸造成50%伤害，并召唤1个枯焦的浮游草蕈兽，之后翠翎恐蕈恢复正常。场上至多存在4个召唤的蕈兽。"/>
	<mx:Text styleName="textStyle11" x="64" y="1072" width="448" alpha="0.75" text="怒气：100草充能盾，受到雷元素攻击+2/次，触发任意激化+15/次，受到火元素攻击-34/次。触发燃烧直接枯焦。"/>
	<mx:Text styleName="textStyle12" x="736" y="160" width="448" text="蕈王喙尘-输出"/>
	<mx:Text styleName="textStyle12" x="736" y="384" width="448" text="尾羽飞扇-追踪"/>
	<mx:Text styleName="textStyle12" x="736" y="608" width="448" text="亚稳孢云-猛攻"/>
	<mx:Text styleName="textStyle12" x="736" y="832" width="448" text="灰复烬生-天赋"/>
	<mx:Text styleName="textStyle12" x="1408" y="160" width="448" text="不羁之行-爆发"/>
	<mx:Text styleName="textStyle12" x="1408" y="384" width="448" text="孢羽囊扇-爆发"/>
	<mx:Text styleName="textStyle12" x="1408" y="608" width="448" text="蕈王疾舞-爆发"/>
	<mx:Text styleName="textStyle12" x="1408" y="832" width="448" text="蕈王尖鸣-白给"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="翠翎恐蕈激化一式：疯狂向玩家冲来，触碰依次造成120%,48%,12%伤害，来回撞击2次，全程自身附着草，然后眩晕20s。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="翠翎恐蕈激化二式：蓄力施放巨量孢子，孢子弱追踪玩家，每个孢子造成45%,22.5%,4.5%,0.45%伤害，技能结束眩晕20s。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="翠翎恐蕈激化三式：在原地疯狂进行挑动，持续4次，造成120%,60%伤害，技能结束眩晕20s。"/>
	<mx:Text styleName="textStyle10" x="1408" y="896" width="448" alpha="0.9" text="距离翠翎恐蕈比较远时，翠翎恐蕈会短暂展开尾翼鸣叫，并自身附着草，该技能不造成伤害。"/>
	<mx:Text styleName="textStyle13" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
