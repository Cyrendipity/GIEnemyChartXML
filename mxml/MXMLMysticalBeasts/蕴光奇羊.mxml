	<mx:Text styleName="textStyle7" x="64" y="465" width="395" alpha="0.75" text="Radiant Antelope"/>
	<mx:Image source="Image4.png" x="64" y="781" width="484" height="124"/>
	<mx:Text styleName="textStyle8" x="736" y="256" width="448" alpha="0.9" text="奇羊进行角突、后蹬两段攻击，依次造成50%,60%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="480" width="448" alpha="0.9" text="奇羊朝玩家直突而来，途径接触造成20%伤害，行至玩家处进行一次角突，造成70%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="704" width="448" alpha="0.9" text="奇羊突然跳起，给予重重一挑，造成70%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="928" width="448" alpha="0.9" text="奇羊展开半径15m的蕴光领域，顺绕一圈造成40%伤害，随后在玩家处依次降下两道落雷，分别造成50%,70%伤害。"/>
	<mx:Text styleName="textStyle8" x="736" y="1152" width="448" alpha="0.9" text="奇羊展开半径15m的蕴光领域，凝聚雷光朝玩家发射，造成100%伤害。"/>
	<mx:Text styleName="textStyle9" x="736" y="192" width="448" text="光流躁步-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="416" width="448" text="蛮羊长突-位移"/>
	<mx:Text styleName="textStyle9" x="736" y="640" width="448" text="苍霆斗角-输出"/>
	<mx:Text styleName="textStyle9" x="736" y="864" width="448" text="银索连乍-定点"/>
	<mx:Text styleName="textStyle9" x="736" y="1088" width="448" text="谲光掣闪-远程"/>
	<mx:Text styleName="textStyle10" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle11" x="64" y="912" width="448" alpha="0.75" text="蕴光领域：展开时施加「蕴光之茧」状态，扣除全队角色10%+1800点生命值，若角色生命值低于7200点，则改为扣除35%生命值，可致命但可开大招躲避；主动治疗清除后获得「出缠」效果。若范围内前台角色仍处于「蕴光之茧」状态，奇羊则不会施放「银索连乍」、「谲光掣闪」。蕴光之茧：暴击率-10%，造成的伤害-10%，受治疗加成-10%。出缠：暴击率+15%，造成的伤害+50%，持续15s。"/>
