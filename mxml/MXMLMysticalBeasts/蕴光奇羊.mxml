	<mx:Text styleName="textStyle" x="64" y="384" width="519" text="蕴光奇羊"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="736" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle4" x="576" y="128" width="546" alpha="0.5" text="元素能量：EP[66x2,33x2,0x2]"/>
	<mx:Text styleName="textStyle5" x="64" y="576" width="305" text="HP: 610060 (11.0F)"/>
	<mx:Text styleName="textStyle6" x="64" y="544" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle5" x="64" y="624" width="375" text="ATK: 14773 (6.0B2)"/>
