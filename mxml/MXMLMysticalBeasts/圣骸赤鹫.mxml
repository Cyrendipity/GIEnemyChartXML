	<mx:Text styleName="textStyle" x="64" y="384" width="410" text="圣骸赤鹫"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="416" text="啃噬伟大生命的火之兽"/>
