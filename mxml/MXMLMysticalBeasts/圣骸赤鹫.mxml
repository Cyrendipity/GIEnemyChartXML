	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="圣骸赤鹫进行啄击、右翼翻转两段攻击，分别造成50%,70%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="距离玩家更远时，圣骸赤鹫振翅起飞，朝玩家飞过来，两翼交替施放火焰弹落地轰炸，每个火焰弹造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="736" width="448" alpha="0.9" text="每45s-60s，圣骸赤鹫升空化作火球，产生并发射大量焰飞刃对准玩家，命中造成50%,25%,12.5%,5%伤害，同时形成「噬骸能量块·火」；此时赤鹫失去强化抗性正常，6s后则会被赤鹫吸收恢复强化。"/>
	<mx:Image source="Image5.png" x="1268" y="171" width="128" height="128"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="钩折扫-输出"/>
	<mx:Text styleName="textStyle11" x="1408" y="416" width="448" text="鹫平飞-妨害"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" text="羽飞刃-噬骸爆发"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="圣骸赤鹫进行双啄击、左爪划、旋火龙卷三段攻击，分别造成50%x2,80%,100%伤害，及时远离可以打断旋火龙卷的攻击。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="距离玩家较远时，圣骸赤鹫振翅起跳，在玩家处下落，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" alpha="0.9" text="处于赤鹫后方时，圣骸赤鹫瞬间转身攻击，造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="1024" width="1024" alpha="0.9" text="圣骸赤鹫从开局、瘫痪恢复后或者吸收「噬骸能量块·火」之后，将进行抗性强化：火抗+60%，其他抗性+30%，并且全身变亮；该效果持续到其施放「羽飞刃」技能后，或被携带有「噬骸能量块·火」的玩家命中后失效。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="赤鹫爪-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="416" width="448" text="鹰落地-远程"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" text="鹰回头-防卫"/>
	<mx:Text styleName="textStyle11" x="736" y="960" width="448" text="秃鹫扑火-天赋"/>
