	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="岩龙蜥汲取火元素，火抗+20%，此后的所有攻击均附带火元素附魔，同时攻击倍率提升；下落时会产生额外的地刺造成伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="汲取赤炎-强化"/>
	<mx:Image source="Image8.png" x="1268" y="171" width="128" height="128"/>
