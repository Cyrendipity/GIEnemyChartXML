	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="岩龙蜥汲取雷元素，雷抗+20%，此后的所有攻击均产生一定数量的游离雷球，游离的雷球触碰即造成30%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="汲取雳电-强化"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="岩龙蜥汲取冰元素，冰抗+20%，此后岩龙蜥进行攻击时会在其附近产生冰簇，冰簇会在触碰或5s后爆破，造成35%伤害。"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="汲取霜霰-强化"/>
