	<mx:Text styleName="textStyle" x="64" y="480" width="442" text="掣电树"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="608" width="305" text="电荷喷薄的巨藤"/>
	<mx:Text styleName="textStyle4" x="64" y="928" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：EO[75,50,25,0]"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="305" text="HP: 275905 (7.0H)"/>
	<mx:Text styleName="textStyle7" x="64" y="736" width="305" alpha="0.75" text="首领 Lv.103 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="816" width="375" text="ATK: 13054 (5.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="864" width="375" text="Wt/Ed: 300/4000"/>
	<mx:Text styleName="textStyle8" x="64" y="561" width="395" alpha="0.75" text="Electro Regisvine"/>
	<mx:Text styleName="textStyle9" x="64" y="651" width="395" alpha="0.75" text="Giant Sparksurge Calamus"/>
	<mx:Image source="Image4.png" x="64" y="973" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="掣电树朝地面猛锤，锤点造成100%伤害，形成3道冲击波，各造成50%伤害，该技能可连续进行3次锤击。"/>
	<mx:Text styleName="textStyle10" x="736" y="448" width="448" alpha="0.9" text="处在掣电树后方时，掣电树向玩家方向迅速旋转半圈，造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="672" width="448" alpha="0.9" text="掣电树使用藤条，一次产生3个雷棘，总计4次，雷棘锁定玩家的方位，每个雷棘造成40%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="896" width="448" alpha="0.9" text="掣电树使用藤条随机召唤3道落雷，每道落雷造成40%伤害，一共召唤4批。"/>
	<mx:Text styleName="textStyle10" x="736" y="1120" width="832" alpha="0.9" text="掣电树首先在冠部形成核心，此时花冠呈黄色，约30s后会将其转移至根部，此时花冠呈紫色，交替进行。掣电树见面及核心转移至冠部时种下盈极花蕊，造成40%伤害；转移至根部时种下虚极花蕊，造成100%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="896" width="448" alpha="0.9" text="掣电树花冠朝近处地面发射激光，来回扫两趟，均造成造成75%伤害，后对准玩家喷射电激光，持续造成25%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="672" width="448" alpha="0.9" text="若盈极花蕊与虚极花蕊均存在于场上，则两极将相吸，产生大范围爆炸，造成300%伤害(闪避帧无效)。两极可被元素反应破坏，但在互相吸引时则不行。"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="瘫痪恢复后，掣电树在原地快速旋转一圈半，造成75%伤害，旋转之前的砸地也造成75%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="448" width="448" alpha="0.9" text="掣电树进行左砸划-右砸划-锤击三段连击，均造成75%伤害，产生的震波造成50%伤害。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="霆花碎暗-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="384" width="448" text="驰掣低鸣-防卫"/>
	<mx:Text styleName="textStyle11" x="736" y="608" width="448" text="紫雷蛰棘-追踪"/>
	<mx:Text styleName="textStyle11" x="736" y="832" width="448" text="紫雷迷林-限制"/>
	<mx:Text styleName="textStyle11" x="736" y="1056" width="448" text="震心曝闪-转换"/>
	<mx:Text styleName="textStyle11" x="1408" y="832" width="448" text="烫璃炙金-持续"/>
	<mx:Text styleName="textStyle11" x="1408" y="608" width="448" text="电荷相撞-爆发"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="雳击轮转-苏醒"/>
	<mx:Text styleName="textStyle11" x="1408" y="384" width="448" text="噬霆回绝-输出"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle13" x="64" y="1164" width="448" alpha="0.75" text="盈虚花蕊：2雷盾，击破可阻止掣电树施放电荷相撞。原循环核心：16雷盾，初始位于冠部，会周期性在冠部和根部转移，击破可瘫痪掣电树18s。次循环核心：8雷盾，为原循环核心的再生版本，以后生成的都是该种核心，击破可瘫痪掣电树18s。"/>
