	<mx:Text styleName="textStyle" x="64" y="384" width="448" text="圣骸角鳄"/>
	<mx:Text styleName="textStyle2" x="576" y="64" width="522" text="全技能一图流"/>
	<mx:Text styleName="textStyle3" x="64" y="512" width="423" text="啃噬伟大生命的水之兽"/>
	<mx:Text styleName="textStyle4" x="64" y="832" width="305" alpha="0.9" text="抗性数据(单位%)"/>
	<mx:Text styleName="textStyle5" x="1387" y="64" width="469" alpha="0.5" text="元素能量：HP[66x2,33x2,0x2]"/>
	<mx:Text styleName="textStyle6" x="64" y="672" width="305" text="HP: 388220 (7.0F)"/>
	<mx:Text styleName="textStyle7" x="64" y="640" width="305" alpha="0.75" text="精英 Lv.100 Data"/>
	<mx:Text styleName="textStyle6" x="64" y="720" width="375" text="ATK: 14773 (6.0B2)"/>
	<mx:Text styleName="textStyle6" x="64" y="768" width="375" text="Wt/Ed: 150/400"/>
	<mx:Text styleName="textStyle8" x="64" y="465" width="395" alpha="0.75" text="Consecrated Horned Crocodile"/>
	<mx:Text styleName="textStyle9" x="64" y="555" width="395" alpha="0.75" text="The Surging One, Devourer of the Mighty"/>
	<mx:Image source="Image4.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle10" x="1408" y="224" width="448" alpha="0.9" text="圣骸角鳄的角左右晃动，发射2个水刃，均造成60%伤害，最后使用尾部发射水刃，造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="480" width="448" alpha="0.9" text="玩家处在其后方时，圣骸角鳄转身甩尾造成70%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="736" width="448" alpha="0.9" text="距离玩家较远时，圣骸角鳄张着嘴冲过来，造成50%伤害。"/>
	<mx:Text styleName="textStyle10" x="1408" y="992" width="448" alpha="0.9" text="圣骸角鳄从开局、瘫痪恢复后或者吸收「噬骸能量块·水」之后，将进行抗性强化：水抗+60%，其他抗性+30%，并且全身变亮；该效果持续到其施放「鲸戏水」技能后，或被携带有「噬骸能量块·水」的玩家命中后失效。"/>
	<mx:Text styleName="textStyle11" x="1408" y="160" width="448" text="角涎波-远程"/>
	<mx:Text styleName="textStyle11" x="1408" y="416" width="448" text="蜥蜴尾-防卫"/>
	<mx:Text styleName="textStyle11" x="1408" y="672" width="448" text="蛞蝓跑-追击"/>
	<mx:Text styleName="textStyle11" x="1408" y="928" width="448" text="鳄鱼划水-天赋"/>
	<mx:Image source="Image5.png" x="1268" y="171" width="128" height="128"/>
	<mx:Text styleName="textStyle12" x="896" y="64" width="228" text="制图@Csxylic米游社"/>
	<mx:Text styleName="textStyle10" x="736" y="224" width="448" alpha="0.9" text="圣骸角鳄进行右划、冲咬、甩尾、翻砸四段攻击，分别造成60%,70%,80%,100%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="480" width="448" alpha="0.9" text="圣骸角鳄进行上咬合攻击，造成70%伤害，顺势倒下翻滚，造成90%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="736" width="448" alpha="0.9" text="距离玩家较远时，圣骸角鳄如龙蜥般潜入地面，期间触碰持续造成10%伤害，至玩家处钻出，造成50%伤害，并顺势落地，造成80%伤害。"/>
	<mx:Text styleName="textStyle10" x="736" y="992" width="448" alpha="0.9" text="每45s-60s，圣骸角鳄在玩家处生成大水喷，造成80%伤害，接着在外环进行二次水喷，造成100%伤害，形成「噬骸能量块·水」；此时角鳄失去强化，6s后则会被角鳄吸收恢复强化。"/>
	<mx:Text styleName="textStyle11" x="736" y="160" width="448" text="鳄翻身-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="416" width="448" text="猪打泥-输出"/>
	<mx:Text styleName="textStyle11" x="736" y="672" width="448" text="龙潜游-位移"/>
	<mx:Text styleName="textStyle11" x="736" y="928" width="448" text="鲸戏水-噬骸爆发"/>
