	<mx:Text styleName="textStyle5" x="64" y="446" width="395" alpha="0.75" text="Biting-Cold Wayob Manifestation"/>
	<mx:Image source="Image8.png" x="64" y="877" width="484" height="124"/>
	<mx:Text styleName="textStyle6" x="736" y="256" width="448" alpha="0.9" text="凛冽化身在玩家处召唤白晶流幕，持续造成20%,10%,5%,2%伤害。"/>
	<mx:Text styleName="textStyle6" x="736" y="480" width="448" alpha="0.9" text="凛冽化身朝玩家方向蓄力，迸发寒涛冽流，造成70%伤害。"/>
	<mx:Text styleName="textStyle6" x="736" y="704" width="448" alpha="0.9" text="凛冽化身凝聚碎冰，片刻后向前扇形区域挥洒暴风雪，持续造成50%,25%,12.5%,5%伤害"/>
	<mx:Text styleName="textStyle6" x="736" y="928" width="448" alpha="0.9" text="凛冽化身即刻展开试炼领域，并获得白护盾，从领域内不断产生向外的互相垂直的4幕霜华白英，造成多段50%伤害(闪避帧无效)，重复4回，最后收回领域并产生皎厄尖冰，造成100%伤害，所剩的护盾将转为等量烟谜之灵御。"/>
